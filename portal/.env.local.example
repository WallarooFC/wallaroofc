# ---------------------------------------------------------------------------
# Wallaroo FC Secretary Portal — environment variables
# Copy to .env.local and fill in values. The app refuses to boot if a required
# var is missing (validated by @t3-oss/env-nextjs in src/env.ts).
# ---------------------------------------------------------------------------

# Supabase ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Portal URLs ---------------------------------------------------------------
NEXT_PUBLIC_PORTAL_URL=https://portal.wallaroofc.com
NEXT_PUBLIC_PUBLIC_SITE_URL=https://wallaroofc.com

# Email (Resend) ------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=secretary@wallaroofc.com.au
RESEND_INBOUND_SECRET=

# SMS (Twilio) — set SMS_ENABLED=false until a Twilio number is procured.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Cron --------------------------------------------------------------------
CRON_SECRET=

# Microsoft OAuth (set TENANT_ID to "common" to support both M365 and personal)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

# Allow-list for magic-link sign-in (comma-separated emails)
ALLOW_LIST_EMAILS=secretary@wallaroofc.com.au,president@wallaroofc.com.au
