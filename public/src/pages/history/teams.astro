---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { ERA_TEAMS } from '../../lib/teams-of-era.ts';

// Half-century is the feature; the five decade teams follow.
const feature = ERA_TEAMS.find(t => t.id === 'half-century')!;
const decades = ERA_TEAMS.filter(t => t.id !== 'half-century');

// Rows for the classic footy line-up display order (forward line first)
const ROWS = [
  { key: 'forwards',      label: 'Forwards' },
  { key: 'half_forwards', label: 'Half Forwards' },
  { key: 'centre',        label: 'Centre' },
  { key: 'half_back',     label: 'Half Back' },
  { key: 'backs',         label: 'Backs' },
] as const;
---
<PageLayout
  title="Teams of the Era · Wallaroo FC"
  description="The Wallaroo Football Club's Team of the Last 50 Years and Teams of the 70s, 80s, 90s, 00s and 10s — the Bulldog XVIIIs that defined each decade."
>
  <PageHero
    eyebrow="Teams of the Era"
    title="The Bulldog XVIIIs,"
    titleItalic="decade by decade."
    intro="Voted by the club — the Team of the Last 50 Years, and one XVIII for each decade back to the 1970s. Every Bulldog on these teams pulled on the red, white and blue with distinction."
  />

  <!-- ── Feature: Team of the Last 50 Years ─────────────────────── -->
  <section class="feature">
    <div class="container wide">
      <div class="eyebrow feature-eyebrow">The Half Century</div>
      <div class="feature-inner">
        <div class="feature-head">
          <h2>Team of the Last 50 Years</h2>
          <p class="feature-sub">{feature.subtitle}</p>
          {feature.note && <p class="feature-note">"{feature.note}"</p>}
        </div>
        <article class="team-card feature-card">
          <header class="team-card-head">
            <span class="team-card-label">Team of the</span>
            <h3>Last 50 Years</h3>
          </header>
          <div class="team-body">
            {ROWS.map(row => (
              <div class="team-row">
                <div class="row-label">{row.label}</div>
                <div class="row-pills">
                  {feature.positions[row.key].map(n => (
                    <span class="pos-pill">{n}</span>
                  ))}
                </div>
              </div>
            ))}
            <div class="team-row split">
              <div class="row-half">
                <div class="row-label">First Ruck</div>
                <div class="pos-column">
                  {feature.positions.first_ruck.map(n => <span class="pos-pill">{n}</span>)}
                </div>
              </div>
              <div class="row-half">
                <div class="row-label">Bench</div>
                <div class="pos-column">
                  {feature.positions.bench.map(n => <span class="pos-pill">{n}</span>)}
                </div>
              </div>
            </div>
            {feature.positions.coach && (
              <div class="team-coach">
                <span class="coach-label">Coach</span>
                <span class="coach-name">{feature.positions.coach}</span>
              </div>
            )}
            <div class="team-footnote">* denotes 2nd Ruck</div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Decade grid ────────────────────────────────────────────── -->
  <section class="decades">
    <div class="container wide">
      <div class="eyebrow">Decade by Decade</div>
      <h2>Five decades,<span class="ital"> five Bulldog XVIIIs.</span></h2>
      <p class="lede">
        The teams that defined each ten-year window. Some names appear across
        multiple decades — that's what it means to be a Bulldog for life.
      </p>

      <div class="decade-grid">
        {decades.map(t => (
          <article class="team-card">
            <header class="team-card-head">
              <span class="team-card-label">Team of the</span>
              <h3>{t.title.replace('Team of the ', '')}</h3>
            </header>
            <div class="team-body compact">
              {ROWS.map(row => (
                <div class="team-row">
                  <div class="row-label">{row.label}</div>
                  <div class="row-pills">
                    {t.positions[row.key].map(n => <span class="pos-pill">{n}</span>)}
                  </div>
                </div>
              ))}
              <div class="team-row split">
                <div class="row-half">
                  <div class="row-label">First Ruck</div>
                  <div class="pos-column">
                    {t.positions.first_ruck.map(n => <span class="pos-pill">{n}</span>)}
                  </div>
                </div>
                <div class="row-half">
                  <div class="row-label">Bench</div>
                  <div class="pos-column">
                    {t.positions.bench.map(n => <span class="pos-pill">{n}</span>)}
                  </div>
                </div>
              </div>
              <div class="team-footnote">* denotes 2nd Ruck</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Attribution ────────────────────────────────────────────── -->
  <section class="attribution">
    <div class="container narrow">
      <div class="eyebrow">Voted by the Club</div>
      <h3>Bulldog for life.</h3>
      <p>
        These teams were selected by past players, coaches and officials of the
        Wallaroo Football Club. If you spot a mis-spelled name or think we've missed
        a Bulldog, get in touch —
        <a href="mailto:admin@wallaroofc.com.au">admin@wallaroofc.com.au</a>.
      </p>
      <p>
        More Bulldog history sits in the <a href="/history">Heritage collection</a>:
        the <a href="/history/records">Historical Records</a>,
        the <a href="/history/premiership-players">Premiership Roll</a>,
        the <a href="/history/chronicle">Club Chronicle</a>,
        the <a href="/history/team-lists">Team-List Archive</a>.
      </p>
    </div>
  </section>
</PageLayout>

<style>
  .container { margin: 0 auto; max-width: 1200px; }

  .eyebrow {
    font-family: var(--headline); font-size: 13px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--red); margin-bottom: 14px;
    display: flex; align-items: center; gap: 14px;
  }
  .eyebrow::before { content: ''; width: 32px; height: 3px; background: var(--red); }

  h2 {
    font-family: var(--display);
    font-size: clamp(36px, 5vw, 60px);
    text-transform: uppercase;
    color: var(--blue-deep);
    line-height: 0.95;
    margin: 0 0 14px;
  }
  h2 .ital {
    font-family: var(--serif); font-style: italic; color: var(--red);
    text-transform: none; letter-spacing: -0.02em;
  }
  h3 {
    font-family: var(--display);
    font-size: clamp(24px, 3vw, 34px);
    text-transform: uppercase;
    color: var(--blue-deep);
    letter-spacing: 0.02em;
    margin: 0 0 12px;
  }

  .lede {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--charcoal);
    margin-bottom: 40px;
    max-width: 780px;
  }

  /* ── Feature (Half Century) ─────────────────────────────────── */
  .feature {
    background: var(--blue-darkest);
    color: var(--white);
    padding: 100px 32px;
    border-top: 4px solid var(--red);
  }
  .feature-eyebrow { color: rgba(255,255,255,0.75); }
  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 60px;
    align-items: center;
  }
  .feature-head h2 { color: var(--white); font-size: clamp(40px, 5vw, 68px); }
  .feature-sub {
    font-family: var(--headline);
    font-size: 14px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin: 4px 0 24px;
  }
  .feature-note {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    border-left: 3px solid var(--red);
    padding-left: 20px;
  }

  /* ── Team card (poster style) ────────────────────────────────── */
  .team-card {
    background: var(--blue-deep);
    border: 3px solid var(--red);
    border-radius: 6px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    overflow: hidden;
    color: var(--white);
  }
  .feature-card { max-width: 620px; margin: 0 auto; }
  .team-card-head {
    background: var(--blue-darkest);
    text-align: center;
    padding: 22px 20px 18px;
    border-bottom: 2px solid var(--red);
  }
  .team-card-label {
    display: block;
    font-family: var(--headline);
    font-size: 13px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 4px;
  }
  .team-card-head h3 {
    font-family: var(--display);
    font-size: clamp(30px, 4vw, 44px);
    color: var(--white);
    letter-spacing: 0.04em;
    line-height: 1;
    margin: 0;
  }
  .team-body {
    padding: 22px 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .team-body.compact { padding: 18px 20px 16px; gap: 10px; }
  .team-row { display: flex; flex-direction: column; gap: 6px; }
  .row-label {
    font-family: var(--headline);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
  }
  .row-pills {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 6px;
  }
  .pos-pill {
    background: var(--red);
    color: var(--white);
    font-family: var(--headline);
    font-size: clamp(11px, 1.5vw, 14px);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 10px;
    text-align: center;
    border-radius: 3px;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .team-row.split {
    flex-direction: row;
    gap: 20px;
    padding-top: 6px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .row-half { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .pos-column { display: flex; flex-direction: column; gap: 4px; }
  .pos-column .pos-pill { text-align: left; padding: 6px 10px; }

  .team-coach {
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 10px;
  }
  .coach-label {
    font-family: var(--headline);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }
  .coach-name {
    font-family: var(--display);
    font-size: 18px;
    color: var(--red);
    letter-spacing: 0.04em;
  }

  .team-footnote {
    font-family: var(--serif);
    font-size: 11px;
    font-style: italic;
    color: rgba(255,255,255,0.5);
    text-align: center;
    margin-top: 4px;
  }

  /* ── Decade grid ─────────────────────────────────────────────── */
  .decades { background: var(--cream); padding: 90px 32px; border-bottom: 1px solid var(--line); }
  .decade-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 24px;
  }

  /* ── Attribution ────────────────────────────────────────────── */
  .attribution { background: var(--white); padding: 80px 32px 100px; border-top: 1px solid var(--line); max-width: none; }
  .attribution .container { max-width: 800px; }
  .attribution p {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.7;
    color: var(--charcoal);
    margin-bottom: 16px;
  }
  .attribution a {
    color: var(--red);
    border-bottom: 2px solid var(--red);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .feature-inner { grid-template-columns: 1fr; gap: 32px; }
    .feature-head { text-align: center; }
    .feature-note { text-align: left; }
  }
  @media (max-width: 720px) {
    .feature, .decades, .attribution { padding: 56px 20px; }
    .row-pills { grid-template-columns: 1fr; }
    .team-row.split { flex-direction: column; }
  }
</style>
