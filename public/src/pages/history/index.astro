---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PremiershipWall from '../../components/PremiershipWall.astro';
import Heritage from '../../components/Heritage.astro';
import { CLASSIC_BOARD, EXPANDED_BOARD, MAIL_MEDALS, GOAL_KICKERS, LIFE_MEMBERS, GAMES_CLUB } from '../../lib/honour-roll.ts';

// Premierships by grade
const GRADE_FLAGS = [
  {
    grade: 'A Grade',
    count: 27,
    years: [1889,1892,1896,1897,1899,1900,1902,1905,1913,1914,1919,1920,1925,1927,1945,1950,1952,1953,1954,1976,1983,1990,1992,1996,1997,1998,2000],
  },
  {
    grade: 'Reserves / A2 / B Grade',
    count: 7,
    years: [1952,1958,1982,1990,1996,1997,1998],
  },
  {
    grade: 'Senior Colts',
    count: 13,
    years: [1953,1959,1962,1964,1981,1987,1988,1993,2014,2022,2023,2024,2025],
  },
  {
    grade: 'Junior Colts',
    count: 4,
    years: [1991,2021,2022,2025],
  },
  {
    grade: 'Combined Juniors / Reserves (pre-1946)',
    count: 9,
    years: [1911,1912,1925,1926,1927,1934,1936,1942,1943],
  },
];

// A Grade flag years for highlighting
const A_FLAG_YEARS = new Set([1889,1892,1896,1897,1899,1900,1902,1905,1913,1914,1919,1920,1925,1927,1945,1950,1952,1953,1954,1976,1983,1990,1992,1996,1997,1998,2000]);

// Special awards
const FRANK_AWARDS = EXPANDED_BOARD.filter(r => r.frank).map(r => ({ year: r.year, winner: r.frank }));
const BOWMAN_AWARDS = EXPANDED_BOARD.filter(r => r.bowman).map(r => ({ year: r.year, winner: r.bowman }));

// B Grade board — only rows with at least one entry
const B_BOARD = EXPANDED_BOARD.filter(r => r.b_coach || r.b_captain || r.b_bf || r.b_goals);

// Games club grouped by band
const gamesByBand = [
  { label: '300+ Games',  rows: GAMES_CLUB.filter(p => p.games >= 300) },
  { label: '250+ Games',  rows: GAMES_CLUB.filter(p => p.games >= 250 && p.games < 300) },
  { label: '200+ Games',  rows: GAMES_CLUB.filter(p => p.games >= 200 && p.games < 250) },
  { label: '150+ Games',  rows: GAMES_CLUB.filter(p => p.games >= 150 && p.games < 200) },
];

// Life members grouped by decade
const decades: { decade: string; rows: typeof LIFE_MEMBERS }[] = [];
let currentDecade = -1;
for (const m of [...LIFE_MEMBERS].sort((a, b) => a.year - b.year)) {
  const dec = Math.floor(m.year / 10) * 10;
  if (dec !== currentDecade) {
    currentDecade = dec;
    decades.push({ decade: `${dec}s`, rows: [] });
  }
  decades[decades.length - 1].rows.push(m);
}
---
<PageLayout
  title="Heritage & History · Wallaroo FC"
  description="Founded 17 June 1867 at the Globe Inn. One of Australia's oldest continuously running football clubs. Club records from 1900, honor boards, 89 life members, 150 Games Club."
>
  <PageHero
    eyebrow="The Heritage"
    title="Founded at the Globe Inn,"
    titleItalic="17 June 1867."
    intro="159 winters on the Yorke Peninsula. Never merged, never folded. One of Australia's oldest continuously running football clubs."
  />

  <!-- Deep archives navigation -->
  <section class="deep-archives">
    <div class="container wide">
      <div class="eyebrow">Deep Archives</div>
      <h2>The <span class="ital">source records.</span></h2>
      <p class="lede">
        Four companion documents preserved from the club archive — each a piece of the
        story from the game's earliest days on the Yorke Peninsula.
      </p>
      <div class="archive-cards">
        <a href="/history/records" class="archive-card feature">
          <span class="ac-eyebrow">1888 – 2008</span>
          <h3>Historical Records</h3>
          <p>The full 122-page ledger — YPFL ladders, mail medallists, other-grade premierships and every Bulldog to the SANFL. The showpiece.</p>
          <span class="ac-cta">Open the records →</span>
        </a>
        <a href="/history/chronicle" class="archive-card">
          <span class="ac-eyebrow">1884 – 1967</span>
          <h3>Club Chronicle</h3>
          <p>168 entries transcribed from newspaper reports — meetings, matches, presentations and premierships across 83 years.</p>
          <span class="ac-cta">Read the chronicle →</span>
        </a>
        <a href="/history/premiership-players" class="archive-card">
          <span class="ac-eyebrow">1902 – 2000</span>
          <h3>Premiership Roll</h3>
          <p>Every Bulldog to have played in a Wallaroo A Grade premiership — 242 names spanning 23 flag seasons.</p>
          <span class="ac-cta">Open the honour roll →</span>
        </a>
        <a href="/history/team-lists" class="archive-card">
          <span class="ac-eyebrow">1888 – 1980</span>
          <h3>Team-List Archive</h3>
          <p>Ninety-two years of A Grade line-ups scanned from the newspaper archive. The record that carries us into the modern games register.</p>
          <span class="ac-cta">Browse the archive →</span>
        </a>
      </div>
    </div>
  </section>

  <Heritage />

  <PremiershipWall />

  <!-- All grades premiership records -->
  <section class="all-grades">
    <div class="container wide">
      <div class="eyebrow">The Full Record</div>
      <h2>Premierships <span class="ital">across all grades.</span></h2>
      <p class="lede">From junior ranks to A Grade, the Bulldogs have lifted a combined 60 flags. Here's the full record by grade.</p>
      <div class="grade-grid">
        {GRADE_FLAGS.map(g => (
          <div class="grade-card">
            <div class="grade-name">{g.grade}</div>
            <div class="grade-count">{g.count}</div>
            <div class="grade-years">{g.years.join('  ·  ')}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Club Officials 1900–2026 -->
  <section class="board-section">
    <div class="container wide">
      <div class="eyebrow">Club Officials</div>
      <h2>Presidents, Secretaries <span class="ital">&amp; Treasurers.</span></h2>
      <p class="lede">Every office-bearer on record from 1900 to present.</p>

      <h3 class="sub-heading">1900 – 1969</h3>
      <div class="hb-wrap">
        <table class="hb-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>President</th>
              <th>Secretary</th>
            </tr>
          </thead>
          <tbody>
            {CLASSIC_BOARD.map(r => (
              <tr>
                <td class="year-cell">{r.year}</td>
                <td>{r.president || '—'}</td>
                <td>{r.secretary || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="sub-heading" style="margin-top:48px">1970 – 2026</h3>
      <div class="hb-wrap">
        <table class="hb-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>President</th>
              <th>Secretary</th>
              <th>Treasurer</th>
            </tr>
          </thead>
          <tbody>
            {EXPANDED_BOARD.map(r => (
              <tr>
                <td class="year-cell">{r.year}</td>
                <td>{r.president || '—'}</td>
                <td>{r.secretary || '—'}</td>
                <td>{r.treasurer || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- A Grade Honor Board -->
  <section class="board-section alt">
    <div class="container wide">
      <div class="eyebrow">Honor Board</div>
      <h2>A Grade <span class="ital">year by year.</span></h2>
      <p class="lede">Captain, coach, best and fairest, and leading goalkicker for every A Grade season on record. ★ marks a premiership year.</p>

      <h3 class="sub-heading">1900 – 1969 &nbsp;<span class="sub-note">(captain only recorded)</span></h3>
      <div class="hb-wrap">
        <table class="hb-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>A Grade Captain</th>
            </tr>
          </thead>
          <tbody>
            {CLASSIC_BOARD.map(r => (
              <tr class={A_FLAG_YEARS.has(r.year) ? 'flag-year' : ''}>
                <td class="year-cell">{r.year}{A_FLAG_YEARS.has(r.year) ? ' ★' : ''}</td>
                <td>{r.a_captain || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="sub-heading" style="margin-top:48px">1970 – 2026</h3>
      <div class="hb-wrap">
        <table class="hb-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Coach</th>
              <th>Captain</th>
              <th>Best &amp; Fairest</th>
              <th>Leading Goals</th>
            </tr>
          </thead>
          <tbody>
            {EXPANDED_BOARD.map(r => (
              <tr class={A_FLAG_YEARS.has(r.year) ? 'flag-year' : ''}>
                <td class="year-cell">{r.year}{A_FLAG_YEARS.has(r.year) ? ' ★' : ''}</td>
                <td>{r.a_coach || '—'}</td>
                <td>{r.a_captain || '—'}</td>
                <td>{r.a_bf || '—'}</td>
                <td>{r.a_goals || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- B Grade Honor Board -->
  <section class="board-section">
    <div class="container wide">
      <div class="eyebrow">Honor Board</div>
      <h2>B Grade <span class="ital">year by year.</span></h2>
      <p class="lede">Coach, captain, best and fairest, and leading goalkicker for B Grade seasons on record.</p>
      <div class="hb-wrap">
        <table class="hb-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Coach</th>
              <th>Captain</th>
              <th>Best &amp; Fairest</th>
              <th>Leading Goals</th>
            </tr>
          </thead>
          <tbody>
            {B_BOARD.map(r => (
              <tr>
                <td class="year-cell">{r.year}</td>
                <td>{r.b_coach || '—'}</td>
                <td>{r.b_captain || '—'}</td>
                <td>{r.b_bf || '—'}</td>
                <td>{r.b_goals || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Special Club Awards -->
  <section class="awards-section alt">
    <div class="container wide">
      <div class="eyebrow">Special Awards</div>
      <h2>Club <span class="ital">awards.</span></h2>
      <p class="lede">Annual club awards recognising outstanding contribution and achievement.</p>
      <div class="awards-cols">
        <div class="award-col">
          <h3 class="award-title">Frank Dietritch Award</h3>
          <table class="award-table">
            <thead><tr><th>Year</th><th>Winner</th></tr></thead>
            <tbody>
              {FRANK_AWARDS.map(a => (
                <tr><td class="year-cell">{a.year}</td><td>{a.winner}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="award-col">
          <h3 class="award-title">Bowman 31 Award</h3>
          <table class="award-table">
            <thead><tr><th>Year</th><th>Winner</th></tr></thead>
            <tbody>
              {BOWMAN_AWARDS.map(a => (
                <tr><td class="year-cell">{a.year}</td><td>{a.winner}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- League Awards -->
  <section class="awards-section">
    <div class="container wide">
      <div class="eyebrow">League Awards</div>
      <h2>YPFL <span class="ital">awards.</span></h2>
      <p class="lede">Yorke Peninsula Football League individual awards won by Wallaroo FC players.</p>
      <div class="awards-cols">
        <div class="award-col">
          <h3 class="award-title">Mail Medal</h3>
          <table class="award-table">
            <thead><tr><th>Year</th><th>Winner</th><th>Grade</th></tr></thead>
            <tbody>
              {MAIL_MEDALS.map(a => (
                <tr><td class="year-cell">{a.year}</td><td>{a.winner}</td><td class="grade-tag">{a.grade}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="award-col">
          <h3 class="award-title">Leading Goal Kicker</h3>
          <table class="award-table">
            <thead><tr><th>Year</th><th>Winner</th><th>Goals</th></tr></thead>
            <tbody>
              {GOAL_KICKERS.map(a => (
                <tr><td class="year-cell">{a.year}</td><td>{a.winner}</td><td class="goals-count">{a.goals}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Life Members -->
  <section class="life-members alt">
    <div class="container wide">
      <div class="eyebrow">Honour Roll</div>
      <h2>Life Members <span class="ital">since 1945.</span></h2>
      <p class="lede">89 names. Each inducted by committee vote for a lifetime's service to the club. Without these people, there is no Bulldogs.</p>
      <div class="decades">
        {decades.map(d => (
          <div class="decade">
            <h3>{d.decade}</h3>
            <ul>
              {d.rows.map(m => (
                <li><span class="year">{m.year}</span><span class="name">{m.name}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 150 Games Club -->
  <section class="games-club">
    <div class="container wide">
      <div class="eyebrow">The 150 Games Club</div>
      <h2><span class="ital">A century and a half.</span></h2>
      <p class="lede">Bulldogs who have played 150 or more senior games for the club. Led by <strong>Darren Smith (390)</strong> and <strong>Lindsay Smith (312)</strong> — two men, more than 700 games between them.</p>
      <div class="bands">
        {gamesByBand.map(band => (
          <div class="band">
            <h3>{band.label}</h3>
            <ol class="players">
              {band.rows.map(p => (
                <li>
                  <span class="name">{p.name}</span>
                  {p.games > 0 ? <span class="games">{p.games}</span> : <span class="games games-lm">LM</span>}
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Story -->
  <section class="long-form">
    <div class="container narrow">
      <h2>The story</h2>

      <h3>17 June 1867 · the Globe Inn</h3>
      <p>The club was established on the evening of 17 June 1867, at a meeting held at the Globe Inn. <strong>The Globe Inn still stands today as the Weeroona Hotel</strong> — same walls, same Wallaroo street corner.</p>
      <p>The minute book records the moment plainly: <em>"about a dozen members joined and paid their subs, then had a few preliminary kicks in the park with a first-rate ball obtained from Adelaide."</em></p>
      <p>The inaugural match was scheduled for <strong>20 June 1867</strong>, at a ground west of Mr Shepherdson's property — near the western end of town, close to where the silos stand today.</p>

      <h3>First recorded game · 1874</h3>
      <p>The first officially recorded game took place in <strong>1874 between Wallaroo and Moonta</strong>. Wallaroo wore blue. Moonta wore pink. Australian rules football was barely codified.</p>
      <p>Comprehensive results, team lists and premiership records survive from <strong>1888 onward</strong>, maintained continuously through every era since.</p>

      <h3>Red joins the blue and white</h3>
      <p>Through the early 20th century the club won A-Grade premierships across multiple competitions. In the late 1960s the nickname shifted from the Seagulls to the Bulldogs, and red joined the blue and white — the colours every player and supporter wears today.</p>
      <p>The first Bulldog flag came soon after. Senior Colts have added five flags since 2014.</p>

      <h3>Same ground, six generations</h3>
      <p>Wallaroo FC has played on the same patch of ground — Cornish Terrace, Wallaroo — since 1867. The clubrooms have been rebuilt, the oval re-turfed, the scoreboard digitised — but every player who has ever pulled on the jumper has done so on the same Wallaroo Oval grass.</p>
      <p>Many families across the Yorke Peninsula are now into their fifth or sixth generation of Bulldogs.</p>

      <h3>Through every era</h3>
      <p>Two World Wars. The Great Depression. The decline and revival of country football. Mining boom, mining bust. Drought years. The merger talks of the 80s — and the firm decision to stay independent. The Bulldogs played through all of it.</p>
      <p>If you've spent any time around the clubrooms you've heard the stories. Every Bulldog you meet has one to tell.</p>

      <h3>Acknowledgment of Country</h3>
      <p>Wallaroo Football Club acknowledges the Narungga people as the Traditional Custodians of the lands on which we play, train and gather. We pay our respects to Elders past and present, and recognise the continuing connection of First Nations people to the country, waters and culture of the Yorke Peninsula.</p>

      <h3>Archives &amp; research</h3>
      <p>The club holds an archive of minute books, jumpers, photographs, team-of-year records and complete premiership records from 1888 to present, maintained by club Historian <strong>Michael West</strong>. Researchers and family-history enthusiasts are welcome to make an appointment via <a href="mailto:admin@wallaroofc.com.au">admin@wallaroofc.com.au</a>.</p>
      <p class="note">★ The premiership years highlighted are representative pending verification with the Historian. If you spot an error, please get in touch.</p>
    </div>
  </section>
</PageLayout>

<style>
  /* ── Shared utilities ───────────────────────────────────────────────── */
  .container { margin: 0 auto; }
  .container.wide  { max-width: 1200px; }
  .container.narrow { max-width: 760px; font-family: var(--serif); font-size: 18px; line-height: 1.7; color: var(--charcoal); }

  .eyebrow { font-family: var(--headline); font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; display: flex; align-items: center; gap: 14px; }
  .eyebrow::before { content: ''; width: 36px; height: 3px; background: var(--red); }

  h2 { font-family: var(--display); font-size: clamp(40px, 5vw, 64px); text-transform: uppercase; line-height: 0.95; margin-bottom: 16px; }
  h2 .ital { font-family: var(--serif); font-style: italic; color: var(--red); text-transform: none; letter-spacing: -0.02em; }

  .lede { font-family: var(--serif); font-size: 19px; line-height: 1.65; margin-bottom: 40px; max-width: 720px; }

  .sub-heading { font-family: var(--display); font-size: 20px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--blue-deep); margin: 0 0 16px; }
  .sub-note { font-family: var(--serif); font-size: 13px; text-transform: none; letter-spacing: 0; color: var(--grey); font-style: italic; }

  /* ── Shared table ───────────────────────────────────────────────────── */
  .hb-wrap { overflow-x: auto; border-radius: 6px; box-shadow: 0 2px 16px rgba(0,0,0,0.07); margin-bottom: 8px; }
  .hb-table { width: 100%; border-collapse: collapse; background: var(--white); font-family: var(--body); font-size: 14px; }
  .hb-table thead th { background: var(--blue-deep); color: var(--white); font-family: var(--headline); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; padding: 12px 16px; text-align: left; white-space: nowrap; }
  .hb-table tbody tr { border-bottom: 1px solid var(--line); transition: background 0.15s; }
  .hb-table tbody tr:hover { background: rgba(20,49,92,0.04); }
  .hb-table tbody td { padding: 9px 16px; color: var(--charcoal); vertical-align: middle; }
  .hb-table tbody tr.flag-year { background: rgba(200,16,46,0.06); }
  .hb-table tbody tr.flag-year:hover { background: rgba(200,16,46,0.10); }
  .year-cell { font-family: var(--display); font-size: 14px; color: var(--blue-deep); letter-spacing: 0.04em; white-space: nowrap; font-weight: 700; }
  .flag-year .year-cell { color: var(--red); }

  /* ── Deep Archives ────────────────────────────────────────────────── */
  .deep-archives {
    background: var(--blue-darkest);
    color: var(--white);
    padding: 100px 32px;
    border-bottom: 3px solid var(--red);
  }
  .deep-archives h2 { color: var(--white); }
  .deep-archives .lede { color: rgba(255,255,255,0.75); max-width: 720px; }
  .archive-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 8px;
  }
  .archive-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-left: 4px solid var(--red);
    padding: 28px 30px;
    border-radius: 4px;
    text-decoration: none;
    color: var(--white);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.2s, transform 0.15s;
  }
  .archive-card:hover {
    background: rgba(200, 16, 46, 0.1);
    transform: translateY(-3px);
  }
  .archive-card.feature {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, rgba(200,16,46,0.14), rgba(200,16,46,0.06));
    border-left-width: 6px;
    padding: 32px 34px;
  }
  .archive-card.feature h3 { font-size: 40px; }
  .archive-card.feature p { font-size: 17px; }
  @media (min-width: 900px) {
    .archive-card.feature { display: grid; grid-template-columns: 220px 1fr auto; align-items: center; gap: 24px; }
    .archive-card.feature .ac-eyebrow { align-self: center; }
    .archive-card.feature h3 { grid-column: 2; margin: 0; }
    .archive-card.feature p { grid-column: 2; }
    .archive-card.feature .ac-cta { grid-column: 3; border-top: none; padding-top: 0; padding-left: 20px; border-left: 1px solid rgba(255,255,255,0.15); align-self: center; }
  }
  .ac-eyebrow {
    font-family: var(--headline);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
  }
  .archive-card h3 {
    font-family: var(--display);
    font-size: 30px;
    letter-spacing: 0.02em;
    color: var(--white);
    margin: 0;
    text-transform: uppercase;
    line-height: 1.05;
  }
  .archive-card p {
    font-family: var(--serif);
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    flex: 1;
  }
  .ac-cta {
    font-family: var(--headline);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    padding-top: 6px;
    border-top: 1px solid rgba(255,255,255,0.15);
  }

  /* ── Section backgrounds ────────────────────────────────────────────── */
  .all-grades   { background: var(--blue-darkest); color: var(--white); padding: 100px 32px; }
  .board-section { background: var(--white); padding: 100px 32px; border-top: 1px solid var(--line); }
  .board-section.alt { background: var(--cream); }
  .awards-section { background: var(--white); padding: 100px 32px; border-top: 1px solid var(--line); }
  .awards-section.alt { background: var(--cream); }
