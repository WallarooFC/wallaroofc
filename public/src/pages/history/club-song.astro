---
import PageLayout from '../../layouts/PageLayout.astro';

// The club song — two verses, sung after every win.
// Lines below match the club's canonical text, with the single spelling
// correction "loose" → "lose" applied.

const VERSE_1 = [
  'Cheer Boys Cheer',
  'We Are Wallaroo',
  'It\'s only now and then we lose a game',
  'We\'ll play them all around',
  'On their home or any ground',
  'If they only play a fair and honest game',
];

const CHORUS = [
  'WE ARE WALLAROO',
  'We Are The Team',
  'We Can\'t Be Beaten',
  'That\'s Easy Seen',
  'At The End Of The Season',
  'You\'ll Know The Reason',
  'We Are The Premier Team',
  'YEAH !!',
];
---
<PageLayout
  title="The Club Song · Wallaroo FC"
  description="Cheer Boys Cheer — We Are Wallaroo. The Bulldog anthem, sung on the fence after every Wallaroo Football Club win."
>
  <!-- ── Hero ───────────────────────────────────────────────────── -->
  <section class="song-hero">
    <div class="hero-inner">
      <div class="eyebrow">The Bulldog Anthem</div>
      <h1>
        <span class="cheer">Cheer</span>
        <span class="boys">Boys</span>
        <span class="cheer2">Cheer</span>
      </h1>
      <p class="hero-lead">
        Every time a Bulldog crosses the white line and wins, the song rings
        out on the fence. Learn the words — you'll want them by the time we lift the next flag.
      </p>
    </div>
    <div class="hero-glow"></div>
  </section>

  <!-- ── Verse 1 ────────────────────────────────────────────────── -->
  <section class="verse verse-1">
    <div class="verse-inner">
      <div class="verse-label">Verse</div>
      <div class="lyric-block">
        {VERSE_1.map((line, i) => (
          <p class={`lyric lyric-${i}`}>{line}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Chorus ─────────────────────────────────────────────────── -->
  <section class="verse chorus">
    <div class="verse-inner">
      <div class="verse-label chorus-label">Chorus</div>
      <div class="lyric-block">
        {CHORUS.map((line, i) => {
          const isRoar   = line === 'WE ARE WALLAROO';
          const isYeah   = line === 'YEAH !!';
          const cls = isRoar ? 'lyric big-roar' : isYeah ? 'lyric yeah' : 'lyric chorus-line';
          return <p class={cls}>{line}</p>;
        })}
      </div>
    </div>
  </section>

  <!-- ── After the whistle ─────────────────────────────────────── -->
  <section class="footer-band">
    <div class="footer-inner">
      <div class="eyebrow">After the whistle</div>
      <h2>Sing it after every <span class="ital">Bulldog win.</span></h2>
      <p>
        For 159 winters on the Yorke Peninsula, the same words have echoed off the
        Wallaroo Oval clubrooms every Saturday the Bulldogs win. Learn them, teach
        them to your kids, roar them from the fence. That's what it means to be a Bulldog.
      </p>
      <div class="footer-links">
        <a href="/history">← Back to Heritage</a>
        <a href="/fixtures">Next Bulldog fixture →</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ── Shared ─────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--headline);
    font-size: 13px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--red);
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .eyebrow::before {
    content: '';
    width: 32px;
    height: 3px;
    background: var(--red);
  }

  /* ── Hero ───────────────────────────────────────────────────── */
  .song-hero {
    background: linear-gradient(180deg, var(--blue-darkest) 0%, var(--blue-deep) 100%);
    color: var(--white);
    padding: 120px 32px 100px;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid var(--red);
  }
  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .hero-glow {
    position: absolute;
    inset: -20% 30%;
    background: radial-gradient(closest-side, rgba(200,16,46,0.28), transparent 70%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
  }
  .song-hero h1 {
    font-family: var(--display);
    font-size: clamp(64px, 12vw, 180px);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 32px;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(12px, 3vw, 40px);
  }
  .song-hero h1 .cheer,
  .song-hero h1 .cheer2 { color: var(--red); }
  .song-hero h1 .boys { color: var(--white); }

  .hero-lead {
    font-family: var(--serif);
    font-size: clamp(16px, 1.8vw, 20px);
    font-style: italic;
    line-height: 1.6;
    color: rgba(255,255,255,0.78);
    max-width: 620px;
    margin: 0 auto;
  }
  .song-hero .eyebrow { color: rgba(255,255,255,0.7); }

  /* ── Verse sections ────────────────────────────────────────── */
  .verse {
    padding: clamp(72px, 10vw, 140px) 32px;
    text-align: center;
    position: relative;
  }
  .verse-inner { max-width: 900px; margin: 0 auto; }
  .verse-label {
    font-family: var(--headline);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 40px;
    display: inline-block;
    padding: 6px 16px;
    border-top: 2px solid var(--red);
    border-bottom: 2px solid var(--red);
  }

  .lyric-block {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 2.5vw, 26px);
  }

  .lyric {
    font-family: var(--display);
    font-size: clamp(28px, 4.5vw, 56px);
    letter-spacing: 0.02em;
    line-height: 1.15;
    color: var(--blue-deep);
    margin: 0;
    text-transform: none;
  }

  /* ── Verse 1 (cream background) ───────────────────────────── */
  .verse-1 { background: var(--cream); border-top: 1px solid var(--line); }

  /* Progressive emphasis on the second-verse rally lines */
  .verse-1 .lyric-1 { /* "We Are Wallaroo" */ font-family: var(--display); color: var(--red); font-size: clamp(36px, 5.5vw, 68px); }

  /* ── Chorus (dark rally hall) ─────────────────────────────── */
  .chorus {
    background: var(--blue-deep);
    color: var(--white);
    border-top: 2px solid var(--red);
    padding-bottom: clamp(96px, 12vw, 160px);
  }
  .chorus .verse-label { color: var(--red); border-color: var(--red); }
  .chorus .chorus-line { color: var(--white); }
  .chorus .big-roar {
    font-family: var(--display);
    color: var(--red);
    font-size: clamp(48px, 8vw, 96px);
    letter-spacing: 0.04em;
    text-shadow: 0 4px 40px rgba(200, 16, 46, 0.5);
    padding: 12px 0;
  }
  .chorus .yeah {
    font-family: var(--display);
    color: var(--red);
    font-size: clamp(72px, 10vw, 132px);
    letter-spacing: 0.04em;
    line-height: 1;
    padding-top: 8px;
    text-shadow: 0 6px 40px rgba(200, 16, 46, 0.6);
  }

  /* ── Footer band ────────────────────────────────────────── */
  .footer-band {
    background: var(--white);
    padding: 90px 32px 110px;
    border-top: 1px solid var(--line);
  }
  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-band h2 {
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 48px);
    text-transform: uppercase;
    color: var(--blue-deep);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin: 0 0 20px;
  }
  .footer-band h2 .ital {
    font-family: var(--serif);
    font-style: italic;
    color: var(--red);
    text-transform: none;
    letter-spacing: -0.02em;
  }
  .footer-band p {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.7;
    color: var(--charcoal);
    margin-bottom: 30px;
  }
  .footer-links {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-family: var(--headline);
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    text-decoration: none;
    border-bottom: 2px solid var(--red);
    padding-bottom: 2px;
  }
  .footer-links a:hover { color: var(--red-deep); border-color: var(--red-deep); }

  @media (max-width: 720px) {
    .song-hero { padding: 80px 24px 60px; }
    .verse { padding: 56px 20px; }
    .footer-band { padding: 60px 24px 80px; }
  }
</style>
