---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db = getAdminClient();

// ── POST handlers ─────────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = String(form.get('action') ?? '');

  if (action === 'add_sponsor') {
    const spSeason = form.get('sp_season');
    await db.from('sponsors').insert({
      name:          String(form.get('sp_name') ?? '').trim(),
      tier:          String(form.get('sp_tier') ?? ''),
      logo_url:      String(form.get('sp_logo') ?? '').trim() || null,
      website:       String(form.get('sp_website') ?? '').trim() || null,
      contact_name:  String(form.get('sp_cname') ?? '').trim() || null,
      contact_email: String(form.get('sp_cemail') ?? '').trim() || null,
      contact_phone: String(form.get('sp_cphone') ?? '').trim() || null,
      display_order: parseInt(String(form.get('sp_order') ?? '999')) || 999,
      season:        spSeason ? parseInt(String(spSeason)) : null,
      notes:         String(form.get('sp_notes') ?? '').trim() || null,
      active:        form.get('sp_active') === 'on',
    });
  }

  if (action === 'update_sponsor') {
    const spSeason = form.get('sp_season');
    await db.from('sponsors').update({
      name:          String(form.get('sp_name') ?? '').trim(),
      tier:          String(form.get('sp_tier') ?? ''),
      logo_url:      String(form.get('sp_logo') ?? '').trim() || null,
      website:       String(form.get('sp_website') ?? '').trim() || null,
      contact_name:  String(form.get('sp_cname') ?? '').trim() || null,
      contact_email: String(form.get('sp_cemail') ?? '').trim() || null,
      contact_phone: String(form.get('sp_cphone') ?? '').trim() || null,
      display_order: parseInt(String(form.get('sp_order') ?? '999')) || 999,
      season:        spSeason ? parseInt(String(spSeason)) : null,
      notes:         String(form.get('sp_notes') ?? '').trim() || null,
      active:        form.get('sp_active') === 'on',
    }).eq('id', String(form.get('sp_id') ?? ''));
  }

  if (action === 'toggle_sponsor') {
    const { data: spRow } = await db.from('sponsors').select('active').eq('id', String(form.get('sp_id') ?? '')).single();
    await db.from('sponsors').update({ active: !spRow?.active }).eq('id', String(form.get('sp_id') ?? ''));
  }

  if (action === 'delete_sponsor') {
    await db.from('sponsors').delete().eq('id', String(form.get('sp_id') ?? ''));
  }

  return Astro.redirect('/admin/sponsors');
}

// ── Data ──────────────────────────────────────────────────────────────────────
const { data: sponsors } = await db
  .from('sponsors')
  .select('*')
  .order('display_order')
  .order('name');

const TIERS = ['platinum', 'vip', 'gold', 'silver', 'bronze'];
const TIER_COLORS: Record<string, string> = {
  platinum: '#e2e8f0',
  vip:      '#f59e0b',
  gold:     '#eab308',
  silver:   '#94a3b8',
  bronze:   '#b45309',
};

const grouped: Record<string, any[]> = {};
for (const tier of TIERS) {
  grouped[tier] = (sponsors ?? []).filter((s: any) => s.tier === tier);
}
---

<AdminLayout title="Sponsors">

  <!-- Toolbar -->
  <div class="toolbar">
    <button class="btn-primary" id="add-sponsor-btn">+ Add Sponsor</button>
    <span class="count">
      {(sponsors ?? []).length} sponsors · {(sponsors ?? []).filter((s: any) => s.active).length} active
    </span>
  </div>

  <!-- Tier sections -->
  {TIERS.map(tier => {
    const ts = grouped[tier];
    if (ts.length === 0) return null;
    return (
      <div class="tier-section">
        <div class="tier-heading" style={`border-color:${TIER_COLORS[tier]}`}>
          <span class="tier-dot" style={`background:${TIER_COLORS[tier]}`}></span>
          {tier.charAt(0).toUpperCase() + tier.slice(1)}
          <span class="tier-count">{ts.length}</span>
        </div>
        <div class="sponsors-grid">
          {ts.map((s: any) => (
            <div class={`sponsor-card ${!s.active ? 'sponsor-inactive' : ''}`}>
              <div class="sponsor-logo-wrap">
                {s.logo_url
                  ? <img src={s.logo_url} alt={s.name} class="sponsor-logo" />
                  : <div class="sponsor-logo-ph">{s.name.charAt(0).toUpperCase()}</div>
                }
              </div>
              <div class="sponsor-info">
                <div class="sponsor-name">
                  {s.name}
                  {!s.active && <span class="badge-inactive">Inactive</span>}
                  {s.season && <span class="badge-season">{s.season}</span>}
                </div>
                {s.website && (
                  <a href={s.website} target="_blank" rel="noopener" class="sponsor-website">
                    {s.website.replace(/^https?:\/\//, '')}
                  </a>
                )}
                <div class="sponsor-contact">
                  {s.contact_name  && <span>👤 {s.contact_name}</span>}
                  {s.contact_email && <a href={`mailto:${s.contact_email}`} class="contact-link">{s.contact_email}</a>}
                  {s.contact_phone && <span>📞 {s.contact_phone}</span>}
                </div>
                {s.notes && <div class="sponsor-notes">{s.notes}</div>}
              </div>
              <div class="sponsor-actions">
                <button class="btn-sm btn-edit"
                  data-id={s.id} data-name={s.name} data-tier={s.tier}
                  data-logo={s.logo_url ?? ''} data-website={s.website ?? ''}
                  data-cname={s.contact_name ?? ''} data-cemail={s.contact_email ?? ''}
                  data-cphone={s.contact_phone ?? ''} data-notes={s.notes ?? ''}
                  data-order={s.display_order} data-active={s.active ? '1' : '0'}
                  data-season={s.season ?? ''}>Edit</button>
                <form method="post" style="display:block">
                  <input type="hidden" name="action"  value="toggle_sponsor" />
                  <input type="hidden" name="sp_id"   value={s.id} />
                  <button class="btn-sm btn-toggle" type="submit">
                    {s.active ? 'Deactivate' : 'Activate'}
                  </button>
                </form>
                <form method="post" style="display:block" onsubmit="return confirm('Delete this sponsor?')">
                  <input type="hidden" name="action" value="delete_sponsor" />
                  <input type="hidden" name="sp_id"  value={s.id} />
                  <button class="btn-sm btn-delete" type="submit">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  })}

  {(sponsors ?? []).length === 0 && (
    <div class="empty-state">
      <div class="empty-icon">🤝</div>
      <p>No sponsors yet. Add your club's sponsors above.</p>
    </div>
  )}

  <!-- Add / Edit Modal -->
  <div id="sponsor-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <button class="modal-close" id="modal-close-btn">✕</button>
      <h3 id="sp-modal-title">Add Sponsor</h3>
      <form method="post" class="modal-form" id="sp-form">
        <input type="hidden" name="action" id="sp-action" value="add_sponsor" />
        <input type="hidden" name="sp_id"  id="sp-id" />
        <label>Sponsor Name <span class="req">*</span>
          <input type="text" name="sp_name" id="sp-name" required />
        </label>
        <div class="form-row">
          <label>Tier <span class="req">*</span>
            <select name="sp_tier" id="sp-tier" required>
              {TIERS.map(t => <option value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>)}
            </select>
          </label>
          <label>Season
            <input type="number" name="sp_season" id="sp-season" value="2026" />
          </label>
        </div>
        <label>Logo URL
          <input type="url" name="sp_logo" id="sp-logo" placeholder="https://…" />
        </label>
        <label>Website
          <input type="url" name="sp_website" id="sp-website" placeholder="https://…" />
        </label>
        <div class="form-row">
          <label>Contact Name
            <input type="text" name="sp_cname" id="sp-cname" />
          </label>
          <label>Contact Phone
            <input type="tel" name="sp_cphone" id="sp-cphone" />
          </label>
        </div>
        <label>Contact Email
          <input type="email" name="sp_cemail" id="sp-cemail" />
        </label>
        <label>Display Order <small style="text-transform:none;letter-spacing:0">(lower = first)</small>
          <input type="number" name="sp_order" id="sp-order" value="999" />
        </label>
        <label>Notes
          <textarea name="sp_notes" id="sp-notes" rows="2"></textarea>
        </label>
        <label class="checkbox-row">
          <input type="checkbox" name="sp_active" id="sp-active" checked />
          Active (show on website)
        </label>
        <div class="modal-footer">
          <button type="button" class="btn-ghost" id="modal-cancel-btn">Cancel</button>
          <button type="submit" class="btn-primary">Save Sponsor</button>
        </div>
      </form>
    </div>
  </div>

</AdminLayout>

<script>
  const modal       = document.getElementById('sponsor-modal') as HTMLElement;
  const openModal   = () => modal.style.display = 'flex';
  const closeModal  = () => modal.style.display = 'none';

  document.getElementById('modal-close-btn')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel-btn')?.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  document.getElementById('add-sponsor-btn')?.addEventListener('click', () => {
    (document.getElementById('sp-modal-title') as HTMLElement).textContent = 'Add Sponsor';
    (document.getElementById('sp-action') as HTMLInputElement).value = 'add_sponsor';
    (document.getElementById('sp-id') as HTMLInputElement).value = '';
    (document.getElementById('sp-form') as HTMLFormElement).reset();
    (document.getElementById('sp-season') as HTMLInputElement).value = '2026';
    (document.getElementById('sp-order') as HTMLInputElement).value = '999';
    (document.getElementById('sp-active') as HTMLInputElement).checked = true;
    openModal();
  });

  document.querySelectorAll('.btn-edit').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      (document.getElementById('sp-modal-title') as HTMLElement).textContent = 'Edit Sponsor';
      (document.getElementById('sp-action') as HTMLInputElement).value  = 'update_sponsor';
      (document.getElementById('sp-id') as HTMLInputElement).value      = el.dataset.id ?? '';
      (document.getElementById('sp-name') as HTMLInputElement).value    = el.dataset.name ?? '';
      (document.getElementById('sp-tier') as HTMLSelectElement).value   = el.dataset.tier ?? '';
      (document.getElementById('sp-logo') as HTMLInputElement).value    = el.dataset.logo ?? '';
      (document.getElementById('sp-website') as HTMLInputElement).value = el.dataset.website ?? '';
      (document.getElementById('sp-cname') as HTMLInputElement).value   = el.dataset.cname ?? '';
      (document.getElementById('sp-cphone') as HTMLInputElement).value  = el.dataset.cphone ?? '';
      (document.getElementById('sp-cemail') as HTMLInputElement).value  = el.dataset.cemail ?? '';
      (document.getElementById('sp-notes') as HTMLTextAreaElement).value = el.dataset.notes ?? '';
      (document.getElementById('sp-order') as HTMLInputElement).value   = el.dataset.order ?? '999';
      (document.getElementById('sp-season') as HTMLInputElement).value  = el.dataset.season ?? '';
      (document.getElementById('sp-active') as HTMLInputElement).checked = el.dataset.active === '1';
      openModal();
    });
  });
</script>

<style>
  .toolbar { display:flex; align-items:center; gap:16px; margin-bottom:28px; }
  .btn-primary { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; }
  .btn-primary:hover { background:#a50d24; }
  .count { font-size:14px; color:var(--admin-muted); }

  .tier-section { margin-bottom:32px; }
  .tier-heading { display:flex; align-items:center; gap:10px; font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:.06em; border-left:3px solid; padding-left:12px; margin-bottom:14px; }
  .tier-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .tier-count { font-size:13px; font-family:'Inter',sans-serif; font-weight:400; color:var(--admin-muted); margin-left:4px; }

  .sponsors-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:14px; }
  .sponsor-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; padding:16px; display:flex; gap:14px; align-items:flex-start; }
  .sponsor-card.sponsor-inactive { opacity:.5; }

  .sponsor-logo-wrap { flex-shrink:0; }
  .sponsor-logo { width:64px; height:64px; object-fit:contain; border-radius:6px; background:rgba(255,255,255,.05); padding:4px; }
  .sponsor-logo-ph { width:64px; height:64px; background:rgba(200,16,46,.15); border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:700; color:#C8102E; }

  .sponsor-info { flex:1; min-width:0; }
  .sponsor-name { font-size:15px; font-weight:600; display:flex; align-items:center; gap:8px; margin-bottom:4px; flex-wrap:wrap; }
  .badge-inactive { background:rgba(255,255,255,.08); color:var(--admin-muted); border-radius:3px; padding:2px 6px; font-size:10px; }
  .badge-season   { background:rgba(200,16,46,.15); color:#f87171; border-radius:3px; padding:2px 6px; font-size:10px; }
  .sponsor-website { font-size:12px; color:#8ab4f8; text-decoration:none; display:block; margin-bottom:6px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .sponsor-contact { display:flex; flex-direction:column; gap:3px; font-size:12px; color:var(--admin-muted); }
  .contact-link { color:#8ab4f8; text-decoration:none; }
  .sponsor-notes { font-size:12px; color:var(--admin-muted); font-style:italic; margin-top:6px; }

  .sponsor-actions { display:flex; flex-direction:column; gap:6px; flex-shrink:0; }
  .btn-sm { border-radius:5px; padding:5px 10px; font-size:12px; cursor:pointer; border:1px solid var(--admin-border); background:transparent; color:var(--admin-muted); white-space:nowrap; width:100%; }
  .btn-edit:hover   { border-color:#C8102E; color:#C8102E; }
  .btn-toggle:hover { border-color:#4ade80; color:#4ade80; }
  .btn-delete:hover { border-color:#f87171; color:#f87171; }

  .empty-state { text-align:center; padding:64px; color:var(--admin-muted); }
  .empty-icon { font-size:48px; margin-bottom:12px; }

  .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:100; display:flex; align-items:center; justify-content:center; padding:20px; }
  .modal { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:28px; width:520px; max-width:95vw; max-height:90vh; overflow-y:auto; position:relative; }
  .modal-close { position:absolute; top:14px; right:16px; background:none; border:none; color:var(--admin-muted); font-size:18px; cursor:pointer; }
  .modal h3 { font-size:20px; font-weight:700; margin-bottom:20px; }
  .modal-form { display:flex; flex-direction:column; gap:14px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .modal-form label { display:flex; flex-direction:column; gap:5px; font-size:13px; color:var(--admin-muted); }
  .modal-form input, .modal-form select, .modal-form textarea {
    background:#081426; border:1px solid var(--admin-border); color:var(--admin-text);
    border-radius:6px; padding:8px 12px; font-size:14px; font-family:inherit;
  }
  .modal-form input:focus, .modal-form select:focus, .modal-form textarea:focus { outline:none; border-color:#C8102E; }
  .req { color:#C8102E; }
  .checkbox-row { flex-direction:row !important; align-items:center; gap:8px; font-size:14px; color:var(--admin-text) !important; cursor:pointer; }
  .modal-footer { display:flex; justify-content:flex-end; gap:10px; margin-top:4px; }
  .btn-ghost { background:transparent; border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:6px; padding:8px 16px; font-size:14px; cursor:pointer; }
  .btn-ghost:hover { color:var(--admin-text); }
</style>
