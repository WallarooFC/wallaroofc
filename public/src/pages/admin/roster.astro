---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db = getAdminClient();

// Get upcoming & recent shifts with their roster
const { data: shifts } = await db
  .from('bar_shifts')
  .select(`
    *,
    bar_roster (
      id,
      confirmed,
      note,
      volunteer_id,
      volunteers ( first_name, last_name, phone, email )
    )
  `)
  .gte('shift_date', new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0])
  .order('shift_date');

// All active volunteers for the assignment dropdown
const { data: volunteers } = await db
  .from('volunteers')
  .select('id, first_name, last_name, roles')
  .eq('active', true)
  .order('last_name');

// RSA-qualified volunteers (have RSA cert)
const { data: rsaQuals } = await db
  .from('qualifications')
  .select('volunteer_id')
  .eq('type', 'rsa')
  .gte('expiry_date', new Date().toISOString().split('T')[0]);

const rsaVolIds = new Set((rsaQuals ?? []).map((q: any) => q.volunteer_id));

function formatDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-AU', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
  });
}
---
<AdminLayout title="Bar Roster">
  <!-- Toolbar -->
  <div class="toolbar">
    <button class="btn-primary" id="add-shift-btn">+ New Shift</button>
    <a href="/admin/roster?all=1" class="btn-secondary">View All Shifts</a>
    <span class="roster-hint">Showing upcoming shifts · Drag to reorder not yet available</span>
  </div>

  {(shifts ?? []).length === 0 && (
    <div class="empty-state">
      <div class="empty-icon">🍺</div>
      <p>No upcoming bar shifts. Create your first shift to start rostering volunteers.</p>
      <button class="btn-primary" id="add-shift-empty">+ Create Shift</button>
    </div>
  )}

  {(shifts ?? []).map((shift: any) => {
    const roster: any[] = shift.bar_roster ?? [];
    const confirmed = roster.filter((r: any) => r.confirmed).length;
    const needed = shift.volunteers_needed ?? 4;
    const filled = roster.length;
    const pct = Math.min(100, Math.round((filled / needed) * 100));
    const isUnder = filled < needed;

    return (
      <div class={`shift-card ${isUnder ? 'shift-under' : 'shift-full'}`}>
        <div class="shift-header">
          <div class="shift-info">
            <div class="shift-title">
              {shift.label ?? `Shift — ${formatDate(shift.shift_date)}`}
              {shift.round && <span class="shift-round">Round {shift.round}</span>}
            </div>
            <div class="shift-meta">
              <span>📅 {formatDate(shift.shift_date)}</span>
              <span>🕐 {shift.start_time?.substring(0,5)} – {shift.end_time?.substring(0,5)}</span>
              <span class={`fill-badge ${isUnder ? 'fill-under' : 'fill-full'}`}>
                {filled}/{needed} volunteers{confirmed > 0 ? ` · ${confirmed} confirmed` : ''}
              </span>
            </div>
            {shift.notes && <div class="shift-notes">{shift.notes}</div>}
          </div>
          <div class="shift-actions">
            <button class="btn-sm btn-assign" data-shift-id={shift.id} data-shift-label={shift.label ?? `Round ${shift.round}`}>
              + Assign
            </button>
            <button class="btn-sm btn-ghost" data-shift-id={shift.id} data-action="edit-shift">Edit</button>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="progress-wrap">
          <div class="progress-bar" style={`width:${pct}%`}></div>
        </div>

        <!-- Roster table -->
        {roster.length === 0 ? (
          <div class="no-roster">No volunteers assigned yet</div>
        ) : (
          <div class="roster-list">
            {roster.map((r: any) => {
              const vol = r.volunteers;
              const hasRSA = rsaVolIds.has(r.volunteer_id);
              return (
                <div class={`roster-item ${r.confirmed ? 'roster-confirmed' : 'roster-pending'}`}>
                  <div class="roster-vol">
                    <span class="roster-name">{vol?.first_name} {vol?.last_name}</span>
                    {hasRSA && <span class="rsa-badge">RSA</span>}
                    {r.confirmed ? <span class="conf-badge">✓ Confirmed</span> : <span class="pend-badge">Pending</span>}
                  </div>
                  <div class="roster-contact">
                    {vol?.phone && <span>{vol.phone}</span>}
                    {r.note && <span class="roster-note">"{r.note}"</span>}
                  </div>
                  <div class="roster-item-actions">
                    {!r.confirmed && (
                      <button class="btn-xs btn-confirm" data-roster-id={r.id}>✓ Confirm</button>
                    )}
                    <button class="btn-xs btn-remove" data-roster-id={r.id}>Remove</button>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        <!-- Slots remaining -->
        {isUnder && (
          <div class="slots-remaining">
            {needed - filled} more volunteer{needed - filled !== 1 ? 's' : ''} needed
          </div>
        )}
      </div>
    );
  })}

  <!-- Add Shift Modal -->
  <dialog id="shift-modal" class="modal">
    <div class="modal-inner">
      <div class="modal-header">
        <h2 id="shift-modal-title">New Bar Shift</h2>
        <button class="modal-close" data-close="shift-modal">✕</button>
      </div>
      <form id="shift-form" class="modal-form">
        <input type="hidden" id="shift-id" name="id" />
        <label class="form-group">
          Shift Label <span class="req">*</span>
          <input type="text" name="label" required placeholder="e.g. Round 7 Home Game" />
        </label>
        <div class="form-row">
          <label class="form-group">
            Date <span class="req">*</span>
            <input type="date" name="shift_date" required />
          </label>
          <label class="form-group">
            Round #
            <input type="number" name="round" min="1" max="30" placeholder="7" />
          </label>
        </div>
        <div class="form-row">
          <label class="form-group">
            Start Time
            <input type="time" name="start_time" value="11:00" />
          </label>
          <label class="form-group">
            End Time
            <input type="time" name="end_time" value="18:00" />
          </label>
        </div>
        <label class="form-group">
          Volunteers Needed
          <input type="number" name="volunteers_needed" value="4" min="1" max="20" />
        </label>
        <label class="form-group">
          Notes
          <textarea name="notes" rows="2" placeholder="Any special instructions…"></textarea>
        </label>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" data-close="shift-modal">Cancel</button>
          <button type="submit" class="btn-primary" id="shift-submit">Save Shift</button>
        </div>
      </form>
    </div>
  </dialog>

  <!-- Assign Volunteer Modal -->
  <dialog id="assign-modal" class="modal">
    <div class="modal-inner">
      <div class="modal-header">
        <h2>Assign Volunteer</h2>
        <button class="modal-close" data-close="assign-modal">✕</button>
      </div>
      <div id="assign-shift-label" class="assign-context"></div>
      <form id="assign-form" class="modal-form">
        <input type="hidden" id="assign-shift-id" name="shift_id" />
        <label class="form-group">
          Volunteer <span class="req">*</span>
          <select name="volunteer_id" id="assign-vol-select" required>
            <option value="">Select volunteer…</option>
            {(volunteers ?? []).map((v: any) => (
              <option value={v.id} data-rsa={rsaVolIds.has(v.id) ? '1' : '0'}>
                {v.last_name}, {v.first_name}
                {rsaVolIds.has(v.id) ? ' ★ RSA' : ''}
                {(v.roles as string[] ?? []).includes('bar') ? ' (bar)' : ''}
              </option>
            ))}
          </select>
        </label>
        <label class="form-group checkbox-single">
          <input type="checkbox" name="confirmed" id="assign-confirmed" /> Mark as confirmed
        </label>
        <label class="form-group">
          Note
          <input type="text" name="note" placeholder="e.g. Available from 1pm only" />
        </label>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" data-close="assign-modal">Cancel</button>
          <button type="submit" class="btn-primary">Assign</button>
        </div>
      </form>
    </div>
  </dialog>
</AdminLayout>

<style>
  .toolbar { display:flex; align-items:center; gap:12px; margin-bottom:24px; }
  .roster-hint { font-size:12px; color:var(--admin-muted); margin-left:auto; }
  .btn-primary { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; }
  .btn-primary:hover { background:#a50d24; }
  .btn-secondary { background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:9px 18px; font-size:14px; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; }
  .btn-secondary:hover { border-color:#C8102E; color:#C8102E; }

  .empty-state { text-align:center; padding:64px 32px; color:var(--admin-muted); }
  .empty-icon { font-size:48px; margin-bottom:12px; }
  .empty-state p { margin-bottom:20px; }

  .shift-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; padding:20px; margin-bottom:20px; }
  .shift-card.shift-under { border-left:3px solid #facc15; }
  .shift-card.shift-full { border-left:3px solid #4ade80; }

  .shift-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px; }
  .shift-title { font-size:16px; font-weight:600; margin-bottom:6px; display:flex; align-items:center; gap:8px; }
  .shift-round { background:rgba(200,16,46,0.2); color:#f87171; border-radius:4px; padding:2px 8px; font-size:12px; font-weight:700; }
  .shift-meta { font-size:13px; color:var(--admin-muted); display:flex; flex-wrap:wrap; gap:16px; margin-bottom:4px; }
  .shift-notes { font-size:12px; color:var(--admin-muted); font-style:italic; margin-top:4px; }

  .fill-badge { font-weight:600; }
  .fill-under { color:#facc15; }
  .fill-full { color:#4ade80; }

  .shift-actions { display:flex; gap:8px; flex-shrink:0; }
  .btn-sm { border-radius:5px; padding:6px 12px; font-size:12px; cursor:pointer; border:1px solid var(--admin-border); }
  .btn-assign { background:#C8102E; border-color:#C8102E; color:#fff; }
  .btn-assign:hover { background:#a50d24; }
  .btn-ghost { background:transparent; color:var(--admin-muted); }
  .btn-ghost:hover { color:var(--admin-text); border-color:var(--admin-text); }

  .progress-wrap { height:4px; background:rgba(255,255,255,0.08); border-radius:2px; margin:12px 0; overflow:hidden; }
  .progress-bar { height:100%; background:linear-gradient(90deg,#C8102E,#e8405d); border-radius:2px; transition:width 0.3s; }

  .no-roster { font-size:13px; color:var(--admin-muted); font-style:italic; }

  .roster-list { display:flex; flex-direction:column; gap:8px; }
  .roster-item { display:flex; align-items:center; gap:12px; padding:8px 12px; border-radius:6px; background:rgba(255,255,255,0.03); border:1px solid var(--admin-border); }
  .roster-item.roster-confirmed { border-color:rgba(74,222,128,0.25); }
  .roster-vol { display:flex; align-items:center; gap:8px; flex:1; min-width:0; }
  .roster-name { font-size:14px; font-weight:500; }
  .rsa-badge { background:rgba(139,92,246,0.2); color:#a78bfa; border-radius:3px; padding:1px 6px; font-size:10px; font-weight:700; }
  .conf-badge { background:rgba(74,222,128,0.15); color:#4ade80; border-radius:3px; padding:2px 6px; font-size:10px; font-weight:600; }
  .pend-badge { background:rgba(234,179,8,0.15); color:#facc15; border-radius:3px; padding:2px 6px; font-size:10px; }
  .roster-contact { font-size:12px; color:var(--admin-muted); flex:1; }
  .roster-note { font-style:italic; }
  .roster-item-actions { display:flex; gap:6px; }
  .btn-xs { background:transparent; border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:4px; padding:3px 8px; font-size:11px; cursor:pointer; white-space:nowrap; }
  .btn-confirm { border-color:rgba(74,222,128,0.4); color:#4ade80; }
  .btn-confirm:hover { background:rgba(74,222,128,0.1); }
  .btn-remove { border-color:rgba(200,16,46,0.3); color:#f87171; }
  .btn-remove:hover { background:rgba(200,16,46,0.1); }

  .slots-remaining { text-align:center; font-size:12px; color:#facc15; margin-top:12px; padding-top:12px; border-top:1px solid var(--admin-border); }

  /* Modal */
  .modal { background:transparent; border:none; padding:0; }
  .modal::backdrop { background:rgba(0,0,0,0.6); }
  .modal-inner { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:28px; width:480px; max-width:95vw; max-height:90vh; overflow-y:auto; }
  .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
  .modal-header h2 { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:0.05em; }
  .modal-close { background:transparent; border:none; color:var(--admin-muted); font-size:18px; cursor:pointer; }
  .modal-close:hover { color:var(--admin-text); }
  .assign-context { font-size:14px; color:var(--admin-muted); margin-bottom:16px; }

  .modal-form { display:flex; flex-direction:column; gap:14px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .form-group { display:flex; flex-direction:column; gap:5px; font-size:13px; color:var(--admin-muted); }
  .form-group input, .form-group select, .form-group textarea {
    background:#081426; border:1px solid var(--admin-border); color:var(--admin-text);
    border-radius:6px; padding:8px 12px; font-size:14px; font-family:inherit;
  }
  .form-group input:focus, .form-group select:focus { outline:none; border-color:#C8102E; }
  .req { color:#C8102E; }
  .checkbox-single { flex-direction:row !important; align-items:center; gap:8px; font-size:14px; color:var(--admin-text); cursor:pointer; }
  .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:4px; }
</style>

<script>
  import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  function openModal(id: string) {
    (document.getElementById(id) as HTMLDialogElement)?.showModal();
  }
  function closeModal(id: string) {
    (document.getElementById(id) as HTMLDialogElement)?.close();
  }

  document.querySelectorAll('[data-close]').forEach(btn => {
    btn.addEventListener('click', () => closeModal((btn as HTMLElement).dataset.close!));
  });

  document.getElementById('add-shift-btn')?.addEventListener('click', () => {
    (document.getElementById('shift-id') as HTMLInputElement).value = '';
    (document.getElementById('shift-modal-title') as HTMLElement).textContent = 'New Bar Shift';
    openModal('shift-modal');
  });
  document.getElementById('add-shift-empty')?.addEventListener('click', () => openModal('shift-modal'));

  // Assign buttons
  document.querySelectorAll('.btn-assign').forEach(btn => {
    btn.addEventListener('click', () => {
      const shiftId = (btn as HTMLElement).dataset.shiftId!;
      const label = (btn as HTMLElement).dataset.shiftLabel ?? '';
      (document.getElementById('assign-shift-id') as HTMLInputElement).value = shiftId;
      document.getElementById('assign-shift-label')!.textContent = `Assigning to: ${label}`;
      openModal('assign-modal');
    });
  });

  // Confirm roster entry
  document.querySelectorAll('.btn-confirm').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.rosterId!;
      const { error } = await supabase.from('bar_roster').update({ confirmed: true }).eq('id', id);
      if (!error) window.location.reload();
      else alert('Error: ' + error.message);
    });
  });

  // Remove roster entry
  document.querySelectorAll('.btn-remove').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Remove this volunteer from the shift?')) return;
      const id = (btn as HTMLElement).dataset.rosterId!;
      const { error } = await supabase.from('bar_roster').delete().eq('id', id);
      if (!error) window.location.reload();
      else alert('Error: ' + error.message);
    });
  });

  // Save shift
  document.getElementById('shift-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('shift-submit')!;
    btn.textContent = 'Saving…';
    const fd = new FormData(e.target as HTMLFormElement);
    const payload: any = {
      label: fd.get('label'),
      shift_date: fd.get('shift_date'),
      round: fd.get('round') ? parseInt(fd.get('round') as string) : null,
      start_time: fd.get('start_time'),
      end_time: fd.get('end_time'),
      volunteers_needed: parseInt(fd.get('volunteers_needed') as string),
      notes: fd.get('notes') || null,
    };
    const id = fd.get('id') as string;
    let err;
    if (id) {
      ({ error: err } = await supabase.from('bar_shifts').update(payload).eq('id', id));
    } else {
      ({ error: err } = await supabase.from('bar_shifts').insert(payload));
    }
    if (err) { alert('Error: ' + err.message); btn.textContent = 'Save Shift'; return; }
    window.location.reload();
  });

  // Assign volunteer
  document.getElementById('assign-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    const payload = {
      shift_id: fd.get('shift_id'),
      volunteer_id: fd.get('volunteer_id'),
      confirmed: fd.has('confirmed'),
      note: fd.get('note') || null,
    };
    const { error } = await supabase.from('bar_roster').upsert(payload, {
      onConflict: 'shift_id,volunteer_id'
    });
    if (error) { alert('Error: ' + error.message); return; }
    window.location.reload();
  });
</script>
