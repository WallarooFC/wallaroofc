  .num-cell { position:relative; cursor:pointer; }
  .num-display { display:inline-flex; align-items:center; justify-content:center; min-width:40px; height:32px; border-radius:6px; font-size:18px; font-weight:700; font-family:monospace; border:2px dashed transparent; transition:border-color .2s,background .2s; padding:0 8px; cursor:pointer; }
  .num-display:hover { border-color:var(--admin-border); background:rgba(255,255,255,.05); }
  .unset { font-size:14px; color:var(--admin-muted); font-weight:400; font-family:inherit; }
  .num-input { display:none; width:72px; height:34px; border-radius:6px; border:2px solid #C8102E; background:var(--admin-bg); color:var(--admin-text); font-size:18px; font-weight:700; font-family:monospace; text-align:center; padding:0 6px; }
  .num-input:focus { outline:none; }
  .num-cell.saving .num-display { opacity:.5; }
  .num-cell.saved .num-display  { border-color:#4ade80; background:rgba(74,222,128,.12); }
  .num-cell.error .num-display  { border-color:#f87171; background:rgba(248,113,113,.12); }

  .name-cell strong { color:var(--admin-text); }
  .health-tag { background:rgba(250,204,21,.2); color:#facc15; border-radius:4px; padding:2px 6px; font-size:11px; margin-left:6px; cursor:help; }
  .muted { color:var(--admin-muted); font-size:13px; }
  .emergency .phone { font-size:12px; }
  .grade-tag { background:rgba(20,49,92,.6); color:#8ab4f8; border-radius:4px; padding:3px 8px; font-size:12px; white-space:nowrap; }
  .status-tag { border-radius:4px; padding:3px 8px; font-size:12px; text-transform:capitalize; }
  .status-tag.active   { background:rgba(34,197,94,.15);  color:#4ade80; }
  .status-tag.inactive { background:rgba(239,68,68,.15);  color:#f87171; }
  .status-tag.pending  { background:rgba(234,179,8,.15);  color:#facc15; }
  .table-hint { font-size:12px; color:var(--admin-muted); margin-top:12px; padding-left:4px; }
  .empty { text-align:center; padding:48px; color:var(--admin-muted); }

  .board-view { display:flex; flex-direction:column; gap:32px; }
  .board-legend { display:flex; gap:20px; margin-bottom:4px; }
  .legend-item { display:flex; align-items:center; gap:6px; font-size:13px; color:var(--admin-muted); }
  .legend-swatch { width:16px; height:16px; border-radius:4px; }
  .legend-swatch.assigned    { background:rgba(200,16,46,.7); }
  .legend-swatch.empty-swatch{ background:var(--admin-card); border:1px solid var(--admin-border); }
  .legend-swatch.conflict    { background:#f97316; }

  .grade-section { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; overflow:hidden; }
  .grade-header { display:flex; justify-content:space-between; align-items:center; padding:16px 20px; border-bottom:1px solid var(--admin-border); }
  .grade-header h2 { font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; }
  .grade-stats { font-size:13px; color:var(--admin-muted); }

  .unassigned-strip { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:10px 20px; background:rgba(250,204,21,.06); border-bottom:1px solid var(--admin-border); }
  .unassigned-label { font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:#facc15; white-space:nowrap; }
  .player-chip { font-size:12px; background:rgba(250,204,21,.12); color:#facc15; border:1px solid rgba(250,204,21,.3); border-radius:20px; padding:3px 10px; white-space:nowrap; }

  .num-grid { display:grid; grid-template-columns:repeat(10,1fr); gap:6px; padding:16px 20px; }
