---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db = getAdminClient();
const { data: allPlayers } = await db
  .from('players')
  .select('*')
  .eq('season', 2026)
  .order('grade')
  .order('last_name');

const grades = ['A-Grade', 'B Grade', 'Senior Colts', 'Junior Colts', 'U11', 'U9'];
const gradeFilter = Astro.url.searchParams.get('grade') ?? 'all';
const search      = Astro.url.searchParams.get('q') ?? '';
const view        = Astro.url.searchParams.get('view') ?? 'list';

const players = allPlayers ?? [];

const filtered = players.filter(p => {
  const matchGrade  = gradeFilter === 'all' || p.grade === gradeFilter;
  const matchSearch = !search || p.full_name?.toLowerCase().includes(search.toLowerCase());
  return matchGrade && matchSearch;
});

// Board data: per grade, map num → player and find conflicts
const boardByGrade: Record<string, { assigned: Record<number, any>; conflicts: Set<number> }> = {};
for (const grade of grades) {
  const assigned: Record<number, any> = {};
  const conflicts = new Set<number>();
  for (const p of players.filter(x => x.grade === grade && x.jumper_number)) {
    const n = p.jumper_number as number;
    if (assigned[n]) conflicts.add(n);
    assigned[n] = p;
  }
  boardByGrade[grade] = { assigned, conflicts };
}

const totalAssigned  = players.filter(p => p.jumper_number).length;
const totalConflicts = grades.reduce((sum, g) => sum + boardByGrade[g].conflicts.size, 0);
const totalTagged    = players.filter(p => p.guernsey_id).length;

const playersJson = JSON.stringify(players.map(p => ({
  id: p.id, name: p.full_name, first: p.first_name, last: p.last_name,
  grade: p.grade, jumper: p.jumper_number ?? null, guernseyId: p.guernsey_id ?? null,
})));
---
<AdminLayout title="Players">

  <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
  <div class="toolbar">
    <form method="get" class="filters" id="filter-form">
      <input type="hidden" name="view" value={view} />
      <input name="q" type="search" placeholder="Search name…" value={search} class="search-input" />
      <select name="grade" class="grade-select" onchange="this.form.submit()">
        <option value="all">All grades</option>
        {grades.map(g => <option value={g} selected={gradeFilter === g}>{g}</option>)}
      </select>
      <button type="submit" class="btn-filter">Filter</button>
    </form>
    <div class="toolbar-right">
      <div class="view-toggle">
        <a href={`?view=list&grade=${gradeFilter}&q=${search}`} class={`view-btn ${view === 'list' ? 'active' : ''}`}>≡ List</a>
        <a href={`?view=board&grade=${gradeFilter}&q=${search}`} class={`view-btn ${view === 'board' ? 'active' : ''}`}>⊞ Board</a>
      </div>
      <span class="count">{filtered.length} players</span>
      <button class="btn-import" id="import-btn">↑ Import CSV</button>
      <button class="btn-sync" id="sync-btn">↻ Sync PlayHQ</button>
    </div>
  </div>

  <!-- ── Stats strip ─────────────────────────────────────────────────────── -->
  <div class="stats-strip">
    <div class="stat"><span class="stat-n">{players.length}</span><span class="stat-l">Total Players</span></div>
    <div class="stat"><span class="stat-n">{totalAssigned}</span><span class="stat-l">Guernsey Assigned</span></div>
    <div class="stat"><span class="stat-n">{players.length - totalAssigned}</span><span class="stat-l">Unassigned</span></div>
    <div class="stat"><span class="stat-n">{totalTagged}</span><span class="stat-l">Guernsey IDs Tagged</span></div>
    {totalConflicts > 0 && (
      <div class="stat conflict-stat">
        <span class="stat-n">{totalConflicts}</span>
        <span class="stat-l">⚠ Conflicts</span>
      </div>
    )}
  </div>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- LIST VIEW                                                             -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  {view === 'list' && (
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="col-num" title="Playing number on the back — click to edit">Guernsey #</th>
            <th class="col-id"  title="Physical garment tag ID — used when multiple players share a number">Guernsey ID</th>
            <th>Name</th>
            <th>Grade</th>
            <th>DOB</th>
            <th>Emergency Contact</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {filtered.length === 0 && (
            <tr><td colspan="7" class="empty">No players found.</td></tr>
          )}
          {filtered.map(p => (
            <tr data-player-id={p.id} data-grade={p.grade}>
              <td class="num-cell" data-field="jumper_number" data-current={p.jumper_number ?? ''}>
                <span class="num-display">{p.jumper_number ?? <span class="unset">—</span>}</span>
                <input type="number" min="1" max="99" placeholder="—" class="num-input" value={p.jumper_number ?? ''} />
              </td>
              <td class="num-cell id-cell" data-field="guernsey_id" data-current={p.guernsey_id ?? ''}>
                <span class="num-display id-display">{p.guernsey_id ?? <span class="unset">—</span>}</span>
                <input type="number" min="1" max="50" placeholder="1–50" class="num-input id-input" value={p.guernsey_id ?? ''} />
              </td>
              <td class="name-cell">
                <strong>{p.full_name}</strong>
                {p.playhq_data?.health_notes && (
                  <span class="health-tag" title={p.playhq_data.health_notes}>⚕</span>
                )}
              </td>
              <td><span class="grade-tag">{p.grade}</span></td>
              <td class="muted">{p.dob ?? '—'}</td>
              <td class="muted emergency">
                {p.emergency_name ?? '—'}
                {p.emergency_phone && <span class="phone"> · {p.emergency_phone}</span>}
              </td>
              <td>
                <span class={`status-tag ${p.registration_status ?? 'active'}`}>
                  {p.registration_status ?? 'active'}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="table-hint">Click any <strong>Guernsey #</strong> or <strong>Guernsey ID</strong> to edit inline. Enter to save · Esc to cancel. Guernsey ID is the physical garment number (1–50) — useful in U9s/U11s where multiple players share the same playing number.</p>
    </div>
  )}

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- BOARD VIEW                                                            -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  {view === 'board' && (
    <div class="board-view">
      <div class="board-legend">
        <span class="legend-item"><span class="legend-swatch assigned"></span> Assigned</span>
        <span class="legend-item"><span class="legend-swatch empty-swatch"></span> Available</span>
        <span class="legend-item"><span class="legend-swatch conflict"></span> Conflict</span>
      </div>

      {grades.map(grade => {
        const { assigned, conflicts } = boardByGrade[grade];
        const gradePlayers = players.filter(p => p.grade === grade);
        if (gradePlayers.length === 0) return null;
        const assignedCount = gradePlayers.filter(p => p.jumper_number).length;
        return (
          <div class="grade-section" id={`grade-${grade.replace(/\s+/g, '-').toLowerCase()}`}>
            <div class="grade-header">
              <h2>{grade}</h2>
              <span class="grade-stats">{assignedCount} / {gradePlayers.length} assigned</span>
            </div>
            {gradePlayers.filter(p => !p.jumper_number).length > 0 && (
              <div class="unassigned-strip">
                <span class="unassigned-label">No guernsey:</span>
                {gradePlayers.filter(p => !p.jumper_number).map(p => (
                  <span class="player-chip" data-player-id={p.id} data-grade={grade}>
                    {p.first_name} {p.last_name}
                  </span>
                ))}
              </div>
            )}
            <div class="num-grid" data-grade={grade}>
              {Array.from({ length: 50 }, (_, i) => i + 1).map(num => {
                const player = assigned[num];
                const isConflict = conflicts.has(num);
                const cls = player
                  ? (isConflict ? 'grid-cell conflict' : 'grid-cell assigned')
                  : 'grid-cell empty';
                return (
                  <button
                    class={cls}
                    data-num={num}
                    data-grade={grade}
                    data-player-id={player?.id ?? ''}
                    title={player
                      ? (isConflict ? `⚠ CONFLICT on #${num}` : `${player.full_name} · click to clear or reassign`)
                      : `Assign #${num}`}
                  >
                    <span class="cell-num">{num}</span>
                    {player && <span class="cell-name">{player.first_name}</span>}
                    {isConflict && <span class="conflict-icon">!</span>}
                  </button>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- ── Assignment modal (board view) ───────────────────────────────────── -->
  <div id="assign-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <button class="modal-close" id="modal-close">✕</button>
      <h3 id="modal-title">Assign Guernsey</h3>
      <p id="modal-sub" class="modal-sub"></p>
      <div id="modal-body" class="modal-body"></div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast" style="display:none"></div>

  <!-- Player data for client JS -->
  <script type="application/json" id="players-data">{playersJson}</script>

  <!-- ── CSV Import modal ──────────────────────────────────────────────────── -->
  <div id="import-modal" class="modal-overlay" style="display:none">
    <div class="modal import-modal">
      <button class="modal-close" id="import-modal-close">✕</button>

      <!-- Step 1: drop zone -->
      <div id="import-step-1">
        <h3>Import PlayHQ CSV</h3>
        <p class="modal-sub">Export participants from PlayHQ admin and drop the file here. Only active players are imported — coaches, volunteers and cancelled registrations are skipped.</p>
        <div class="csv-drop" id="csv-drop">
          <div class="csv-drop-icon">📂</div>
          <p>Drop CSV file here or <label class="csv-browse" for="csv-file-input">browse</label></p>
          <p class="csv-drop-hint">participants_YYYYMMDD….csv</p>
          <input type="file" id="csv-file-input" accept=".csv,.xlsx,.xls,text/csv,text/plain,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" style="display:none" />
        </div>
        <p class="import-error" id="import-parse-error" style="display:none"></p>
      </div>

      <!-- Step 2: preview -->
      <div id="import-step-2" style="display:none">
        <h3 id="import-preview-heading">Preview</h3>
        <p class="modal-sub" id="import-preview-sub"></p>
        <div class="import-table-wrap">
          <table class="import-table" id="import-preview-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Grade / Team</th>
                <th>Mobile</th>
                <th>DOB / Email</th>
                <th>#</th>
              </tr>
            </thead>
            <tbody id="import-preview-body"></tbody>
          </table>
        </div>
        <div class="import-actions">
          <button class="modal-btn" id="import-back-btn" style="background:transparent;border:1px solid var(--admin-border);color:var(--admin-muted)">← Back</button>
          <button class="modal-btn primary" id="import-confirm-btn">Import players</button>
        </div>
      </div>

      <!-- Step 3: result -->
      <div id="import-step-3" style="display:none">
        <h3>Import complete</h3>
        <p class="import-result" id="import-result-text"></p>
        <div class="import-errors-list" id="import-errors-list" style="display:none"></div>
        <div class="import-actions">
          <button class="modal-btn primary" onclick="window.location.reload()">Reload players</button>
        </div>
      </div>
    </div>
  </div>

</AdminLayout>

<script is:inline>
(function () {
  // ── Team name → internal grade (exact then fuzzy) ───────────────────────
  var TEAM_GRADE_MAP = {
    'wallaroo - a grade':  'A-Grade',
    'wallaroo a grade':    'A-Grade',
    'wallaroo - reserves': 'B Grade',
    'wallaroo reserves':   'B Grade',
    'wallaroo u17':        'Senior Colts',
    'wallaroo - u17':      'Senior Colts',
    'wallaroo under 17':   'Senior Colts',
    'wallaroo - u14':      'Junior Colts',
    'wallaroo u14':        'Junior Colts',
    'wallaroo under 14':   'Junior Colts',
    'wallaroo - u11':      'U11',
    'wallaroo u11':        'U11',
    'wallaroo under 11':   'U11',
    'wallaroo u9':         'U9',
    'wallaroo - u9':       'U9',
    'wallaroo under 9':    'U9',
  };

  var GRADE_PRIORITY = {
    'A-Grade': 1, 'B Grade': 2, 'Senior Colts': 3,
    'Junior Colts': 4, 'U11': 5, 'U9': 6,
  };

  // Fuzzy team → grade: normalise dashes/spaces then keyword-match
  function teamToGrade(raw) {
    if (!raw) return null;
    var key = raw.toLowerCase().trim();
    if (TEAM_GRADE_MAP[key]) return TEAM_GRADE_MAP[key];
    // normalise any dash variant + collapse whitespace
    var norm = key.replace(/[–—‒‐]/g, '-').replace(/\s+/g, ' ');
    if (TEAM_GRADE_MAP[norm]) return TEAM_GRADE_MAP[norm];
    // strip all dashes and spaces for looser match
    var stripped = norm.replace(/[-\s]/g, '');
    if (/wallarooareserves?/.test(stripped) || /reserves?$/.test(stripped)) return 'B Grade';
    if (/wallarooagrade/.test(stripped) || /agrade$/.test(stripped)) return 'A-Grade';
    if (/u17|under17/.test(stripped)) return 'Senior Colts';
    if (/u14|under14/.test(stripped)) return 'Junior Colts';
    if (/u11|under11/.test(stripped)) return 'U11';
    if (/u9|under9/.test(stripped))   return 'U9';
    return null;
  }

  // ── CSV parser ───────────────────────────────────────────────────────────
  function parseCSV(text) {
    var rows = [], row = [], field = '', inQuote = false;
    for (var i = 0; i < text.length; i++) {
      var ch = text[i];
      if (inQuote) {
        if (ch === '"') {
          if (text[i + 1] === '"') { field += '"'; i++; }
          else { inQuote = false; }
        } else { field += ch; }
      } else {
        if      (ch === '"')  { inQuote = true; }
        else if (ch === ',')  { row.push(field); field = ''; }
        else if (ch === '\n') {
          row.push(field); field = '';
          if (row.length > 1) rows.push(row);
          row = [];
        } else if (ch !== '\r') { field += ch; }
      }
    }
    if (row.length) { row.push(field); rows.push(row); }
    return rows;
  }

  // ── Date DD/MM/YYYY → YYYY-MM-DD ─────────────────────────────────────────
  function normaliseDob(raw) {
    if (!raw) return null;
    // Already ISO
    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
    // DD/MM/YYYY
    var m = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (m) return m[3] + '-' + m[2].padStart(2,'0') + '-' + m[1].padStart(2,'0');
    return null;
  }

  // ── Phone → E.164 ────────────────────────────────────────────────────────
  function normaliseMobile(raw) {
    if (!raw) return null;
    var digits = raw.replace(/\D/g, '');
    if (digits.length === 9)  return '+61' + digits;
    if (digits.length === 10 && digits[0] === '0') return '+61' + digits.slice(1);
    if (digits.length === 11 && digits.slice(0, 2) === '61') return '+' + digits;
    return null;
  }

  // ── Parse ALL active registrations into players + members ────────────────
  function parseRegistrations(rows) {
    if (rows.length < 2) return { players: [], members: [], skipped: 0, skipReasons: {} };
    var h = rows[0];

    // Exact match, then case-insensitive partial
    function col() {
      var names = Array.prototype.slice.call(arguments);
      for (var n = 0; n < names.length; n++) {
        var want = names[n].trim().toLowerCase();
        for (var j = 0; j < h.length; j++) {
          if (h[j].trim().toLowerCase() === want) return j;
        }
      }
      return -1;
    }
    function colPartial(a, b) {
      for (var j = 0; j < h.length; j++) {
        if (h[j].toLowerCase().includes(a) && h[j].toLowerCase().includes(b)) return j;
      }
      return -1;
    }

    var iFirst    = col('First Name', 'firstname', 'first');
    var iLast     = col('Last Name',  'lastname',  'last');
    var iPref     = col('Preferred Name');
    var iId       = col('Profile ID', 'profile id', 'id');
    var iDob      = col('Date of Birth', 'dob', 'date of birth');
    var iRole     = col('Role');
    var iTeam     = col('Team', 'Team Name');
    var iNum      = col('Player Number', 'jumper', 'number');
    var iStatus   = col('Status');
    var iMobile   = col('Account Holder Mobile', 'mobile', 'phone');
    var iEmail    = col('Account Holder Email',  'email');
    var iP1First  = col('Parent/Guardian1 First Name');
    var iP1Last   = col('Parent/Guardian1 Last Name');
    var iP2First  = col('Parent/Guardian2 First Name');
    var iP2Last   = col('Parent/Guardian2 Last Name');
    var iEmgFirst = col('Emergency Contact First Name');
    var iEmgLast  = col('Emergency Contact Last Name');
    var iEmgPhone = col('Emergency Contact Mobile Number');
    var iMedical  = colPartial('medical conditions or allergies', 'outline');

    var playerById = {};   // dedup players by grade priority
    var memberByKey = {};  // dedup members by playhq_id+role
    var skipped = 0;
    var skipReasons = { inactive: 0, noId: 0, noGrade: 0 };

    for (var i = 1; i < rows.length; i++) {
      var r = rows[i];
      if (!r || r.every(function(f) { return !f; })) continue;

      var status = (r[iStatus] || '').trim().toLowerCase();
      if (status !== 'active') { skipped++; skipReasons.inactive++; continue; }

      var playhq_id = (r[iId]   || '').trim();
      if (!playhq_id) { skipped++; skipReasons.noId++; continue; }

      var roleRaw  = (r[iRole]  || '').trim();
      var roleLow  = roleRaw.toLowerCase();
      var team     = (r[iTeam]  || '').trim();
      var grade    = teamToGrade(team);
      var firstName = (r[iFirst] || '').trim();
      var lastName  = (r[iLast]  || '').trim();
      var fullName  = (firstName + ' ' + lastName).trim();
      var mobile    = normaliseMobile((r[iMobile] || '').trim());
      var email     = (r[iEmail] || '').trim() || null;

      if (roleLow === 'player') {
        // Players must map to a known grade
        if (!grade) { skipped++; skipReasons.noGrade++; continue; }

        var preferred = (r[iPref]  || '').trim();
        var dob       = normaliseDob((r[iDob] || '').trim());
        var numRaw    = (r[iNum]   || '').trim();
        var jumper    = numRaw ? parseInt(numRaw, 10) : null;
        var health    = iMedical >= 0 ? (r[iMedical] || '').trim() : '';
        var p1Name    = [(r[iP1First]||'').trim(), (r[iP1Last]||'').trim()].filter(Boolean).join(' ');
        var p2Name    = [(r[iP2First]||'').trim(), (r[iP2Last]||'').trim()].filter(Boolean).join(' ');
        var emgFirst  = (r[iEmgFirst] || '').trim();
        var emgLast   = (r[iEmgLast]  || '').trim();
        var emgName   = [emgFirst, emgLast].filter(Boolean).join(' ');
        var emgPhone  = normaliseMobile((r[iEmgPhone] || '').trim());

        var player = {
          playhq_id: playhq_id, first_name: firstName, last_name: lastName,
          full_name: fullName, preferred_name: preferred || undefined,
          grade: grade, dob: dob || undefined, jumper_number: jumper,
          mobile: mobile || undefined,
          emergency_name: emgName || undefined,
          emergency_phone: emgPhone || undefined,
          registration_status: 'active',
          playhq_data: {
            health_notes:  health  || undefined,
            team_raw:      team,
            parent1_name:  p1Name  || undefined,
            parent2_name:  p2Name  || undefined,
          },
          _preview_role: 'Player',
        };

        var prev = playerById[playhq_id];
        if (!prev || (GRADE_PRIORITY[grade] || 99) < (GRADE_PRIORITY[prev.grade] || 99)) {
          playerById[playhq_id] = player;
        }
      } else {
        // Coach / Team Manager / Volunteer — keep all (playhq_id + role) combos
        var key = playhq_id + '|' + roleLow;
        memberByKey[key] = {
          playhq_id: playhq_id, first_name: firstName, last_name: lastName,
          full_name: fullName, role: roleRaw,
          team: team || undefined, grade: grade || undefined,
          mobile: mobile || undefined, email: email || undefined,
          playhq_data: { team_raw: team },
          _preview_role: roleRaw,
          _preview_team: team || '—',
        };
      }
    }

    var players = [], members = [];
    for (var k in playerById)  { if (Object.prototype.hasOwnProperty.call(playerById,  k)) players.push(playerById[k]); }
    for (var k in memberByKey) { if (Object.prototype.hasOwnProperty.call(memberByKey, k)) members.push(memberByKey[k]); }
    return { players: players, members: members, skipped: skipped, skipReasons: skipReasons };
  }

  // ── State ────────────────────────────────────────────────────────────────
  var parsedPlayers = [];
  var parsedMembers = [];

  // ── Step visibility ──────────────────────────────────────────────────────
  function showStep(n) {
    for (var i = 1; i <= 3; i++) {
      var el = document.getElementById('import-step-' + i);
      if (el) el.style.display = (i === n) ? '' : 'none';
    }
  }

  // ── Open / close modal ───────────────────────────────────────────────────
  function openImportModal() {
    var m = document.getElementById('import-modal');
    if (m) { m.style.display = 'flex'; showStep(1); }
    var err = document.getElementById('import-parse-error');
    if (err) { err.style.display = 'none'; err.textContent = ''; }
    parsedPlayers = []; parsedMembers = [];
  }

  function closeImportModal() {
    var m = document.getElementById('import-modal');
    if (m) m.style.display = 'none';
  }

  // ── Process file (CSV or Excel) ──────────────────────────────────────────
  function processFile(file) {
    var errEl = document.getElementById('import-parse-error');
    function showErr(msg) { if (errEl) { errEl.textContent = msg; errEl.style.display = ''; } }

    function doRows(rows) {
      try {
        var result = parseRegistrations(rows);
        parsedPlayers = result.players;
        parsedMembers = result.members;
        var total = parsedPlayers.length + parsedMembers.length;

        if (total === 0) {
          var why = [];
          if (result.skipReasons.inactive) why.push(result.skipReasons.inactive + ' inactive');
          if (result.skipReasons.noId)     why.push(result.skipReasons.noId     + ' missing ID');
          if (result.skipReasons.noGrade)  why.push(result.skipReasons.noGrade  + ' unrecognised team');
          showErr('No active registrations found in ' + (rows.length - 1) + ' rows. Skipped: ' + (why.join(', ') || result.skipped + ' total') + '.'); return;
        }

        // Warn if players are unexpectedly empty
        var errEl = document.getElementById('import-parse-error');
        if (parsedPlayers.length === 0 && result.skipReasons.noGrade > 0) {
          if (errEl) {
            errEl.textContent = '⚠ ' + result.skipReasons.noGrade + ' player rows had unrecognised team names and were skipped. Staff will still be imported.';
            errEl.style.display = '';
          }
        } else if (errEl) { errEl.style.display = 'none'; }

        // Build combined preview (players first, then members)
        var all = parsedPlayers.concat(parsedMembers);
        var tbody = document.getElementById('import-preview-body');
        if (tbody) {
          tbody.innerHTML = all.map(function(rec) {
            var isPlayer = rec._preview_role === 'Player';
            var roleLabel = isPlayer
              ? '<span class="import-grade">' + (rec.grade || '—') + '</span>'
              : '<span class="import-role-tag import-role-' + (rec._preview_role || '').toLowerCase().replace(/\s+/g, '-') + '">' + (rec._preview_role || '—') + '</span>';
            var gradeTeam = isPlayer ? (rec.grade || '—') : (rec._preview_team || rec.team || '—');
            var dobEmail  = isPlayer ? (rec.dob || '—') : (rec.email || '—');
            var num       = isPlayer && rec.jumper_number != null ? rec.jumper_number : '—';
            return '<tr>' +
              '<td>' + rec.full_name + '</td>' +
              '<td>' + roleLabel + '</td>' +
              '<td>' + gradeTeam + '</td>' +
              '<td>' + (rec.mobile || '—') + '</td>' +
              '<td>' + dobEmail + '</td>' +
              '<td>' + num + '</td></tr>';
          }).join('');
        }

        var heading = document.getElementById('import-preview-heading');
        if (heading) heading.textContent = 'Preview — ' + parsedPlayers.length + ' players · ' + parsedMembers.length + ' staff';
        var sub = document.getElementById('import-preview-sub');
        var subParts = [result.skipped + ' rows skipped'];
        if (result.skipReasons.inactive) subParts.push(result.skipReasons.inactive + ' inactive');
        if (result.skipReasons.noGrade)  subParts.push(result.skipReasons.noGrade  + ' unrecognised team');
        if (sub) sub.textContent = subParts.join(' · ') + '.';
        showStep(2);
      } catch (err) { showErr('Parse error: ' + err.message); }
    }

    if (!file) return;
    var fname = (file.name || '').toLowerCase();
    var isExcel = fname.endsWith('.xlsx') || fname.endsWith('.xls') ||
                  file.type === 'application/vnd.ms-excel' ||
                  file.type === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet';

    if (isExcel) {
      function withXLSX(cb) {
        if (window.XLSX) { cb(); return; }
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js';
        s.onload = cb;
        s.onerror = function() {
          showErr('Could not load Excel parser. Open the file in Excel, File → Save As → CSV (Comma delimited), then import that file.');
        };
        document.head.appendChild(s);
      }
      withXLSX(function() {
        var reader = new FileReader();
        reader.onload = function(e) {
          try {
            var wb  = window.XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
            var csv = window.XLSX.utils.sheet_to_csv(wb.Sheets[wb.SheetNames[0]]);
            doRows(parseCSV(csv));
          } catch (err) { showErr('Excel read error: ' + err.message); }
        };
        reader.readAsArrayBuffer(file);
      });
    } else {
      var reader = new FileReader();
      reader.onload = function(e) {
        var text = (e.target.result || '').replace(/^﻿/, '');
        doRows(parseCSV(text));
      };
      reader.readAsText(file);
    }
  }

  // ── Wire up elements ─────────────────────────────────────────────────────
  var importBtn = document.getElementById('import-btn');
  if (importBtn) importBtn.addEventListener('click', openImportModal);

  var importClose = document.getElementById('import-modal-close');
  if (importClose) importClose.addEventListener('click', closeImportModal);

  var importModal = document.getElementById('import-modal');
  if (importModal) {
    importModal.addEventListener('click', function(e) {
      if (e.target === importModal) closeImportModal();
    });
  }

  var dropZone  = document.getElementById('csv-drop');
  var fileInput = document.getElementById('csv-file-input');

  if (dropZone) {
    dropZone.addEventListener('dragover',  function(e) { e.preventDefault(); dropZone.classList.add('over'); });
    dropZone.addEventListener('dragleave', function()  { dropZone.classList.remove('over'); });
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault(); dropZone.classList.remove('over');
      var f = e.dataTransfer && e.dataTransfer.files[0];
      if (f) processFile(f);
    });
    dropZone.addEventListener('click', function(e) {
      if (e.target !== fileInput) { if (fileInput) fileInput.click(); }
    });
  }

  if (fileInput) {
    fileInput.addEventListener('change', function() {
      if (fileInput.files && fileInput.files[0]) processFile(fileInput.files[0]);
    });
  }

  var backBtn = document.getElementById('import-back-btn');
  if (backBtn) backBtn.addEventListener('click', function() { showStep(1); });

  var confirmBtn = document.getElementById('import-confirm-btn');
  if (confirmBtn) {
    confirmBtn.addEventListener('click', function() {
      if (!parsedPlayers.length && !parsedMembers.length) return;
      confirmBtn.disabled = true;
      confirmBtn.textContent = 'Importing…';

      // Strip internal preview fields before sending
      function stripPreview(arr) {
        return arr.map(function(rec) {
          var out = {};
          for (var k in rec) {
            if (Object.prototype.hasOwnProperty.call(rec, k) && k.indexOf('_preview') !== 0) {
              out[k] = rec[k];
            }
          }
          return out;
        });
      }

      fetch('/api/admin/import-players', {
        method:      'POST',
        credentials: 'include',
        headers:     { 'Content-Type': 'application/json' },
        body:        JSON.stringify({
          players: stripPreview(parsedPlayers),
          members: stripPreview(parsedMembers),
          season:  2026,
        }),
      })
      .then(function(res) { return res.json(); })
      .then(function(json) {
        var resultEl = document.getElementById('import-result-text');
        if (resultEl) {
          if (json.ok) {
            resultEl.style.color = '';
            resultEl.textContent = '✓ ' + json.playersImported + ' players + ' + json.membersImported + ' staff imported' +
              (json.errors ? ' · ' + json.errors + ' errors.' : ' successfully.');
          } else {
            resultEl.style.color = '#f87171';
            resultEl.textContent = '✗ ' + (json.error || 'Import failed');
          }
        }
        var errList = document.getElementById('import-errors-list');
        if (errList) {
          if (json.errorDetails && json.errorDetails.length > 0) {
            errList.innerHTML = json.errorDetails.map(function(e) { return '<div>' + e + '</div>'; }).join('');
            errList.style.display = '';
          } else { errList.style.display = 'none'; }
        }
        showStep(3);
      })
      .catch(function(err) {
        var resultEl = document.getElementById('import-result-text');
        if (resultEl) { resultEl.style.color = '#f87171'; resultEl.textContent = '✗ Network error: ' + err.message; }
        showStep(3);
      })
      .finally(function() {
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Import all';
      });
    });
  }
})();
</script>

<script>
  let players: any[] = JSON.parse(
    document.getElementById('players-data')?.textContent ?? '[]'
  );

  // ── Toast ────────────────────────────────────────────────────────────────
  const toast = document.getElementById('toast')!;
  let toastTimer: ReturnType<typeof setTimeout>;
  function showToast(msg: string, type: 'ok'|'error'|'warn' = 'ok') {
    toast.textContent = msg;
    toast.className   = `toast toast-${type}`;
    toast.style.display = 'block';
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => { toast.style.display = 'none'; }, 3500);
  }

  // ── Save guernsey number via API ─────────────────────────────────────────
  async function saveNumber(
    playerId: string,
    field: 'jumper_number'|'guernsey_id',
    value: string
  ): Promise<{ ok: boolean; player?: any; conflict?: string | null }> {
    const res = await fetch('/api/admin/player', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: playerId, field, value: value === '' ? null : parseInt(value) }),
    });
    const json = await res.json();
    if (!res.ok) throw new Error(json.error ?? 'Save failed');
    const idx = players.findIndex(p => p.id === playerId);
    if (idx >= 0 && json.player) {
      players[idx].jumper     = json.player.jumper_number ?? null;
      players[idx].guernseyId = json.player.guernsey_id  ?? null;
    }
    return json;
  }

  // ════════════════════════════════════════════════════════════════════════
  // LIST VIEW — inline editing
  // ════════════════════════════════════════════════════════════════════════
  document.querySelectorAll<HTMLTableCellElement>('.num-cell').forEach(cell => {
    const display  = cell.querySelector<HTMLElement>('.num-display')!;
    const input    = cell.querySelector<HTMLInputElement>('.num-input')!;
    const field    = cell.dataset.field as 'jumper_number'|'guernsey_id';
    const row      = cell.closest<HTMLTableRowElement>('tr')!;
    const playerId = row.dataset.playerId!;

    display.addEventListener('click', () => {
      display.style.display = 'none';
      input.style.display   = 'block';
      input.focus();
      input.select();
    });

    async function commit() {
      display.style.display = 'block';
      input.style.display   = 'none';
      const newVal = input.value.trim();
      const oldVal = String(cell.dataset.current ?? '');
      if (newVal === oldVal) return;
      try {
        cell.classList.add('saving');
        const result = await saveNumber(playerId, field, newVal);
        cell.dataset.current = newVal;
        display.innerHTML    = newVal || '<span class="unset">—</span>';
        cell.classList.remove('saving');
        cell.classList.add('saved');
        setTimeout(() => cell.classList.remove('saved'), 1400);
        if (result.conflict) showToast(`⚠ ${result.conflict}`, 'warn');
        else if (field === 'jumper_number') showToast(newVal ? `Guernsey #${newVal} saved` : 'Guernsey # cleared');
        else showToast(newVal ? `Guernsey ID "${newVal}" saved` : 'Guernsey ID cleared');
      } catch (e: any) {
        cell.classList.remove('saving');
        cell.classList.add('error');
        setTimeout(() => cell.classList.remove('error'), 1400);
        showToast(`Error: ${e.message}`, 'error');
        input.value = oldVal;
      }
    }

    input.addEventListener('blur',    commit);
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter')  input.blur();
      if (e.key === 'Escape') {
        input.value           = String(cell.dataset.current ?? '');
        display.style.display = 'block';
        input.style.display   = 'none';
      }
    });
  });

  // ════════════════════════════════════════════════════════════════════════
  // BOARD VIEW — cell clicks → modal
  // ════════════════════════════════════════════════════════════════════════
  const modal      = document.getElementById('assign-modal')!;
  const modalClose = document.getElementById('modal-close')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalSub   = document.getElementById('modal-sub')!;
  const modalBody  = document.getElementById('modal-body')!;

  function closeModal() { modal.style.display = 'none'; }
  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  document.querySelectorAll<HTMLButtonElement>('.grid-cell').forEach(cell => {
    cell.addEventListener('click', () => {
      const num       = parseInt(cell.dataset.num!);
      const grade     = cell.dataset.grade!;
      const currentId = cell.dataset.playerId || null;
      modalTitle.textContent = `Guernsey #${num} — ${grade}`;

      if (currentId) {
        const player = players.find(p => p.id === currentId);
        modalSub.textContent = player ? `Currently: ${player.name}` : 'Currently assigned';
        modalBody.innerHTML  = `
          <div class="modal-actions">
            <button class="modal-btn danger" id="btn-clear">Clear #${num}</button>
            <div class="modal-divider">or reassign to</div>
            ${buildPlayerSelect(grade, currentId, num)}
            <button class="modal-btn primary" id="btn-assign">Assign</button>
          </div>`;
        document.getElementById('btn-clear')?.addEventListener('click', async () => {
          await assignNumber(currentId, num, null, grade, cell); closeModal();
        });
        document.getElementById('btn-assign')?.addEventListener('click', async () => {
          const sel = modalBody.querySelector<HTMLSelectElement>('select');
          if (!sel?.value) return;
          await assignNumber(sel.value, null, num, grade, cell); closeModal();
        });
      } else {
        modalSub.textContent = `Assign a player to #${num}`;
        modalBody.innerHTML  = `
          <div class="modal-actions">
            ${buildPlayerSelect(grade, null, num)}
            <button class="modal-btn primary" id="btn-assign">Assign #${num}</button>
          </div>`;
        document.getElementById('btn-assign')?.addEventListener('click', async () => {
          const sel = modalBody.querySelector<HTMLSelectElement>('select');
          if (!sel?.value) return;
          await assignNumber(sel.value, null, num, grade, cell); closeModal();
        });
      }
      modal.style.display = 'flex';
    });
  });

  function buildPlayerSelect(grade: string, excludeId: string | null, num: number): string {
    const opts = players
      .filter(p => p.grade === grade && p.id !== excludeId)
      .sort((a, b) => a.name.localeCompare(b.name))
      .map(p => `<option value="${p.id}">${p.name}${p.jumper ? ` (currently #${p.jumper})` : ' (unassigned)'}</option>`)
      .join('');
    return opts
      ? `<select class="modal-select">${opts}</select>`
      : `<p class="modal-empty">No other players in ${grade}</p>`;
  }

  async function assignNumber(
    targetId: string,
    clearNum: number | null,
    assignNum: number | null,
    grade: string,
    clickedCell: HTMLButtonElement
  ) {
    try {
      if (assignNum !== null) {
        const res = await saveNumber(targetId, 'jumper_number', String(assignNum));
        if (res.conflict) showToast(`⚠ ${res.conflict}`, 'warn');
        else showToast(`#${assignNum} assigned`);
      }
      if (clearNum !== null) {
        await saveNumber(targetId, 'jumper_number', '');
        showToast(`#${clearNum} cleared`);
      }
      refreshBoardGrade(grade);
    } catch (e: any) { showToast(`Error: ${e.message}`, 'error'); }
  }

  function refreshBoardGrade(grade: string) {
    const assigned: Record<number, any> = {};
    const conflicts = new Set<number>();
    for (const p of players.filter(x => x.grade === grade && x.jumper)) {
      const n = p.jumper as number;
      if (assigned[n]) conflicts.add(n);
      assigned[n] = p;
    }
    document.querySelectorAll<HTMLButtonElement>(`.grid-cell[data-grade="${grade}"]`).forEach(cell => {
      const num = parseInt(cell.dataset.num!);
      const p   = assigned[num];
      const con = conflicts.has(num);
      cell.dataset.playerId = p?.id ?? '';
      cell.className = `grid-cell ${p ? (con ? 'conflict' : 'assigned') : 'empty'}`;
      cell.title = p ? (con ? `⚠ CONFLICT on #${num}` : `${p.name} · click to clear or reassign`) : `Assign #${num}`;
      const nameEl = cell.querySelector<HTMLElement>('.cell-name');
      if (nameEl) nameEl.textContent = p ? p.first : '';
      else if (p) cell.insertAdjacentHTML('beforeend', `<span class="cell-name">${p.first}</span>`);
      let conEl = cell.querySelector('.conflict-icon');
      if (con && !conEl) cell.insertAdjacentHTML('beforeend', '<span class="conflict-icon">!</span>');
      else if (!con && conEl) conEl.remove();
    });
    const strip = document.querySelector<HTMLElement>(
      `.grade-section:has([data-grade="${grade}"]) .unassigned-strip`
    );
    if (strip) {
      const unassigned = players.filter(p => p.grade === grade && !p.jumper);
      strip.style.display = unassigned.length === 0 ? 'none' : 'flex';
      strip.querySelectorAll('.player-chip').forEach(c => c.remove());
      unassigned.forEach(p => {
        const chip = document.createElement('span');
        chip.className = 'player-chip';
        chip.dataset.playerId = p.id;
        chip.dataset.grade    = grade;
        chip.textContent = `${p.first} ${p.last}`;
        strip.appendChild(chip);
      });
    }
  }

  // ── Sync button ──────────────────────────────────────────────────────────
  document.getElementById('sync-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('sync-btn') as HTMLButtonElement;
    btn.textContent = '↻ Syncing…';
    btn.disabled = true;
    try {
      const res = await fetch('/api/sync/playhq', { method: 'POST' });
      showToast(res.ok ? '✓ PlayHQ sync complete' : '✗ Sync error', res.ok ? 'ok' : 'error');
      if (res.ok) setTimeout(() => location.reload(), 800);
    } catch { showToast('Sync failed — check connection', 'error'); }
    btn.textContent = '↻ Sync PlayHQ';
    btn.disabled = false;
  });
</script>

<style>
  .toolbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
  .filters { display:flex; gap:8px; flex:1; min-width:0; }
  .search-input { flex:1; min-width:160px; background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:8px 12px; font-size:14px; }
  .search-input:focus { outline:none; border-color:#C8102E; }
  .grade-select { background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:8px 12px; font-size:14px; cursor:pointer; }
  .btn-filter { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:8px 16px; font-size:14px; font-weight:600; cursor:pointer; }
  .toolbar-right { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
  .count { font-size:13px; color:var(--admin-muted); }
  .btn-sync { background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:8px 14px; font-size:13px; cursor:pointer; transition:border-color .2s; }
  .btn-sync:hover { border-color:#C8102E; color:#C8102E; }
  .view-toggle { display:flex; border:1px solid var(--admin-border); border-radius:6px; overflow:hidden; }
  .view-btn { padding:7px 14px; font-size:13px; text-decoration:none; color:var(--admin-muted); background:var(--admin-card); transition:all .2s; white-space:nowrap; }
  .view-btn.active { background:#C8102E; color:#fff; }
  .view-btn:hover:not(.active) { background:rgba(200,16,46,.08); color:#C8102E; }

  .stats-strip { display:flex; gap:12px; margin-bottom:24px; flex-wrap:wrap; }
  .stat { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:8px; padding:12px 20px; display:flex; flex-direction:column; align-items:center; min-width:100px; }
  .stat-n { font-size:28px; font-weight:700; color:var(--admin-text); line-height:1; }
  .stat-l { font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--admin-muted); margin-top:4px; }
