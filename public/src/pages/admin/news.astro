---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db = getAdminClient();

const { data: articles } = await db
  .from('news')
  .select('*, profiles(full_name)')
  .order('created_at', { ascending: false });

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-AU', {
    day: 'numeric', month: 'short', year: 'numeric'
  });
}

function slugify(text: string) {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const CATEGORIES = ['Club News','Match Report','Announcement','Sponsor News','Community','Results'];
---
<AdminLayout title="News">
  <div class="toolbar">
    <button class="btn-primary" id="add-article-btn">+ New Article</button>
    <span class="count">{(articles ?? []).length} articles · {(articles ?? []).filter((a:any) => a.published).length} published</span>
  </div>

  {(articles ?? []).length === 0 && (
    <div class="empty-state">
      <div class="empty-icon">📰</div>
      <p>No articles yet. Write your first news article or match report.</p>
    </div>
  )}

  <div class="articles-list">
    {(articles ?? []).map((a: any) => (
      <div class={`article-card ${!a.published ? 'article-draft' : ''} ${a.pinned ? 'article-pinned' : ''}`}>
        <div class="article-main">
          {a.image_url && <img src={a.image_url} alt="" class="article-thumb" />}
          <div class="article-body">
            <div class="article-meta-top">
              <span class="article-category">{a.category}</span>
              {a.pinned && <span class="pin-badge">📌 Pinned</span>}
              {!a.published && <span class="draft-badge">Draft</span>}
              {a.published && <span class="pub-badge">Published</span>}
            </div>
            <div class="article-title">{a.title}</div>
            <div class="article-meta">
              <span>{formatDate(a.created_at)}</span>
              {a.profiles?.full_name && <span>by {a.profiles.full_name}</span>}
              {a.published_at && <span>Published {formatDate(a.published_at)}</span>}
            </div>
            {a.body_md && (
              <div class="article-preview">
                {a.body_md.substring(0, 150)}{a.body_md.length > 150 ? '…' : ''}
              </div>
            )}
          </div>
        </div>
        <div class="article-actions">
          <button class="btn-sm btn-edit-article"
            data-id={a.id} data-title={a.title} data-category={a.category}
            data-slug={a.slug} data-body={a.body_md ?? ''} data-image={a.image_url ?? ''}
            data-href={a.href ?? ''} data-published={a.published ? '1' : '0'}
            data-pinned={a.pinned ? '1' : '0'}>Edit</button>
          <button class="btn-sm btn-publish" data-id={a.id} data-published={a.published ? '1' : '0'}>
            {a.published ? 'Unpublish' : 'Publish'}
          </button>
          <button class="btn-sm btn-delete-article" data-id={a.id} data-title={a.title}>Delete</button>
        </div>
      </div>
    ))}
  </div>

  <!-- Article Editor Modal -->
  <dialog id="article-modal" class="modal">
    <div class="modal-inner modal-wide">
      <div class="modal-header">
        <h2 id="article-modal-title">New Article</h2>
        <button class="modal-close" data-close="article-modal">✕</button>
      </div>
      <form id="article-form" class="modal-form">
        <input type="hidden" id="article-id" name="id" />
        <label class="form-group">
          Title <span class="req">*</span>
          <input type="text" name="title" required id="a-title" placeholder="e.g. Round 7 Match Report vs Port Julia" />
        </label>
        <div class="form-row">
          <label class="form-group">
            Category
            <select name="category" id="a-category">
              {CATEGORIES.map(c => <option value={c}>{c}</option>)}
            </select>
          </label>
          <label class="form-group">
            URL Slug
            <input type="text" name="slug" id="a-slug" placeholder="auto-generated from title" />
          </label>
        </div>
        <label class="form-group">
          Content (Markdown)
          <textarea name="body_md" id="a-body" rows="12" placeholder="Write your article in Markdown…

# Heading

**Bold text** and *italic text*

## Match Summary

The boys delivered a strong performance…"></textarea>
        </label>
        <label class="form-group">
          Featured Image URL
          <input type="url" name="image_url" id="a-image" placeholder="https://…" />
        </label>
        <label class="form-group">
          External Link (overrides article body)
          <input type="url" name="href" id="a-href" placeholder="https://… leave blank to use article body" />
        </label>
        <div class="form-row checkbox-row">
          <label class="checkbox-single">
            <input type="checkbox" name="published" id="a-published" /> Publish immediately
          </label>
          <label class="checkbox-single">
            <input type="checkbox" name="pinned" id="a-pinned" /> Pin to top
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" data-close="article-modal">Cancel</button>
          <button type="submit" class="btn-primary" id="article-submit">Save Article</button>
        </div>
      </form>
    </div>
  </dialog>
</AdminLayout>

<style>
  .toolbar { display:flex; align-items:center; gap:16px; margin-bottom:24px; }
  .btn-primary { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; }
  .btn-primary:hover { background:#a50d24; }
  .count { font-size:14px; color:var(--admin-muted); }

  .empty-state { text-align:center; padding:64px; color:var(--admin-muted); }
  .empty-icon { font-size:48px; margin-bottom:12px; }

  .articles-list { display:flex; flex-direction:column; gap:14px; }
  .article-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; padding:18px 20px; display:flex; align-items:flex-start; justify-content:space-between; gap:16px; }
  .article-card.article-draft { opacity:0.7; border-style:dashed; }
  .article-card.article-pinned { border-left:3px solid #C8102E; }

  .article-main { display:flex; gap:16px; align-items:flex-start; flex:1; min-width:0; }
  .article-thumb { width:80px; height:60px; object-fit:cover; border-radius:6px; flex-shrink:0; }

  .article-body { flex:1; min-width:0; }
  .article-meta-top { display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap; }
  .article-category { font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:#8ab4f8; }
  .pin-badge { font-size:11px; color:#facc15; }
  .draft-badge { background:rgba(234,179,8,0.15); color:#facc15; border-radius:3px; padding:1px 6px; font-size:10px; font-weight:600; }
  .pub-badge { background:rgba(74,222,128,0.15); color:#4ade80; border-radius:3px; padding:1px 6px; font-size:10px; font-weight:600; }

  .article-title { font-size:16px; font-weight:600; margin-bottom:5px; }
  .article-meta { font-size:12px; color:var(--admin-muted); display:flex; gap:12px; margin-bottom:8px; }
  .article-preview { font-size:13px; color:var(--admin-muted); line-height:1.5; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }

  .article-actions { display:flex; flex-direction:column; gap:6px; flex-shrink:0; }
  .btn-sm { border-radius:5px; padding:5px 10px; font-size:12px; cursor:pointer; border:1px solid var(--admin-border); background:transparent; color:var(--admin-muted); white-space:nowrap; }
  .btn-sm:hover { border-color:var(--admin-text); color:var(--admin-text); }
  .btn-delete-article:hover { border-color:#f87171; color:#f87171; }
  .btn-publish:hover { border-color:#4ade80; color:#4ade80; }

  .modal { background:transparent; border:none; padding:0; }
  .modal::backdrop { background:rgba(0,0,0,0.6); }
  .modal-inner { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:28px; width:680px; max-width:95vw; max-height:90vh; overflow-y:auto; }
  .modal-wide { width:780px; }
  .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
  .modal-header h2 { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:0.05em; }
  .modal-close { background:transparent; border:none; color:var(--admin-muted); font-size:18px; cursor:pointer; }
  .modal-form { display:flex; flex-direction:column; gap:14px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .form-group { display:flex; flex-direction:column; gap:5px; font-size:13px; color:var(--admin-muted); }
  .form-group input, .form-group select, .form-group textarea {
    background:#081426; border:1px solid var(--admin-border); color:var(--admin-text);
    border-radius:6px; padding:8px 12px; font-size:14px; font-family:inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline:none; border-color:#C8102E; }
  .form-group textarea { resize:vertical; }
  .req { color:#C8102E; }
  .checkbox-row { display:flex !important; flex-direction:row !important; gap:24px; }
  .checkbox-single { display:flex; align-items:center; gap:8px; font-size:14px; color:var(--admin-text); cursor:pointer; }
  .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:4px; }
  .btn-ghost { background:transparent; border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:6px; padding:8px 16px; font-size:14px; cursor:pointer; }
  .btn-ghost:hover { color:var(--admin-text); }
</style>

<script>
  import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  function openModal(id: string) { (document.getElementById(id) as HTMLDialogElement)?.showModal(); }
  function closeModal(id: string) { (document.getElementById(id) as HTMLDialogElement)?.close(); }

  document.querySelectorAll('[data-close]').forEach(b => b.addEventListener('click', () => closeModal((b as HTMLElement).dataset.close!)));

  function slugify(text: string) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  document.getElementById('add-article-btn')?.addEventListener('click', () => {
    (document.getElementById('article-id') as HTMLInputElement).value = '';
    (document.getElementById('article-modal-title') as HTMLElement).textContent = 'New Article';
    (document.getElementById('article-form') as HTMLFormElement).reset();
    openModal('article-modal');
  });

  // Auto-slug from title
  document.getElementById('a-title')?.addEventListener('input', (e) => {
    const slug = document.getElementById('a-slug') as HTMLInputElement;
    if (!slug.dataset.manual) {
      slug.value = slugify((e.target as HTMLInputElement).value);
    }
  });
  document.getElementById('a-slug')?.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.manual = '1';
  });

  document.querySelectorAll('.btn-edit-article').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      (document.getElementById('article-id') as HTMLInputElement).value = el.dataset.id!;
      (document.getElementById('article-modal-title') as HTMLElement).textContent = 'Edit Article';
      (document.getElementById('a-title') as HTMLInputElement).value = el.dataset.title ?? '';
      (document.getElementById('a-category') as HTMLSelectElement).value = el.dataset.category ?? '';
      (document.getElementById('a-slug') as HTMLInputElement).value = el.dataset.slug ?? '';
      (document.getElementById('a-body') as HTMLTextAreaElement).value = el.dataset.body ?? '';
      (document.getElementById('a-image') as HTMLInputElement).value = el.dataset.image ?? '';
      (document.getElementById('a-href') as HTMLInputElement).value = el.dataset.href ?? '';
      (document.getElementById('a-published') as HTMLInputElement).checked = el.dataset.published === '1';
      (document.getElementById('a-pinned') as HTMLInputElement).checked = el.dataset.pinned === '1';
      openModal('article-modal');
    });
  });

  document.querySelectorAll('.btn-publish').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const id = el.dataset.id!;
      const published = el.dataset.published === '1';
      const updates: any = { published: !published };
      if (!published) updates.published_at = new Date().toISOString();
      const { error } = await supabase.from('news').update(updates).eq('id', id);
      if (!error) window.location.reload();
      else alert('Error: ' + error.message);
    });
  });

  document.querySelectorAll('.btn-delete-article').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      if (!confirm(`Delete "${el.dataset.title}"? This cannot be undone.`)) return;
      const { error } = await supabase.from('news').delete().eq('id', el.dataset.id!);
      if (!error) window.location.reload();
      else alert('Error: ' + error.message);
    });
  });

  document.getElementById('article-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('article-submit')!;
    btn.textContent = 'Saving…';
    const fd = new FormData(e.target as HTMLFormElement);
    const title = fd.get('title') as string;
    const slug = (fd.get('slug') as string) || slugify(title);
    const isPublished = fd.has('published');
    const payload: any = {
      title,
      slug,
      category: fd.get('category'),
      body_md: fd.get('body_md') || null,
      image_url: fd.get('image_url') || null,
      href: fd.get('href') || null,
      published: isPublished,
      pinned: fd.has('pinned'),
    };
    if (isPublished) payload.published_at = new Date().toISOString();
    const id = (document.getElementById('article-id') as HTMLInputElement).value;
    let err;
    if (id) {
      ({ error: err } = await supabase.from('news').update(payload).eq('id', id));
    } else {
      ({ error: err } = await supabase.from('news').insert(payload));
    }
    if (err) { alert('Error: ' + err.message); btn.textContent = 'Save Article'; return; }
    window.location.reload();
  });
</script>
