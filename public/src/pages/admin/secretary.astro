---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db     = getAdminClient();
const season = 2026;
const today  = new Date().toISOString().split('T')[0];
const in30   = new Date(Date.now() + 30 * 86400000).toISOString().split('T')[0];
const in60   = new Date(Date.now() + 60 * 86400000).toISOString().split('T')[0];

// ── POST — clearances only ───────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = String(form.get('action') ?? '');

  if (action === 'add_clearance') {
    await db.from('clearances').insert({
      season,
      direction:      String(form.get('direction')),
      player_name:    String(form.get('player_name')).trim(),
      dob:            form.get('dob') || null,
      previous_club:  String(form.get('previous_club') || '').trim() || null,
      grade:          String(form.get('grade') || '').trim() || null,
      date_requested: String(form.get('date_requested') || today),
      status:         'pending',
      notes:          String(form.get('notes') || '').trim() || null,
    });
  }

  if (action === 'update_clearance_status') {
    await db.from('clearances')
      .update({
        status:        String(form.get('status')),
        date_approved: form.get('status') === 'approved' ? today : null,
        notes:         String(form.get('notes') || '').trim() || null,
      })
      .eq('id', String(form.get('id')));
  }

  if (action === 'delete_clearance') {
    await db.from('clearances').delete().eq('id', String(form.get('id')));
  }

  return Astro.redirect('/admin/secretary');
}

// ── Data ─────────────────────────────────────────────────────────────────────
const grades = ['A-Grade', 'B Grade', 'Senior Colts', 'Junior Colts', 'U11', 'U9'];

// Players — stats only
const { data: playersRaw } = await db
  .from('players')
  .select('id, grade, registration_status, jumper_number')
  .eq('season', season);
const players = playersRaw ?? [];

const totalPlayers    = players.length;
const activeReg       = players.filter(p => p.registration_status === 'active').length;
const totalUnassigned = players.filter(p => !p.jumper_number).length;

// Guernsey conflict detection
const playersByGrade: Record<string, any[]> = {};
for (const g of grades) playersByGrade[g] = [];
for (const p of players) {
  if (p.grade && playersByGrade[p.grade]) playersByGrade[p.grade].push(p);
}
let conflictGrades = 0;
for (const g of grades) {
  const nums = playersByGrade[g].filter(p => p.jumper_number).map(p => p.jumper_number);
  if (new Set(nums).size !== nums.length) conflictGrades++;
}

// ── Qualifications — WWCC + ALL other types, expiry + missing info ────────
// We only count issues on the dashboard; no volunteer name join is needed here.
const { data: qualsRaw } = await db
  .from('qualifications')
  .select('id, type, label, reference_number, expiry_date, verified');

const quals = (qualsRaw ?? []) as Array<{
  id: string; type: string; label: string | null; reference_number: string | null;
  expiry_date: string | null; verified: boolean | null;
}>;

const wwccQuals = quals.filter(q => q.type === 'wwc');
const wwccExpired  = wwccQuals.filter(q => q.expiry_date && q.expiry_date < today);
const wwccCritical = wwccQuals.filter(q => q.expiry_date && q.expiry_date >= today && q.expiry_date <= in30);
const wwccWarning  = wwccQuals.filter(q => q.expiry_date && q.expiry_date >  in30 && q.expiry_date <= in60);
const wwccMissingExpiry = wwccQuals.filter(q => !q.expiry_date);
const wwccMissingRef    = wwccQuals.filter(q => !q.reference_number || !q.reference_number.trim());

const otherQuals = quals.filter(q => q.type !== 'wwc');
const otherExpired  = otherQuals.filter(q => q.expiry_date && q.expiry_date < today);
const otherExpiring = otherQuals.filter(q => q.expiry_date && q.expiry_date >= today && q.expiry_date <= in30);
const otherMissingExpiry = otherQuals.filter(q => !q.expiry_date);
const otherMissingRef    = otherQuals.filter(q => !q.reference_number || !q.reference_number.trim());
const otherUnverified    = otherQuals.filter(q => !q.verified);

const wwccExpiredCount  = wwccExpired.length;
const wwccCriticalCount = wwccCritical.length;
const wwccWarningCount  = wwccWarning.length;

// Clearances
const { data: clearancesData } = await db
  .from('clearances')
  .select('*')
  .eq('season', season)
  .order('date_requested', { ascending: false });

const clearances        = clearancesData ?? [];
const clearancesIn      = clearances.filter(c => c.direction === 'in');
const clearancesOut     = clearances.filter(c => c.direction === 'out');
const clearancesPending = clearances.filter(c => c.status === 'pending');

// ── Sponsor register — build one row per sponsor GROUP + surface issues ──
const { data: sponsorRegisterRaw } = await db
  .from('club_members')
  .select('id, membership_number, full_name, membership_type, email, phone')
  .not('full_name', 'is', null);

const SPONSOR_HAYSTACK = ['sponsor', 'sposnsor', 'diamond', 'platinum', 'vip', 'gold', 'silver', 'bronze', 'major', 'club', 'patron', 'parton'];
const NON_SPONSOR      = ['player', 'life', 'committee', 'social'];
const sponsorRows = (sponsorRegisterRaw ?? []).filter(r => {
  const t = (r.membership_type ?? '').toLowerCase();
  if (!t) return false;
  if (NON_SPONSOR.some(k => t.includes(k))) return false;
  return SPONSOR_HAYSTACK.some(k => t.includes(k));
});

type SponsorGroup = {
  anchor_id:    string;
  full_name:    string;
  tier:         string;
  numbers:      number[];
  email:        string | null;
  phone:        string | null;
  contactCount: number;
  lastActivity: string | null;   // ISO date of most recent activity
  overdueFollowUp: string | null; // ISO date of nearest overdue follow-up
};

function tierOf(raw: string | null): string {
  const t = (raw ?? '').toLowerCase();
  if (t.includes('major'))    return 'Major';
  if (t.includes('diamond'))  return 'Diamond';
  if (t.includes('platinum')) return 'Platinum';
  if (t.includes('vip'))      return 'VIP';
  if (t.includes('gold'))     return 'Gold';
  if (t.includes('silver'))   return 'Silver';
  if (t.includes('bronze') || t.includes('parton') || t.includes('patron')) return 'Bronze';
  return 'Club';
}

// One SponsorGroup per (name, tier-family).
const groupMap = new Map<string, SponsorGroup>();
for (const r of sponsorRows) {
  const tier = tierOf(r.membership_type);
  const key  = `${(r.full_name ?? '').trim().toLowerCase()}|${tier}`;
  const existing = groupMap.get(key);
  if (existing) {
    existing.numbers.push(r.membership_number);
    existing.email ||= r.email;
    existing.phone ||= r.phone;
    if (r.membership_number < Math.min(...existing.numbers)) existing.anchor_id = r.id;
  } else {
    groupMap.set(key, {
      anchor_id: r.id,
      full_name: r.full_name!,
      tier,
      numbers:   [r.membership_number],
      email:     r.email,
      phone:     r.phone,
      contactCount:    0,
      lastActivity:    null,
      overdueFollowUp: null,
    });
  }
}
// Fix anchor to lowest-number sibling
for (const g of groupMap.values()) {
  g.numbers.sort((a, b) => a - b);
  const anchorRow = sponsorRows.find(r => r.full_name === g.full_name && r.membership_number === g.numbers[0]);
  if (anchorRow) g.anchor_id = anchorRow.id;
}

// Pull all anchor ids in one shot to load contacts + activity in bulk.
const anchorIds = Array.from(groupMap.values()).map(g => g.anchor_id);
const [{ data: contactsRaw }, { data: activitiesRaw }] = anchorIds.length ? await Promise.all([
  db.from('sponsor_contacts').select('member_id').in('member_id', anchorIds),
  db.from('sponsor_activities').select('member_id, activity_date, follow_up_date').in('member_id', anchorIds),
]) : [{ data: [] }, { data: [] }];

for (const c of contactsRaw ?? []) {
  const g = Array.from(groupMap.values()).find(x => x.anchor_id === c.member_id);
  if (g) g.contactCount++;
}
for (const a of activitiesRaw ?? []) {
  const g = Array.from(groupMap.values()).find(x => x.anchor_id === a.member_id);
  if (!g) continue;
  if (a.activity_date && (!g.lastActivity || a.activity_date > g.lastActivity)) g.lastActivity = a.activity_date;
  if (a.follow_up_date && a.follow_up_date <= today) {
    if (!g.overdueFollowUp || a.follow_up_date < g.overdueFollowUp) g.overdueFollowUp = a.follow_up_date;
  }
}

const sponsorGroupsArr = Array.from(groupMap.values());
const totalSponsorGroups   = sponsorGroupsArr.length;

// Cutoff for "stale" contact — 30 days without a log entry.
const daysAgo30 = new Date(Date.now() - 30 * 86400000).toISOString().split('T')[0];

const sponsorsMissingEmail    = sponsorGroupsArr.filter(g => !g.email);
const sponsorsMissingPhone    = sponsorGroupsArr.filter(g => !g.phone);
const sponsorsNoContact       = sponsorGroupsArr.filter(g => g.contactCount === 0);
const sponsorsStale           = sponsorGroupsArr.filter(g => !g.lastActivity || g.lastActivity < daysAgo30);
const sponsorsOverdueFollowUp = sponsorGroupsArr.filter(g => g.overdueFollowUp !== null);

// The union of "sponsors that need any kind of attention" — for the focus list.
const sponsorsNeedingAttention = sponsorGroupsArr
  .filter(g => !g.email || !g.phone || g.contactCount === 0 || !g.lastActivity || g.lastActivity < daysAgo30 || g.overdueFollowUp !== null)
  .sort((a, b) => {
    // Sort: overdue follow-up first, then stale, then by tier
    const aScore = (a.overdueFollowUp ? 4 : 0) + (!a.email ? 2 : 0) + (!a.phone ? 1 : 0) + (!a.lastActivity ? 1 : 0);
    const bScore = (b.overdueFollowUp ? 4 : 0) + (!b.email ? 2 : 0) + (!b.phone ? 1 : 0) + (!b.lastActivity ? 1 : 0);
    return bScore - aScore || a.numbers[0] - b.numbers[0];
  });

// Action items
type ActionTopic = 'WWCC' | 'Qualification' | 'Player' | 'Clearance' | 'Sponsor';
type ActionItem  = { level: 'alert'|'warn'|'info'; topic: ActionTopic; text: string; href: string; cta: string };
const actions: ActionItem[] = [];

// ── WWCC ────────────────────────────────────────────────────────────
if (wwccExpiredCount > 0) actions.push({
  level: 'alert', topic: 'WWCC',
  text:  `${wwccExpiredCount} expired WWCC check${wwccExpiredCount > 1 ? 's' : ''} — volunteers cannot work with children`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (wwccMissingExpiry.length > 0) actions.push({
  level: 'alert', topic: 'WWCC',
  text:  `${wwccMissingExpiry.length} WWCC record${wwccMissingExpiry.length > 1 ? 's have' : ' has'} no expiry date on file`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (wwccCriticalCount > 0) actions.push({
  level: 'warn', topic: 'WWCC',
  text:  `${wwccCriticalCount} WWCC check${wwccCriticalCount > 1 ? 's' : ''} expiring within 30 days`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (wwccMissingRef.length > 0) actions.push({
  level: 'warn', topic: 'WWCC',
  text:  `${wwccMissingRef.length} WWCC record${wwccMissingRef.length > 1 ? 's are' : ' is'} missing a reference number`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (wwccWarningCount > 0) actions.push({
  level: 'info', topic: 'WWCC',
  text:  `${wwccWarningCount} WWCC check${wwccWarningCount > 1 ? 's' : ''} expiring within 60 days`,
  href:  '/admin/qualifications', cta: 'Open →',
});

// ── Other qualifications (trainer, first-aid, etc.) ────────────────
if (otherExpired.length > 0) actions.push({
  level: 'alert', topic: 'Qualification',
  text:  `${otherExpired.length} non-WWCC qualification${otherExpired.length > 1 ? 's have' : ' has'} expired`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (otherExpiring.length > 0) actions.push({
  level: 'warn', topic: 'Qualification',
  text:  `${otherExpiring.length} non-WWCC qualification${otherExpiring.length > 1 ? 's' : ''} expiring within 30 days`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (otherMissingExpiry.length > 0) actions.push({
  level: 'warn', topic: 'Qualification',
  text:  `${otherMissingExpiry.length} non-WWCC qualification${otherMissingExpiry.length > 1 ? 's have' : ' has'} no expiry date on file`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (otherMissingRef.length > 0) actions.push({
  level: 'info', topic: 'Qualification',
  text:  `${otherMissingRef.length} non-WWCC qualification${otherMissingRef.length > 1 ? 's are' : ' is'} missing a reference number`,
  href:  '/admin/qualifications', cta: 'Open →',
});
if (otherUnverified.length > 0) actions.push({
  level: 'info', topic: 'Qualification',
  text:  `${otherUnverified.length} qualification${otherUnverified.length > 1 ? 's are' : ' is'} unverified`,
  href:  '/admin/qualifications', cta: 'Open →',
});

// ── Players ────────────────────────────────────────────────────────
if (conflictGrades > 0) actions.push({
  level: 'alert', topic: 'Player',
  text:  `Guernsey number conflicts detected in ${conflictGrades} grade${conflictGrades > 1 ? 's' : ''}`,
  href:  '/admin/players', cta: 'Open →',
});
if (totalUnassigned > 0) actions.push({
  level: 'warn', topic: 'Player',
  text:  `${totalUnassigned} player${totalUnassigned > 1 ? 's' : ''} without a guernsey number`,
  href:  '/admin/players', cta: 'Open →',
});

// ── Clearances ────────────────────────────────────────────────────
if (clearancesPending.length > 0) actions.push({
  level: 'warn', topic: 'Clearance',
  text:  `${clearancesPending.length} pending clearance${clearancesPending.length > 1 ? 's' : ''} awaiting processing`,
  href:  '#clearances', cta: 'Manage ↓',
});

// ── Sponsors ─────────────────────────────────────────────────────
if (sponsorsOverdueFollowUp.length > 0) actions.push({
  level: 'alert', topic: 'Sponsor',
  text:  `${sponsorsOverdueFollowUp.length} sponsor follow-up${sponsorsOverdueFollowUp.length > 1 ? 's are' : ' is'} due today or overdue`,
  href:  '/admin/sponsor-register', cta: 'Open Register →',
});
if (sponsorsMissingEmail.length > 0) actions.push({
  level: 'alert', topic: 'Sponsor',
  text:  `${sponsorsMissingEmail.length} sponsor${sponsorsMissingEmail.length > 1 ? 's are' : ' is'} missing an email — group mailing list is incomplete`,
  href:  '/admin/sponsor-register', cta: 'Open Register →',
});
if (sponsorsMissingPhone.length > 0) actions.push({
  level: 'warn', topic: 'Sponsor',
  text:  `${sponsorsMissingPhone.length} sponsor${sponsorsMissingPhone.length > 1 ? 's are' : ' is'} missing a phone number`,
  href:  '/admin/sponsor-register', cta: 'Open Register →',
});
if (sponsorsNoContact.length > 0) actions.push({
  level: 'warn', topic: 'Sponsor',
  text:  `${sponsorsNoContact.length} sponsor${sponsorsNoContact.length > 1 ? 's have' : ' has'} no contact person on file`,
  href:  '/admin/sponsor-register', cta: 'Open Register →',
});
if (sponsorsStale.length > 0) actions.push({
  level: 'warn', topic: 'Sponsor',
  text:  `${sponsorsStale.length} sponsor${sponsorsStale.length > 1 ? 's have' : ' has'} had no contact in the last 30 days`,
  href:  '/admin/sponsor-register', cta: 'Open Register →',
});

// Bucket by severity for the grouped display below.
const alertActions = actions.filter(a => a.level === 'alert');
const warnActions  = actions.filter(a => a.level === 'warn');
const infoActions  = actions.filter(a => a.level === 'info');

const TOPIC_META: Record<ActionTopic, { icon: string; label: string }> = {
  'WWCC':          { icon: '🛡',  label: 'WWCC' },
  'Qualification': { icon: '📋', label: 'Qualification' },
  'Player':        { icon: '👥', label: 'Player' },
  'Clearance':     { icon: '📄', label: 'Clearance' },
  'Sponsor':       { icon: '💼', label: 'Sponsor' },
};

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
}
const statusColors: Record<string, string> = {
  pending:   'status-pending',
  approved:  'status-approved',
  refused:   'status-refused',
  withdrawn: 'status-withdrawn',
};
---

<AdminLayout title="Secretary">

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- OVERVIEW STATS                                                        -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <div class="section-label">Season Overview</div>
  <div class="stats-grid">
    <a href="/admin/players" class="stat-card">
      <span class="stat-n">{totalPlayers}</span>
      <span class="stat-l">Total Players</span>
      <span class="stat-sub">{activeReg} active · {totalUnassigned} no guernsey</span>
    </a>
    <a href="/admin/qualifications" class={`stat-card ${wwccExpiredCount > 0 || wwccMissingExpiry.length > 0 || otherExpired.length > 0 ? 'alert' : wwccCriticalCount > 0 || otherExpiring.length > 0 ? 'warn' : ''}`}>
      <span class="stat-n">{wwccExpiredCount + otherExpired.length + wwccMissingExpiry.length + otherMissingExpiry.length}</span>
      <span class="stat-l">Qualifications Issues</span>
      <span class="stat-sub">{wwccExpiredCount + otherExpired.length} expired · {wwccMissingExpiry.length + otherMissingExpiry.length} no expiry</span>
    </a>
    <a href="#clearances" class={`stat-card ${clearancesPending.length > 0 ? 'warn' : ''}`}>
      <span class="stat-n">{clearancesPending.length}</span>
      <span class="stat-l">Pending Clearances</span>
      <span class="stat-sub">{clearancesIn.length} in · {clearancesOut.length} out this season</span>
    </a>
    <a href="#sponsorship-focus" class={`stat-card ${sponsorsOverdueFollowUp.length > 0 || sponsorsMissingEmail.length > 0 ? 'alert' : sponsorsNeedingAttention.length > 0 ? 'warn' : ''}`}>
      <span class="stat-n">{sponsorsNeedingAttention.length}</span>
      <span class="stat-l">Sponsors Needing Attention</span>
      <span class="stat-sub">{sponsorsOverdueFollowUp.length} follow-up · {sponsorsMissingEmail.length} no email · of {totalSponsorGroups} total</span>
    </a>
  </div>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- ACTION REQUIRED                                                       -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <div class="section-label">Action Required</div>

  {actions.length === 0 ? (
    <div class="all-clear">
      <span class="all-clear-icon">✓</span>
      Nothing requires your attention. All checks are current.
    </div>
  ) : (
    <div class="action-bucket-list">
      {alertActions.length > 0 && (
        <section class="action-bucket bucket-alert">
          <header class="action-bucket-head">
            <span class="bucket-icon">🚨</span>
            <span class="bucket-title">Immediate Action</span>
            <span class="bucket-count">{alertActions.length}</span>
          </header>
          <ul class="action-bucket-list-inner">
            {alertActions.map(item => (
              <li class="action-row">
                <span class="action-topic">{TOPIC_META[item.topic].icon} {TOPIC_META[item.topic].label}</span>
                <span class="action-text">{item.text}</span>
                <a href={item.href} class="action-cta">{item.cta}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {warnActions.length > 0 && (
        <section class="action-bucket bucket-warn">
          <header class="action-bucket-head">
            <span class="bucket-icon">⚠️</span>
            <span class="bucket-title">Needs Attention</span>
            <span class="bucket-count">{warnActions.length}</span>
          </header>
          <ul class="action-bucket-list-inner">
            {warnActions.map(item => (
              <li class="action-row">
                <span class="action-topic">{TOPIC_META[item.topic].icon} {TOPIC_META[item.topic].label}</span>
                <span class="action-text">{item.text}</span>
                <a href={item.href} class="action-cta">{item.cta}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {infoActions.length > 0 && (
        <section class="action-bucket bucket-info">
          <header class="action-bucket-head">
            <span class="bucket-icon">ℹ️</span>
            <span class="bucket-title">For Awareness</span>
            <span class="bucket-count">{infoActions.length}</span>
          </header>
          <ul class="action-bucket-list-inner">
            {infoActions.map(item => (
              <li class="action-row">
                <span class="action-topic">{TOPIC_META[item.topic].icon} {TOPIC_META[item.topic].label}</span>
                <span class="action-text">{item.text}</span>
                <a href={item.href} class="action-cta">{item.cta}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- SPONSORSHIP FOCUS                                                     -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <div class="section-label focus-label" id="sponsorship-focus">
    Sponsorship Focus
    <a href="/admin/sponsor-register" class="section-btn">Open Sponsor Register →</a>
  </div>

  <div class="focus-tiles">
    <div class={`focus-tile ${sponsorsOverdueFollowUp.length > 0 ? 'alert' : ''}`}>
      <span class="focus-n">{sponsorsOverdueFollowUp.length}</span>
      <span class="focus-l">Follow-ups Due / Overdue</span>
    </div>
    <div class={`focus-tile ${sponsorsMissingEmail.length > 0 ? 'alert' : ''}`}>
      <span class="focus-n">{sponsorsMissingEmail.length}</span>
      <span class="focus-l">Missing Email</span>
    </div>
    <div class={`focus-tile ${sponsorsMissingPhone.length > 0 ? 'warn' : ''}`}>
      <span class="focus-n">{sponsorsMissingPhone.length}</span>
      <span class="focus-l">Missing Phone</span>
    </div>
    <div class={`focus-tile ${sponsorsNoContact.length > 0 ? 'warn' : ''}`}>
      <span class="focus-n">{sponsorsNoContact.length}</span>
      <span class="focus-l">No Contact Person</span>
    </div>
    <div class={`focus-tile ${sponsorsStale.length > 0 ? 'warn' : ''}`}>
      <span class="focus-n">{sponsorsStale.length}</span>
      <span class="focus-l">No Contact &gt; 30 days</span>
    </div>
  </div>

  {sponsorsNeedingAttention.length === 0 ? (
    <div class="all-clear">
      <span class="all-clear-icon">✓</span>
      All sponsors have complete details and recent contact. Well done.
    </div>
  ) : (
    <a href="/admin/sponsor-register" class="focus-open">
      <span>{sponsorsNeedingAttention.length} sponsor{sponsorsNeedingAttention.length > 1 ? 's need' : ' needs'} attention</span>
      <span class="focus-open-cta">Open Sponsor Register to review →</span>
    </a>
  )}

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- SECRETARY TOOLS                                                       -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <div class="section-label">Secretary Tools</div>
  <div class="quick-actions">
    <a href="/admin/membership" class="quick-action-btn">
      <span class="qa-icon" aria-hidden="true">🎫</span>
      <span class="qa-label">Club Membership</span>
      <span class="qa-sub">Register &amp; contact details</span>
    </a>
    <a href="/admin/meal-vouchers" class="quick-action-btn">
      <span class="qa-icon" aria-hidden="true">🍽</span>
      <span class="qa-label">Meal Vouchers</span>
      <span class="qa-sub">Sponsor &amp; VIP entitlements</span>
    </a>
    <a href="/admin/qualifications" class="quick-action-btn">
      <span class="qa-icon" aria-hidden="true">📋</span>
      <span class="qa-label">Qualifications &amp; WWCC</span>
      <span class="qa-sub">Compliance &amp; expiry tracking</span>
    </a>
  </div>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- CLEARANCES                                                            -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <div class="section-label" id="clearances">
    Player Clearances — {season}
    <button class="section-btn" id="new-clearance-btn">+ New clearance</button>
  </div>

  {clearances.length === 0 && (
    <div class="empty-section">No clearances recorded for {season}.</div>
  )}

  {clearances.length > 0 && (
    <table class="data-table">
      <thead>
        <tr>
          <th>Direction</th>
          <th>Player</th>
          <th>Grade</th>
          <th>Club</th>
          <th>Requested</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {clearances.map(c => (
          <tr>
            <td>
              <span class={`dir-badge ${c.direction === 'in' ? 'dir-in' : 'dir-out'}`}>
                {c.direction === 'in' ? '↓ IN' : '↑ OUT'}
              </span>
            </td>
            <td class="player-name">
              {c.player_name}
              {c.dob && <span class="muted"> · DOB {c.dob}</span>}
            </td>
            <td class="muted">{c.grade || '—'}</td>
            <td class="muted">{c.previous_club || '—'}</td>
            <td class="muted">{fmtDate(c.date_requested)}</td>
            <td>
              <span class={`badge ${statusColors[c.status]}`}>{c.status}</span>
              {c.date_approved && <span class="muted"> {fmtDate(c.date_approved)}</span>}
            </td>
            <td class="row-actions">
              <button
                class="btn-icon"
                data-clearance={JSON.stringify(c)}
                title="Update status"
                onclick="openUpdateModal(this)"
              >✎</button>
              <form method="post" style="display:inline" onsubmit="return confirm('Delete this clearance?')">
                <input type="hidden" name="action" value="delete_clearance" />
                <input type="hidden" name="id"     value={c.id} />
                <button class="btn-icon btn-danger-icon" title="Delete">✕</button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}


  <!-- ── New Clearance Modal ─────────────────────────────────────────────── -->
  <div id="clearance-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <button class="modal-close" onclick="document.getElementById('clearance-modal').style.display='none'">✕</button>
      <h3>New Clearance</h3>
      <form method="post" class="modal-form">
        <input type="hidden" name="action" value="add_clearance" />
        <div class="form-row-2">
          <label>Direction
            <select name="direction" required>
              <option value="in">↓ Transfer IN to Wallaroo</option>
              <option value="out">↑ Transfer OUT from Wallaroo</option>
            </select>
          </label>
          <label>Grade
            <select name="grade">
              <option value="">— select —</option>
              {grades.map(g => <option value={g}>{g}</option>)}
            </select>
          </label>
        </div>
        <label>Player name <input type="text" name="player_name" required placeholder="Full name" /></label>
        <div class="form-row-2">
          <label>Date of birth <input type="date" name="dob" /></label>
          <label>Date requested <input type="date" name="date_requested" value={today} required /></label>
        </div>
        <label>Previous / destination club <input type="text" name="previous_club" placeholder="e.g. Ardrossan FC" /></label>
        <label>Notes <textarea name="notes" rows="2" placeholder="Any relevant details…"></textarea></label>
        <button type="submit" class="btn-primary">Save clearance</button>
      </form>
    </div>
  </div>

  <!-- ── Update Status Modal ─────────────────────────────────────────────── -->
  <div id="update-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <button class="modal-close" onclick="document.getElementById('update-modal').style.display='none'">✕</button>
      <h3>Update Clearance</h3>
      <form method="post" class="modal-form" id="update-form">
        <input type="hidden" name="action" value="update_clearance_status" />
        <input type="hidden" name="id"     id="update-id" />
        <p id="update-player" class="update-player"></p>
        <label>Status
          <select name="status" id="update-status" required>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="refused">Refused</option>
            <option value="withdrawn">Withdrawn</option>
          </select>
        </label>
        <label>Notes <textarea name="notes" id="update-notes" rows="2"></textarea></label>
        <button type="submit" class="btn-primary">Update</button>
      </form>
    </div>
  </div>

</AdminLayout>

<script>
  document.getElementById('new-clearance-btn')?.addEventListener('click', () => {
    (document.getElementById('clearance-modal') as HTMLElement).style.display = 'flex';
  });
  document.getElementById('clearance-modal')?.addEventListener('click', (e: Event) => {
    if (e.target === e.currentTarget)
      (document.getElementById('clearance-modal') as HTMLElement).style.display = 'none';
  });
  document.getElementById('update-modal')?.addEventListener('click', (e: Event) => {
    if (e.target === e.currentTarget)
      (document.getElementById('update-modal') as HTMLElement).style.display = 'none';
  });

  (window as any).openUpdateModal = (btn: HTMLButtonElement) => {
    const data = JSON.parse(btn.dataset.clearance!);
    (document.getElementById('update-id') as HTMLInputElement).value      = data.id;
    (document.getElementById('update-status') as HTMLSelectElement).value = data.status;
    (document.getElementById('update-notes') as HTMLTextAreaElement).value = data.notes ?? '';
    const dir = data.direction === 'in' ? '↓ IN' : '↑ OUT';
    (document.getElementById('update-player') as HTMLElement).textContent =
      `${dir} · ${data.player_name}${data.grade ? ' · ' + data.grade : ''}`;
    (document.getElementById('update-modal') as HTMLElement).style.display = 'flex';
  };
</script>

<style>
  /* ── Section labels ────────────────────────────────────────────────────*/
  .section-label {
    display:flex; align-items:center; justify-content:space-between;
    font-size:11px; text-transform:uppercase; letter-spacing:.14em;
    color:var(--admin-muted); margin:32px 0 14px;
    padding-bottom:8px; border-bottom:1px solid var(--admin-border);
  }
  .section-label:first-child { margin-top:0; }
  .section-btn  { background:#C8102E; color:#fff; border:none; border-radius:5px; padding:5px 12px; font-size:12px; cursor:pointer; text-transform:none; letter-spacing:0; }
  .section-btn:hover { background:#a00e26; }

  /* ── Quick actions (sits between Action Required and Clearances) ───────*/
  .quick-actions { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:12px; margin:16px 0 32px; }
  .quick-action-btn {
    display:flex; flex-direction:column; gap:2px;
    padding:16px 20px; text-decoration:none;
    background:var(--admin-card); border:1px solid var(--admin-border); border-radius:8px;
    color:var(--admin-text);
    transition:border-color .12s, transform .12s, box-shadow .12s;
  }
  .quick-action-btn:hover { border-color:#C8102E; transform:translateY(-1px); box-shadow:0 4px 12px rgba(200,16,46,0.12); }
  .qa-icon { font-size:22px; line-height:1; margin-bottom:6px; }
  .qa-label { font-weight:600; font-size:15px; letter-spacing:0.02em; }
  .qa-sub { font-size:12px; color:var(--admin-muted); }

  /* ── Stats grid ────────────────────────────────────────────────────────*/
  .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; margin-bottom:8px; }
  .stat-card {
    background:var(--admin-card); border:1px solid var(--admin-border);
    border-radius:10px; padding:20px 22px;
    display:flex; flex-direction:column; gap:4px;
    text-decoration:none; color:inherit; transition:border-color .2s;
  }
  .stat-card:hover { border-color:#C8102E; }
  .stat-card.alert { border-color:rgba(239,68,68,.5); background:rgba(239,68,68,.05); }
  .stat-card.warn  { border-color:rgba(249,115,22,.4); background:rgba(249,115,22,.04); }
  .stat-n   { font-size:38px; font-weight:700; color:var(--admin-text); line-height:1; }
  .stat-card.alert .stat-n { color:#f87171; }
  .stat-card.warn  .stat-n { color:#fb923c; }
  .stat-l   { font-size:12px; font-weight:600; color:var(--admin-text); margin-top:2px; }
  .stat-sub { font-size:11px; color:var(--admin-muted); }

  /* ── Action Required — severity buckets ────────────────────────────────*/
  .action-bucket-list { display:flex; flex-direction:column; gap:14px; margin-bottom:8px; }
  .action-bucket {
    border-radius:10px; overflow:hidden; border:1px solid;
  }
  .bucket-alert { border-color:rgba(239,68,68,.45); background:rgba(239,68,68,.04); }
  .bucket-warn  { border-color:rgba(249,115,22,.35); background:rgba(249,115,22,.03); }
  .bucket-info  { border-color:rgba(96,165,250,.28); background:rgba(96,165,250,.03); }

  .action-bucket-head {
    display:flex; align-items:center; gap:10px;
    padding:10px 16px;
    font-size:12px; font-weight:700; letter-spacing:.10em; text-transform:uppercase;
    border-bottom:1px solid;
  }
  .bucket-alert .action-bucket-head { color:#f87171; border-bottom-color:rgba(239,68,68,.3); background:rgba(239,68,68,.08); }
  .bucket-warn  .action-bucket-head { color:#fb923c; border-bottom-color:rgba(249,115,22,.25); background:rgba(249,115,22,.06); }
  .bucket-info  .action-bucket-head { color:#93c5fd; border-bottom-color:rgba(96,165,250,.22); background:rgba(96,165,250,.05); }
  .bucket-icon  { font-size:16px; }
  .bucket-title { flex:1; }
  .bucket-count {
    background:rgba(255,255,255,.1); color:inherit; border-radius:999px;
    padding:2px 10px; font-size:11px; letter-spacing:.02em;
  }

  .action-bucket-list-inner { list-style:none; margin:0; padding:0; }
  .action-row {
    display:grid; grid-template-columns:110px 1fr auto; gap:14px; align-items:center;
    padding:11px 16px; border-bottom:1px solid var(--admin-border);
    font-size:13px;
  }
  .action-row:last-child { border-bottom:none; }
  .action-row:hover { background:rgba(255,255,255,.03); }
  .action-topic {
    font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.06em;
    color:var(--admin-muted); white-space:nowrap;
  }
  .action-text { color:var(--admin-text); line-height:1.4; }
  .action-cta { font-size:12px; font-weight:600; text-decoration:none; white-space:nowrap; color:#C8102E; }
  .action-cta:hover { text-decoration:underline; }
  @media (max-width: 720px) {
    .action-row { grid-template-columns:1fr; gap:4px; }
    .action-topic { color:var(--admin-muted); }
  }

  .all-clear { display:flex; align-items:center; gap:10px; background:rgba(34,197,94,.08); border:1px solid rgba(34,197,94,.2); border-radius:8px; padding:16px 20px; font-size:14px; color:#4ade80; }
  .all-clear-icon { font-size:18px; }

  /* ── Clearances table ──────────────────────────────────────────────────*/
  .data-table { width:100%; border-collapse:collapse; font-size:13px; background:var(--admin-card); border:1px solid var(--admin-border); border-radius:8px; overflow:hidden; margin-bottom:8px; }
  th { text-align:left; padding:9px 14px; font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--admin-muted); background:rgba(0,0,0,.2); border-bottom:1px solid var(--admin-border); }
  td { padding:10px 14px; border-bottom:1px solid var(--admin-border); vertical-align:middle; }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(255,255,255,.02); }
  .muted { color:var(--admin-muted); font-size:12px; }
  .player-name { font-weight:500; color:var(--admin-text); font-size:13px; }
  .empty-section { color:var(--admin-muted); font-size:14px; font-style:italic; padding:12px 0; }

  .badge { border-radius:4px; padding:3px 8px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.06em; }
  .status-pending   { background:rgba(234,179,8,.15);  color:#facc15; }
  .status-approved  { background:rgba(34,197,94,.15);  color:#4ade80; }
  .status-refused   { background:rgba(239,68,68,.15);  color:#f87171; }
  .status-withdrawn { background:rgba(255,255,255,.08); color:var(--admin-muted); }
  .dir-badge { font-size:11px; font-weight:700; letter-spacing:.06em; border-radius:4px; padding:3px 8px; }
  .dir-in  { background:rgba(34,197,94,.15);  color:#4ade80; }
  .dir-out { background:rgba(249,115,22,.15); color:#fb923c; }
  .row-actions { display:flex; gap:4px; align-items:center; }
  .btn-icon { background:rgba(255,255,255,.06); border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:5px; padding:4px 8px; font-size:13px; cursor:pointer; }
  .btn-icon:hover { color:var(--admin-text); border-color:var(--admin-text); }
  .btn-danger-icon:hover { background:rgba(239,68,68,.15); color:#f87171; border-color:rgba(239,68,68,.3); }

  /* ── Sponsorship focus zone ────────────────────────────────────────────*/
  .focus-label {
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    scroll-margin-top:20px;
  }
  .focus-label .section-btn {
    background:transparent; border:none; color:#C8102E; font-size:12px;
    font-weight:600; text-decoration:none; padding:4px 8px; border-radius:4px;
    cursor:pointer;
  }
  .focus-label .section-btn:hover { text-decoration:underline; }

  .focus-tiles {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
    gap:10px; margin:8px 0 16px;
  }
  .focus-tile {
    background:var(--admin-card); border:1px solid var(--admin-border);
    border-radius:8px; padding:14px 18px; display:flex; flex-direction:column; gap:2px;
  }
  .focus-tile.alert { border-color:rgba(239,68,68,.5); background:rgba(239,68,68,.06); }
  .focus-tile.warn  { border-color:rgba(249,115,22,.4); background:rgba(249,115,22,.05); }
  .focus-n {
    font-size:26px; font-weight:700; color:var(--admin-text); line-height:1;
  }
  .focus-tile.alert .focus-n { color:#f87171; }
  .focus-tile.warn  .focus-n { color:#fb923c; }
  .focus-l { font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--admin-muted); }

  .focus-open {
    display:flex; align-items:center; justify-content:space-between;
    background:rgba(200,16,46,.06); border:1px solid rgba(200,16,46,.35);
    border-radius:8px; padding:14px 20px; margin-bottom:8px;
    text-decoration:none; color:var(--admin-text); font-size:14px;
    transition:background-color .2s;
  }
  .focus-open:hover { background:rgba(200,16,46,.12); }
  .focus-open-cta { font-size:12px; font-weight:600; color:#C8102E; }

  /* ── Modal ─────────────────────────────────────────────────────────────*/
  .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:100; display:flex; align-items:center; justify-content:center; padding:20px; }
  .modal { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:28px 32px; width:520px; max-width:95vw; position:relative; max-height:90vh; overflow-y:auto; }
  .modal-close { position:absolute; top:14px; right:16px; background:none; border:none; color:var(--admin-muted); font-size:18px; cursor:pointer; }
  .modal h3 { font-size:18px; font-weight:700; margin-bottom:20px; }
  .update-player { font-size:13px; color:var(--admin-muted); margin-bottom:16px; font-style:italic; }
  .modal-form { display:flex; flex-direction:column; gap:14px; }
  .form-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .modal-form label { display:flex; flex-direction:column; gap:5px; font-size:12px; text-transform:uppercase; letter-spacing:.1em; color:var(--admin-muted); }
  .modal-form input, .modal-form select, .modal-form textarea {
    background:var(--admin-bg); border:1px solid var(--admin-border);
    color:var(--admin-text); border-radius:6px; padding:9px 12px; font-size:14px;
    font-family:inherit;
  }
  .modal-form input:focus, .modal-form select:focus, .modal-form textarea:focus { outline:none; border-color:#C8102E; }
  .modal-form textarea { resize:vertical; }
  .btn-primary { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:11px 20px; font-size:14px; font-weight:600; cursor:pointer; margin-top:4px; }
  .btn-primary:hover { background:#a00e26; }

  @media (max-width:700px) {
    .stats-grid { grid-template-columns:1fr 1fr; }
    .form-row-2 { grid-template-columns:1fr; }
  }
</style>
