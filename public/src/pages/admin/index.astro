---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Dashboard">
  <div class="dash-grid">

    <div class="stat-card">
      <div class="stat-label">Current Round</div>
      <div class="stat-num">7</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Registered Players</div>
      <div class="stat-num" id="player-count">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Active Sponsors</div>
      <div class="stat-num" id="sponsor-count">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Expiring Quals (90 days)</div>
      <div class="stat-num alert" id="qual-count">—</div>
    </div>

    <div class="panel">
      <h2>Quick Links</h2>
      <nav class="quick-nav">
        <a href="/admin/players">👥 Players</a>
        <a href="/admin/qualifications">📋 Qualifications & WWC</a>
        <a href="/admin/roster">🍺 Bar Roster</a>
        <a href="/admin/fixtures">📅 Fixtures</a>
        <a href="/admin/results">🏉 Results</a>
        <a href="/admin/sponsors">🤝 Sponsors</a>
        <a href="/admin/news">📰 News</a>
        <a href="/admin/members">👤 Committee</a>
      </nav>
    </div>

    <div class="panel">
      <h2>PlayHQ Sync</h2>
      <p class="muted">Last synced: <span id="last-sync">checking…</span></p>
      <button id="sync-btn" class="btn-sync">Sync Now</button>
    </div>

  </div>
</AdminLayout>

<style>
  .dash-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .stat-card {
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    padding: 24px;
  }
  .stat-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--admin-muted); margin-bottom: 8px; }
  .stat-num { font-size: 48px; font-family: 'Bebas Neue', sans-serif; color: var(--admin-text); }
  .stat-num.alert { color: #e55; }
  .panel {
    grid-column: span 2;
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    padding: 28px;
  }
  .panel h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
  .quick-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .quick-nav a {
    display: block;
    padding: 12px 16px;
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 6px;
    font-size: 14px;
    color: var(--admin-text);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .quick-nav a:hover { border-color: #C8102E; color: #C8102E; }
  .muted { font-size: 13px; color: var(--admin-muted); margin-bottom: 16px; }
  .btn-sync {
    background: #C8102E;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-sync:hover { background: #8E0B20; }
  @media (max-width: 900px) {
    .dash-grid { grid-template-columns: 1fr 1fr; }
    .panel { grid-column: span 2; }
  }
</style>
