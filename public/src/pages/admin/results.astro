---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminClient } from '../../lib/supabase';

const db = getAdminClient();

const gradeFilter = Astro.url.searchParams.get('grade') ?? 'all';
const roundFilter = Astro.url.searchParams.get('round') ?? 'all';

let query = db.from('results').select('*').eq('season', 2026).order('round').order('grade');
if (gradeFilter !== 'all') query = query.eq('grade', gradeFilter);
if (roundFilter !== 'all') query = query.eq('round', parseInt(roundFilter));

const { data: results } = await query;

// Also get completed fixtures that don't have results yet
const { data: pendingFixtures } = await db
  .from('fixtures')
  .select('*')
  .eq('season', 2026)
  .eq('status', 'upcoming')
  .order('match_date')
  .order('grade');

const grades = ['A-Grade','B Grade','Senior Colts','Junior Colts','U11','U9'];
const rounds = Array.from({ length: 20 }, (_, i) => i + 1);

// Group results by round
const byRound: Record<number, any[]> = {};
for (const r of results ?? []) {
  if (!byRound[r.round]) byRound[r.round] = [];
  byRound[r.round].push(r);
}

// Win/loss/draw summary for Wallaroo
const wallarooTeams = ['wallaroo', 'wallaroo fc', 'wallaroo bulldogs'];
const isWallaroo = (name?: string) => wallarooTeams.includes((name ?? '').toLowerCase());

let wins = 0, losses = 0, draws = 0, byes = 0;
for (const r of results ?? []) {
  if (r.bye_team) { byes++; continue; }
  const walHome = isWallaroo(r.home_team);
  const walAway = isWallaroo(r.away_team);
  if (!walHome && !walAway) continue;
  const walScore = walHome ? r.home_score : r.away_score;
  const oppScore = walHome ? r.away_score : r.home_score;
  if (walScore > oppScore) wins++;
  else if (walScore < oppScore) losses++;
  else draws++;
}
---
<AdminLayout title="Results">
  <!-- Season summary -->
  <div class="season-summary">
    <div class="summary-item"><span class="s-num s-win">{wins}</span><span class="s-label">Wins</span></div>
    <div class="summary-item"><span class="s-num s-loss">{losses}</span><span class="s-label">Losses</span></div>
    <div class="summary-item"><span class="s-num s-draw">{draws}</span><span class="s-label">Draws</span></div>
    <div class="summary-item"><span class="s-num s-bye">{byes}</span><span class="s-label">Byes</span></div>
    <div class="summary-divider"></div>
    <div class="summary-item"><span class="s-num">{(results ?? []).length}</span><span class="s-label">Total Results</span></div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <form method="get" class="filters">
      <select name="grade" class="select" onchange="this.form.submit()">
        <option value="all">All Grades</option>
        {grades.map(g => <option value={g} selected={gradeFilter === g}>{g}</option>)}
      </select>
      <select name="round" class="select" onchange="this.form.submit()">
        <option value="all">All Rounds</option>
        {rounds.map(r => <option value={r} selected={roundFilter === String(r)}>Round {r}</option>)}
      </select>
      <button type="submit" class="btn-filter">Filter</button>
    </form>
    <div class="toolbar-right">
      <span class="count">{(results ?? []).length} results</span>
      <button class="btn-primary" id="add-result-btn">+ Enter Result</button>
    </div>
  </div>

  <!-- Pending fixtures notice -->
  {(pendingFixtures ?? []).length > 0 && (
    <div class="pending-notice">
      <strong>{(pendingFixtures ?? []).length} upcoming fixture{(pendingFixtures ?? []).length !== 1 ? 's' : ''}</strong> — click a game to enter the score after it's played
    </div>
  )}

  <!-- Results by round -->
  {Object.entries(byRound).sort((a,b) => parseInt(b[0]) - parseInt(a[0])).map(([round, roundResults]) => (
    <div class="round-section">
      <div class="round-heading">Round {round}</div>
      <div class="results-grid">
        {roundResults.map((r: any) => {
          if (r.bye_team) {
            return (
              <div class="result-card result-bye">
                <div class="result-grade">{r.grade}</div>
                <div class="bye-label">BYE — {r.bye_team}</div>
              </div>
            );
          }
          const walHome = isWallaroo(r.home_team);
          const walAway = isWallaroo(r.away_team);
          const walScore = walHome ? r.home_score : r.away_score;
          const oppScore = walHome ? r.away_score : r.home_score;
          const outcome = (!walHome && !walAway) ? null :
            walScore > oppScore ? 'win' :
            walScore < oppScore ? 'loss' : 'draw';

          return (
            <div class={`result-card result-${outcome ?? 'neutral'}`} data-result-id={r.id}>
              <div class="result-grade">{r.grade}</div>
              <div class="result-match">
                <div class="result-team">
                  <span class={walHome ? 'team-wallaroo' : 'team-opp'}>{r.home_team}</span>
                  <span class="result-score">{r.home_score ?? '—'}</span>
                </div>
                <span class="result-vs">vs</span>
                <div class="result-team result-team-right">
                  <span class="result-score">{r.away_score ?? '—'}</span>
                  <span class={walAway ? 'team-wallaroo' : 'team-opp'}>{r.away_team}</span>
                </div>
              </div>
              {outcome && (
                <div class={`outcome-badge outcome-${outcome}`}>
                  {outcome === 'win' ? '✓ WIN' : outcome === 'loss' ? '✗ LOSS' : '— DRAW'}
                  {r.margin > 0 && ` by ${r.margin}`}
                </div>
              )}
              <button class="btn-edit-result" data-result-id={r.id}
                data-home={r.home_team} data-away={r.away_team}
                data-hs={r.home_score} data-as={r.away_score}
                data-grade={r.grade} data-round={r.round}>Edit</button>
            </div>
          );
        })}
      </div>
    </div>
  ))}

  {Object.keys(byRound).length === 0 && (
    <div class="empty-state">No results yet — sync from PlayHQ or enter manually.</div>
  )}

  <!-- Enter/Edit Result Modal -->
  <dialog id="result-modal" class="modal">
    <div class="modal-inner">
      <div class="modal-header">
        <h2 id="result-modal-title">Enter Result</h2>
        <button class="modal-close" data-close="result-modal">✕</button>
      </div>
      <form id="result-form" class="modal-form">
        <input type="hidden" id="result-id" name="id" />
        <div class="form-row">
          <label class="form-group">
            Round <span class="req">*</span>
            <input type="number" name="round" min="1" max="30" required id="result-round" />
          </label>
          <label class="form-group">
            Grade <span class="req">*</span>
            <select name="grade" required id="result-grade">
              {grades.map(g => <option value={g}>{g}</option>)}
            </select>
          </label>
        </div>
        <div class="score-entry">
          <label class="form-group">
            Home Team <span class="req">*</span>
            <input type="text" name="home_team" required id="result-home" />
          </label>
          <label class="form-group score-input">
            Score
            <input type="number" name="home_score" min="0" id="result-hs" />
          </label>
          <span class="vs-divider">vs</span>
          <label class="form-group score-input">
            Score
            <input type="number" name="away_score" min="0" id="result-as" />
          </label>
          <label class="form-group">
            Away Team <span class="req">*</span>
            <input type="text" name="away_team" required id="result-away" />
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" data-close="result-modal">Cancel</button>
          <button type="submit" class="btn-primary" id="result-submit">Save Result</button>
        </div>
      </form>
    </div>
  </dialog>
</AdminLayout>

<style>
  .season-summary { display:flex; align-items:center; gap:24px; background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; padding:16px 24px; margin-bottom:24px; }
  .summary-item { text-align:center; }
  .s-num { display:block; font-size:28px; font-weight:700; line-height:1; }
  .s-win { color:#4ade80; }
  .s-loss { color:#f87171; }
  .s-draw { color:#facc15; }
  .s-bye { color:var(--admin-muted); }
  .s-label { font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--admin-muted); }
  .summary-divider { width:1px; height:40px; background:var(--admin-border); margin:0 8px; }

  .toolbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; gap:16px; flex-wrap:wrap; }
  .filters { display:flex; gap:10px; }
  .select { background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:9px 14px; font-size:14px; cursor:pointer; }
  .btn-filter { background:var(--admin-card); border:1px solid var(--admin-border); color:var(--admin-text); border-radius:6px; padding:9px 14px; font-size:14px; cursor:pointer; }
  .btn-filter:hover { border-color:#C8102E; color:#C8102E; }
  .toolbar-right { display:flex; align-items:center; gap:12px; }
  .count { font-size:14px; color:var(--admin-muted); }
  .btn-primary { background:#C8102E; color:#fff; border:none; border-radius:6px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; }
  .btn-primary:hover { background:#a50d24; }

  .pending-notice { background:rgba(139,92,246,0.12); border:1px solid rgba(139,92,246,0.3); border-radius:8px; padding:10px 16px; font-size:13px; color:#a78bfa; margin-bottom:20px; }

  .round-section { margin-bottom:28px; }
  .round-heading { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:0.06em; color:var(--admin-muted); margin-bottom:12px; border-bottom:1px solid var(--admin-border); padding-bottom:8px; }
  .results-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:12px; }

  .result-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:8px; padding:14px 16px; position:relative; }
  .result-card.result-win  { border-left:3px solid #4ade80; }
  .result-card.result-loss { border-left:3px solid #f87171; }
  .result-card.result-draw { border-left:3px solid #facc15; }
  .result-card.result-bye  { border-style:dashed; opacity:0.7; }
  .result-grade { font-size:11px; text-transform:uppercase; letter-spacing:0.1em; color:var(--admin-muted); margin-bottom:8px; }
  .bye-label { font-size:14px; color:var(--admin-muted); font-style:italic; }

  .result-match { display:flex; align-items:center; gap:8px; }
  .result-team { display:flex; align-items:center; gap:8px; flex:1; }
  .result-team-right { flex-direction:row-reverse; }
  .result-score { font-size:22px; font-weight:700; min-width:28px; text-align:center; }
  .result-vs { font-size:12px; color:var(--admin-muted); flex-shrink:0; }
  .team-wallaroo { font-size:13px; font-weight:600; }
  .team-opp { font-size:13px; color:var(--admin-muted); }

  .outcome-badge { display:inline-block; margin-top:8px; font-size:10px; font-weight:700; letter-spacing:0.08em; border-radius:3px; padding:2px 7px; }
  .outcome-win  { background:rgba(74,222,128,0.15); color:#4ade80; }
  .outcome-loss { background:rgba(248,113,113,0.15); color:#f87171; }
  .outcome-draw { background:rgba(234,179,8,0.15); color:#facc15; }

  .btn-edit-result { position:absolute; top:10px; right:10px; background:transparent; border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:4px; padding:3px 8px; font-size:11px; cursor:pointer; }
  .btn-edit-result:hover { border-color:#C8102E; color:#C8102E; }

  .empty-state { text-align:center; padding:48px; color:var(--admin-muted); }

  .modal { background:transparent; border:none; padding:0; }
  .modal::backdrop { background:rgba(0,0,0,0.6); }
  .modal-inner { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:28px; width:560px; max-width:95vw; max-height:90vh; overflow-y:auto; }
  .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
  .modal-header h2 { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:0.05em; }
  .modal-close { background:transparent; border:none; color:var(--admin-muted); font-size:18px; cursor:pointer; }

  .modal-form { display:flex; flex-direction:column; gap:16px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .form-group { display:flex; flex-direction:column; gap:5px; font-size:13px; color:var(--admin-muted); }
  .form-group input, .form-group select {
    background:#081426; border:1px solid var(--admin-border); color:var(--admin-text);
    border-radius:6px; padding:8px 12px; font-size:14px; font-family:inherit;
  }
  .form-group input:focus, .form-group select:focus { outline:none; border-color:#C8102E; }
  .req { color:#C8102E; }
  .score-entry { display:grid; grid-template-columns:1fr 80px auto 80px 1fr; gap:10px; align-items:end; }
  .score-input input { text-align:center; font-size:20px; font-weight:700; padding:8px 4px; }
  .vs-divider { text-align:center; padding-bottom:12px; color:var(--admin-muted); font-size:14px; }
  .modal-actions { display:flex; justify-content:flex-end; gap:10px; }
  .btn-ghost { background:transparent; border:1px solid var(--admin-border); color:var(--admin-muted); border-radius:6px; padding:8px 16px; font-size:14px; cursor:pointer; }
  .btn-ghost:hover { color:var(--admin-text); }
</style>

<script>
  import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  function openModal(id: string) { (document.getElementById(id) as HTMLDialogElement)?.showModal(); }
  function closeModal(id: string) { (document.getElementById(id) as HTMLDialogElement)?.close(); }

  document.querySelectorAll('[data-close]').forEach(b => b.addEventListener('click', () => closeModal((b as HTMLElement).dataset.close!)));

  document.getElementById('add-result-btn')?.addEventListener('click', () => {
    (document.getElementById('result-id') as HTMLInputElement).value = '';
    (document.getElementById('result-modal-title') as HTMLElement).textContent = 'Enter Result';
    (document.getElementById('result-form') as HTMLFormElement).reset();
    openModal('result-modal');
  });

  document.querySelectorAll('.btn-edit-result').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      (document.getElementById('result-id') as HTMLInputElement).value = el.dataset.resultId!;
      (document.getElementById('result-modal-title') as HTMLElement).textContent = 'Edit Result';
      (document.getElementById('result-home') as HTMLInputElement).value = el.dataset.home ?? '';
      (document.getElementById('result-away') as HTMLInputElement).value = el.dataset.away ?? '';
      (document.getElementById('result-hs') as HTMLInputElement).value = el.dataset.hs ?? '';
      (document.getElementById('result-as') as HTMLInputElement).value = el.dataset.as ?? '';
      (document.getElementById('result-round') as HTMLInputElement).value = el.dataset.round ?? '';
      (document.getElementById('result-grade') as HTMLSelectElement).value = el.dataset.grade ?? '';
      openModal('result-modal');
    });
  });

  document.getElementById('result-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('result-submit')!;
    btn.textContent = 'Saving…';
    const fd = new FormData(e.target as HTMLFormElement);
    const payload: any = {
      round: parseInt(fd.get('round') as string),
      grade: fd.get('grade'),
      home_team: fd.get('home_team'),
      away_team: fd.get('away_team'),
      home_score: parseInt(fd.get('home_score') as string),
      away_score: parseInt(fd.get('away_score') as string),
      season: 2026,
    };
    const id = fd.get('id') as string;
    let err;
    if (id) {
      ({ error: err } = await supabase.from('results').update(payload).eq('id', id));
    } else {
      payload.playhq_id = `manual-${Date.now()}`;
      ({ error: err } = await supabase.from('results').insert(payload));
    }
    if (err) { alert('Error: ' + err.message); btn.textContent = 'Save Result'; return; }
    window.location.reload();
  });
</script>
