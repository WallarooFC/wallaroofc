---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SocialCalendar from '../../components/SocialCalendar.astro';

const entries = (await getCollection('social'))
  .map(e => e.data)
  .sort((a, b) => a.round - b.round);
---
<PageLayout
  title="Social Calendar · Wallaroo FC"
  description="WFNC 2026 social calendar — every round, every after-match venue."
>
  <PageHero
    eyebrow="WFNC 2026 Social Calendar"
    title="Off the field,"
    titleItalic="on the town."
    intro="18 rounds of after-match social events with sponsor partners and opposition clubs across the Yorke Peninsula."
  />

  <SocialCalendar entries={entries} note="" />

  <section class="social-extras">
    <div class="container">
      <div class="card-grid">
        <article class="card">
          <h2>★ Signature events</h2>
          <ul class="signature-list">
            <li><strong>Mark Depledge Day</strong> · R3, Wallaroo Oval · 25 April</li>
            <li><strong>90's Reunion</strong> · R5, Wallaroo Oval · 9 May</li>
            <li><strong>Sponsors Day &amp; Auction</strong> · R7, Wallaroo Oval · 23 May</li>
            <li><strong>Jumpers Auction · '76 Premiership Reunion</strong> · R8, Wallaroo Oval · 30 May</li>
            <li><strong>Bulldog Ball</strong> · R12, Wallaroo · 4 July</li>
          </ul>
        </article>
        <article class="card">
          <h2>What to expect</h2>
          <p>Social rounds are hosted at sponsor pubs, alehouses, or opposition club rooms. Open to all — players, supporters, families. Most start within an hour of A-Grade's final siren.</p>
          <p>For sponsor-day events at home, the function is held in the Wallaroo Oval clubrooms straight after the game.</p>
          <p class="cta-text">RSVP isn't required for most events — just turn up. Specific bookings for the Bulldog Ball and Sponsors Day get announced 6 weeks ahead via Facebook.</p>
        </article>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .social-extras { background: var(--white); padding: 80px 32px 120px; border-top: 1px solid var(--line); }
  .container { max-width: 1200px; margin: 0 auto; }
  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .card { background: var(--cream); padding: 40px 36px; border-radius: 6px; border-left: 4px solid var(--red); }
  .card h2 { font-family: var(--display); font-size: 28px; text-transform: uppercase; color: var(--blue-deep); margin-bottom: 20px; letter-spacing: 0.02em; }
  .signature-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .signature-list li { font-family: var(--body); font-size: 15px; padding: 12px 16px; background: var(--white); border-left: 3px solid var(--red); border-radius: 4px; }
  .signature-list strong { font-family: var(--display); color: var(--blue-deep); display: block; font-size: 15px; letter-spacing: 0.02em; text-transform: uppercase; }
  .card p { font-family: var(--serif); font-size: 17px; line-height: 1.6; color: var(--charcoal); margin-bottom: 16px; }
  .cta-text { font-family: var(--serif); font-style: italic; color: var(--grey); font-size: 16px !important; }
  @media (max-width: 800px) { .card-grid { grid-template-columns: 1fr; } .social-extras { padding: 48px 24px; } }
</style>
