---
export const prerender = false;
import { getCollection, render } from 'astro:content';
import { supabase } from '../../lib/supabase';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/news/');

// Try Supabase first
const { data: dbArticle } = await supabase
  .from('news')
  .select('*')
  .eq('slug', slug)
  .eq('published', true)
  .maybeSingle();

// If not in Supabase, try YAML content collection
let yamlContent: string | null = null;
let title = '';
let category = '';
let dateLabel = '';
let summary: string | undefined;
let bodyHtml = '';
let imageUrl: string | null = null;

if (dbArticle) {
  title    = dbArticle.title;
  category = dbArticle.category ?? 'Club News';
  dateLabel = new Date(dbArticle.published_at ?? dbArticle.created_at)
    .toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
  imageUrl = dbArticle.image_url ?? null;

  // Simple Markdown → HTML
  const md = dbArticle.body_md ?? '';
  bodyHtml = md
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2">$1</a>')
    .split(/\n{2,}/)
    .map(p => p.trim())
    .filter(Boolean)
    .map(p => p.startsWith('<h') ? p : `<p>${p.replace(/\n/g, '<br/>')}</p>`)
    .join('\n');
} else {
  // YAML fallback
  const articles = await getCollection('news');
  const article  = articles.find(a => a.id === slug);
  if (!article) return Astro.redirect('/news/');

  title    = article.data.title;
  category = article.data.category ?? 'Club News';
  summary  = article.data.summary;
  dateLabel = article.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });

  const { Content } = await render(article);
  // Store the component for rendering — we'll handle it in the template
  yamlContent = null; // signal to use <Content /> below
  // We need to handle YAML articles differently — store the render result
  // Use a workaround: render to string-like via a flag
  (Astro as any).__yamlContent = Content;
}

const useYaml = !dbArticle;
const YamlContent = useYaml ? (Astro as any).__yamlContent : null;
---
<PageLayout
  title={`${title} · Wallaroo FC`}
  description={summary ?? bodyHtml.replace(/<[^>]+>/g, '').substring(0, 160)}
>
  <PageHero
    eyebrow={`${category} · ${dateLabel}`}
    title={title}
    intro={useYaml ? summary : undefined}
    showCrest={false}
  />

  <article class="news-article">
    <div class="news-inner">
      {imageUrl && <img src={imageUrl} alt={title} class="featured-img" />}

      {useYaml && YamlContent && <YamlContent />}
      {!useYaml && <Fragment set:html={bodyHtml} />}

      <p class="back-link"><a href="/news/">← All news</a></p>
    </div>
  </article>
</PageLayout>

<style>
  .news-article { background: var(--cream); padding: 80px 32px 120px; }
  .news-inner {
    max-width: 760px; margin: 0 auto;
    font-family: var(--serif); font-size: 19px; line-height: 1.7; color: var(--charcoal);
  }
  .featured-img { width: 100%; border-radius: 6px; margin-bottom: 40px; object-fit: cover; max-height: 400px; }
  .news-inner :global(h2) { font-family: var(--display); font-size: 32px; color: var(--blue-deep); text-transform: uppercase; margin: 48px 0 16px; }
  .news-inner :global(h3) { font-family: var(--display); font-size: 24px; color: var(--blue-deep); text-transform: uppercase; margin: 32px 0 12px; }
  .news-inner :global(p) { margin-bottom: 18px; }
  .news-inner :global(strong) { color: var(--blue-deep); font-weight: 600; }
  .news-inner :global(ul), .news-inner :global(ol) { margin: 16px 0 24px 24px; }
  .news-inner :global(li) { margin-bottom: 6px; }
  .news-inner :global(blockquote) { border-left: 4px solid var(--red); padding-left: 20px; font-style: italic; color: var(--grey); margin: 24px 0; }
  .news-inner :global(a) { color: var(--red); text-decoration: underline; }
  .back-link { margin-top: 64px; font-family: var(--headline); font-size: 14px; text-transform: uppercase; letter-spacing: 0.14em; }
  .back-link a { color: var(--blue-deep); border-bottom: 2px solid var(--red); padding-bottom: 2px; text-decoration: none; }
  @media (max-width: 700px) { .news-article { padding: 48px 24px 80px; } }
</style>
