---
export const prerender = false;
import { getCollection } from 'astro:content';
import { supabase } from '../../lib/supabase';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';

const { data: dbSponsors } = await supabase
  .from('sponsors')
  .select('*')
  .eq('active', true)
  .order('display_order')
  .order('name');

let sponsors: any[] = [];
if ((dbSponsors ?? []).length > 0) {
  sponsors = (dbSponsors ?? []).map(s => ({
    name:  s.name,
    tier:  s.tier,
    order: s.display_order,
    url:   s.website,
  }));
} else {
  sponsors = (await getCollection('sponsors')).map(e => e.data);
}

// Clean logo files — simple marks/wordmarks, no overlay text
const logoMap: Record<string, string> = {
  // Pre-existing clean logos
  'T-Ports':                          '/sponsors/tports.png',
  'Leanic Civil':                     '/sponsors/leanic.png',
  'Murray Pest Control':              '/sponsors/murray-pest.png',
  'Subway':                           '/sponsors/subway.png',
  'Spencer Gulf Searoad':             '/sponsors/spencer-gulf-searoad.png',
  'Wallaroo Alehouse':                '/sponsors/coopers-alehouse.png',
  'WFI':                              '/sponsors/wfi.png',
  'Gunnings':                         '/sponsors/gunnings.png',
  'Bond Store Wallaroo':              '/sponsors/bond-store.png',
  'McDonalds':                        '/sponsors/mcdonalds.png',
  'Kadina McDonalds':                 '/sponsors/mcdonalds.png',
  'Forty Winks':                      '/sponsors/forty-winks.png',
  'Real Estate On Yorke':             '/sponsors/real-estate-on-yorke.jpg',
  'SportsPower Kadina':               '/sponsors/sportspower.png',
  'Wallaroo Hotel':                   '/sponsors/wallaroo-hotel.png',
  'Wallaroo Beachfront Tourist Park': '/sponsors/wallaroo-tourist-park.png',
  'Wardle Co':                        '/sponsors/wardle-co.png',
  'YP Energy Solutions':              '/sponsors/yp-energy.png',
  // Sourced from business websites
  'Anglers Inn':                      '/sponsors/anglers-inn.png',
  'AW Vater & Co':                    '/sponsors/aw-vater.png',
  'Enfield Furnishers':               '/sponsors/enfield-furnishers.jpg',
  'Hello World Kadina':               '/sponsors/hello-world.svg',
  'Jeff White Mechanical':            '/sponsors/jeff-white-mechanical.png',
  'Kadina Mitre 10':                  '/sponsors/kadina-mitre10.svg',
  'KP Lawyers':                       '/sponsors/kp-lawyers.jpg',
  'Larwood Ag Services':              '/sponsors/larwood-ag.png',
  'Newbery Chemists':                 '/sponsors/newbery-chemists.png',
  'Poona Crushing and Gravel':        '/sponsors/poona-crushing.jpg',
  'Shippy Hardware':                  '/sponsors/shippy-hardware.png',
