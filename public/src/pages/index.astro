  'Bond Store Wallaroo':              '/sponsors/bond-store.png',
  'McDonalds':                        '/sponsors/mcdonalds.png',
  'Kadina McDonalds':                 '/sponsors/mcdonalds.png',
};

let sponsorEntries: any[] = [];
if ((dbSponsors ?? []).length > 0) {
  sponsorEntries = (dbSponsors ?? []).map(s => ({
    name:  s.name,
    tier:  s.tier,
    order: s.display_order,
    logo:  s.logo_url ?? sponsorLogoMap[s.name],
  }));
} else {
  const yaml = (await getCollection('sponsors')).map(e => e.data);
  sponsorEntries = yaml.map((s: any) => ({ ...s, logo: sponsorLogoMap[s.name] }));
}

const sortInTier = (a: any, b: any) => (a.order ?? 999) - (b.order ?? 999) || a.name.localeCompare(b.name);
const tierOrder = ['platinum', 'vip', 'gold', 'silver', 'bronze'];

