---
export const prerender = false;

import { getCollection, getEntry } from 'astro:content';
import { supabase } from '../lib/supabase';
import { nameToSlug } from '../lib/clubs';

import Layout from '../layouts/Layout.astro';
import TopStrip from '../components/TopStrip.astro';
import Masthead from '../components/Masthead.astro';
import Hero from '../components/Hero.astro';
import YPFLStrip from '../components/YPFLStrip.astro';
import ResultsTicker from '../components/ResultsTicker.astro';
import ThisWeek from '../components/ThisWeek.astro';
import GameDayInfo from '../components/GameDayInfo.astro';
import CanteenStrip from '../components/CanteenStrip.astro';
import FullFixture from '../components/FullFixture.astro';
import SocialCalendar from '../components/SocialCalendar.astro';
import JoinStrip from '../components/JoinStrip.astro';
import JuniorPathway from '../components/JuniorPathway.astro';
import Volunteers from '../components/Volunteers.astro';
import Heritage from '../components/Heritage.astro';
import PremiershipWall from '../components/PremiershipWall.astro';
import Events from '../components/Events.astro';
import Gallery from '../components/Gallery.astro';
import Sponsors from '../components/Sponsors.astro';
import Footer from '../components/Footer.astro';

// Prevent Vercel edge caching — always serve fresh data
Astro.response.headers.set('Cache-Control', 'no-store, max-age=0');

// ─────────────────────────────────────────────────────────────
// 1. Site config from Supabase (with YAML fallback)
// ─────────────────────────────────────────────────────────────
const { data: configRows } = await supabase.from('site_config').select('key,value');
const cfg: Record<string, string> = {};
for (const r of configRows ?? []) cfg[r.key] = r.value ?? '';

// Fall back to YAML if Supabase site_config is empty
let site: Record<string, any> = {};
if (Object.keys(cfg).length === 0) {
  const siteEntry = await getEntry('site', 'config');
  site = siteEntry?.data?.config ?? {};
} else {
  const currentRound = parseInt(cfg.current_round ?? '1');
  site = {
    season:                   parseInt(cfg.season ?? '2026'),
    currentRound,
    lastCompletedRound:       parseInt(cfg.last_completed_round ?? String(currentRound - 1)),
    currentDate:              cfg.current_date ?? '',
    nextMatchDate:            cfg.next_match_date ?? '',
    nextMatchBounce:          cfg.next_match_bounce ?? '',
    nextMatchVenue:           cfg.next_match_venue ?? '',
    nextMatchHomeOrAway:      cfg.next_match_home_or_away ?? 'HOME',
    nextMatchOpponent:        cfg.next_match_opponent ?? '',
    nextMatchOpponentName:    cfg.next_match_opponent_name ?? '',
    nextMatchOpponentRecord:  cfg.next_match_opponent_record ?? '',
    ourRecord:                cfg.our_record ?? '',
    thisWeekVenue:            cfg.this_week_venue ?? '',
    thisWeekVenueLabel:       cfg.this_week_venue_label ?? '',
  };
}

// ─────────────────────────────────────────────────────────────
// 2. Fixtures — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
const [{ data: dbFixtures }, { data: dbResults }] = await Promise.all([
  supabase.from('fixtures').select('*').eq('season', site.season ?? 2026).order('round').order('grade'),
  supabase.from('results').select('round,home_team,home_score,away_team,away_score').eq('season', site.season ?? 2026).eq('grade', 'A-Grade').or('home_team.ilike.%wallaroo%,away_team.ilike.%wallaroo%'),
]);

// Grade bounce time defaults
const GRADE_TIMES: Record<string, { time: string; ampm: 'AM' | 'PM' }> = {
  'A-Grade':      { time: '2:40',  ampm: 'PM' },
  'B Grade':      { time: '12:55', ampm: 'PM' },
  'Senior Colts': { time: '11:20', ampm: 'AM' },
  'Junior Colts': { time: '10:00', ampm: 'AM' },
  'U11':          { time: '9:00',  ampm: 'AM' },
  'U9':           { time: '9:00',  ampm: 'AM' },
};

// Build round → Wallaroo score map
const scoreByRound = new Map<number, { wallarooScore: number; oppScore: number; wallarooWon: boolean }>();
for (const r of dbResults ?? []) {
  const wallarooIsHome = r.home_team?.toLowerCase().includes('wallaroo');
  const wallarooIsAway = r.away_team?.toLowerCase().includes('wallaroo');
  if (!wallarooIsHome && !wallarooIsAway) continue;
  const wScore = wallarooIsHome ? r.home_score : r.away_score;
  const oScore = wallarooIsHome ? r.away_score : r.home_score;
  if (wScore !== null && oScore !== null) {
    scoreByRound.set(r.round, { wallarooScore: wScore, oppScore: oScore, wallarooWon: wScore > oScore });
  }
}

// Map Supabase fixtures → FullFixture FixtureCard shape
let fixtures: any[] = [];
let weekFixtures: any[] = [];

if ((dbFixtures ?? []).length > 0) {
  fixtures = (dbFixtures ?? [])
    .filter(f => f.opponent && f.grade === 'A-Grade') // A-Grade only for full fixture display
    .map(f => {
      const matchDate = f.match_date
        ? new Date(f.match_date + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short' })
        : '';
      const score = f.status === 'completed' ? scoreByRound.get(f.round) : undefined;
      return {
        round:         f.round,
        date:          matchDate,
        type:          f.status === 'bye' ? 'bye' : 'match',
        oppSlug:       nameToSlug(f.opponent),
        oppName:       f.opponent,
        venue:         f.is_home ? 'HOME' : 'AWAY',
        venueDetail:   f.is_home ? 'Wallaroo Oval' : f.venue,
        status:        f.status === 'completed' ? 'past' : f.status === 'upcoming' ? 'upcoming' : undefined,
        wallarooScore: score?.wallarooScore,
        oppScore:      score?.oppScore,
        wallarooWon:   score?.wallarooWon,
      };
    });

  // This week's fixtures (current round, Wallaroo games only)
  const currentRound = parseInt(String(site.currentRound));
  weekFixtures = (dbFixtures ?? [])
    .filter(f => f.round === currentRound && f.status !== 'bye' && f.opponent)
    .map(f => {
      const gt = GRADE_TIMES[f.grade] ?? { time: '—', ampm: 'AM' };
      const [timePart, ampmRaw] = (f.match_time ?? '').split(':').length > 1
        ? (() => {
            const [h, m] = (f.match_time ?? '').split(':');
            const hr = parseInt(h);
            return [
              `${hr > 12 ? hr - 12 : hr}:${m}`,
              hr >= 12 ? 'PM' : 'AM',
            ];
          })()
        : [gt.time, gt.ampm];
      // Convert time to minutes-since-midnight for sorting
      const [th, tm] = timePart.split(':').map(Number);
      const totalMins = (ampmRaw === 'PM' && th !== 12 ? th + 12 : th) * 60 + (tm || 0);
      return {
        grade:       f.grade,
        homeSlug:    nameToSlug(f.home_team) ?? 'wallaroo',
        homeName:    f.home_team ?? '',
        awaySlug:    nameToSlug(f.away_team) ?? 'wallaroo',
        awayName:    f.away_team ?? '',
        time:        timePart,
        ampm:        ampmRaw,
        venueLabel:  f.is_home ? 'Home' : 'Away',
        isHomeVenue: !!f.is_home,
        _sortMins:   totalMins,
      };
    })
    .sort((a, b) => a._sortMins - b._sortMins);
} else {
  // YAML fallback
  const yamlFixtures = (await getCollection('fixtures')).map(e => e.data).sort((a, b) => a.round - b.round);
  fixtures = yamlFixtures;
  weekFixtures = (await getCollection('thisWeekFixtures')).map(e => e.data);
}

// ─────────────────────────────────────────────────────────────
// 3. Finals — always from YAML (manually curated)
// ─────────────────────────────────────────────────────────────
const MONTH_ORDER: Record<string, number> = { Jan:1, Feb:2, Mar:3, Apr:4, May:5, Jun:6, Jul:7, Aug:8, Sep:9, Oct:10, Nov:11, Dec:12 };
function finalDateSort(d: string) {
  const parts = d.replace(/^(Sat|Sun|Mon|Tue|Wed|Thu|Fri)\s+/, '').split(' ');
  return (MONTH_ORDER[parts[1]] ?? 0) * 100 + parseInt(parts[0]);
}
const finals = (await getCollection('finals')).map(e => e.data).sort((a: any, b: any) => finalDateSort(a.date) - finalDateSort(b.date));

// ─────────────────────────────────────────────────────────────
// 4. Results ticker — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
let tickerResults: any[] = [];

// Find the latest round that has actual game results (not just future-round byes)
const { data: latestGameRow } = await supabase
  .from('results')
  .select('round')
  .eq('season', site.season ?? 2026)
  .is('bye_team', null)           // actual games only — bye rows have bye_team set
  .order('round', { ascending: false })
  .limit(1)
  .single();

if (latestGameRow) {
  const { data: dbResults } = await supabase
    .from('results')
    .select('*')
    .eq('season', site.season ?? 2026)
    .eq('round', latestGameRow.round)
    .order('grade');

  tickerResults = (dbResults ?? []).map(r => {
    if (r.bye_team) return { grade: r.grade, round: r.round, byeTeam: r.bye_team };
    const hs = r.home_score ?? 0;
    const as_ = r.away_score ?? 0;
    const margin = Math.abs(hs - as_);
    const homeWon = hs > as_;
    const drawn   = hs === as_;
    return {
      grade:      r.grade,
      round:      r.round,
      homeName:   homeWon || drawn ? r.home_team : r.away_team,
      homeScore:  String(homeWon || drawn ? hs : as_),
      awayName:   homeWon || drawn ? r.away_team : r.home_team,
      awayScore:  String(homeWon || drawn ? as_ : hs),
      margin:     drawn ? undefined : `${margin} PTS`,
      drawn,
      byeTeam:    r.bye_team,
    };
  });
} else {
  const allResults = (await getCollection('results')).map(e => e.data).sort((a, b) => b.round - a.round);
  const latestResults = allResults[0];
  if (latestResults) {
    tickerResults = latestResults.games.map((g: any) => ({
      grade: g.grade, round: latestResults.round,
      homeName: g.homeName, homeScore: g.homeScore,
      awayName: g.awayName, awayScore: g.awayScore,
      margin: g.margin, byeTeam: g.byeTeam,
    }));
  }
}

// ─────────────────────────────────────────────────────────────
// 4b. Recent form — Wallaroo A-Grade last 6 completed results
// ─────────────────────────────────────────────────────────────
let recentForm: any[] = [];
if (latestGameRow) {
  // Fetch Wallaroo A-Grade results (excluding byes)
  const { data: formResults } = await supabase
    .from('results')
    .select('*')
    .eq('season', site.season ?? 2026)
    .eq('grade', 'A-Grade')
    .is('bye_team', null)
    .or('home_team.eq.Wallaroo,away_team.eq.Wallaroo')
    .order('round', { ascending: false })
    .limit(6);

  recentForm = (formResults ?? []).map(r => {
    const isHome    = r.home_team === 'Wallaroo';
    const opponent  = isHome ? r.away_team : r.home_team;
    const ourScore  = isHome ? r.home_score : r.away_score;
    const theirScore = isHome ? r.away_score : r.home_score;
    const won       = ourScore > theirScore;
    const drawn     = ourScore === theirScore;
    return {
      round:      r.round,
      opponent,
      ourScore,
      theirScore,
      result:     drawn ? 'D' : won ? 'W' : 'L',
      isHome,
      margin:     Math.abs(ourScore - theirScore),
    };
  });
}

// ─────────────────────────────────────────────────────────────
// 5. Ladders — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
let ladders: any[] = [];
const { data: dbLadders } = await supabase
  .from('ladders')
  .select('*')
  .eq('season', site.season ?? 2026)
  .order('display_order');

if ((dbLadders ?? []).length > 0) {
  ladders = (dbLadders ?? []).map(l => ({
    grade:   l.tab_label ?? l.grade,
    key:     l.grade.toLowerCase().replace(/\s+/g, '-'),
    columns: l.columns,
    rows:    l.rows,
  }));
} else {
  const yamlLadders = (await getCollection('ladders')).map(e => e.data).sort((a: any, b: any) => a.order - b.order);
  ladders = yamlLadders.map((l: any) => ({
    grade:   l.tabLabel ?? l.grade,
    key:     l.grade.toLowerCase().replace(/\s+/g, '-'),
    columns: l.columns,
    rows:    l.rows,
  }));
}

// ─────────────────────────────────────────────────────────────
// 6. News — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
let news: any[] = [];
const { data: dbNews } = await supabase
  .from('news')
  .select('*')
  .eq('published', true)
  .order('pinned', { ascending: false })
  .order('published_at', { ascending: false })
  .limit(3);

if ((dbNews ?? []).length > 0) {
  news = (dbNews ?? []).map(n => ({
    meta:  `${n.category} · ${new Date(n.published_at ?? n.created_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }).toUpperCase()}`,
    title: n.title,
    href:  n.href ?? `/news/${n.slug}/`,
  }));
} else {
  const yamlNews = (await getCollection('news'))
    .map(e => ({ ...e.data, slug: e.id }))
    .sort((a: any, b: any) => {
      if (a.pinned !== b.pinned) return (b.pinned ? 1 : 0) - (a.pinned ? 1 : 0);
      return b.date.getTime() - a.date.getTime();
    }).slice(0, 3);
  news = yamlNews.map((n: any) => ({
    meta:  `${n.category} · ${n.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }).toUpperCase()}`,
    title: n.title,
    href:  n.href ?? `/news/${n.slug}/`,
  }));
}

// ─────────────────────────────────────────────────────────────
// 7. Sponsors — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
const { data: dbSponsors } = await supabase
  .from('sponsors')
  .select('*')
  .eq('active', true)
  .order('display_order')
  .order('name');

// Sponsor logo map — only proper logo files (simple marks on white/transparent backgrounds).
const sponsorLogoMap: Record<string, string> = {
