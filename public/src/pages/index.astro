  { name: 'Yorke Peninsula Country Times',         logo: `${BASE}/Bronze/Yorke_Peninsula_Country_Times.png` },
  // ── Club ───────────────────────────────────────────────────
  { name: 'A1 Auto Car Sales',                     logo: `${BASE}/Club/A1_Auto_Car_Sales.png` },
  { name: 'AW Vater & Co',                         logo: `${BASE}/Club/AW_Vater_&_Co.png` },
  { name: "Butch's Auto Detailing",                logo: `${BASE}/Club/Butchs_Auto_Detailing.png` },
  { name: 'Eagle Surf',                            logo: `${BASE}/Club/Eagle_Surf.png` },
  { name: 'G & J East',                            logo: `${BASE}/Club/G_&_J_East.png` },
  { name: 'Geoff James Paving & Landscaping',      logo: `${BASE}/Club/Geoff_James_Paving_&_Landscaping.png` },
  { name: 'Kadina Mitre 10',                       logo: `${BASE}/Club/Kadina_Mitre_10.png` },
  { name: "Murphy's Crash & Towing",               logo: `${BASE}/Club/Murphys_Crash_&_Towing.png` },
  { name: 'NYP Car Fix Service',                   logo: `${BASE}/Club/NYP_Car_Fix_Service.png` },
  { name: 'Newbery Chemists Tim Gross & Partners', logo: `${BASE}/Club/Newbery_Chemists_Tim_Gross_&_Partners.png` },
  { name: "Perry's",                               logo: `${BASE}/Club/Perrys.png` },
  { name: 'Skinner Family Funerals',               logo: `${BASE}/Club/Skinner_Family_Funerals.png` },
  { name: "The Mac's Beachfront Villas",           logo: `${BASE}/Club/The_Macs_Beachfront_Villas.png` },
  { name: "Yorke's Meat & Smallgoods",             logo: `${BASE}/Club/Yorkes_Meat_&_Smallgoods.png` },
];

const platinumSponsors = sponsorEntries.filter(s => s.tier === 'platinum').sort(sortInTier);
const vipGoldSponsors  = sponsorEntries.filter(s => s.tier === 'vip' || s.tier === 'gold').sort(sortInTier);
const sponsorsForHomepage = [
  { label: 'Platinum Sponsors',    platinum: true,  logos: platinumSponsors.map(s => s.name) },
  { label: 'VIP & Gold Partners',  platinum: false, logos: vipGoldSponsors.map(s => s.name) },
].filter(t => t.logos.length > 0);

// ─────────────────────────────────────────────────────────────
// 8. Social calendar — Supabase with YAML fallback
// ─────────────────────────────────────────────────────────────
let social: any[] = [];
const { data: dbSocial } = await supabase
  .from('social_events')
  .select('*')
  .order('event_date');

if ((dbSocial ?? []).length > 0) {
  social = (dbSocial ?? []).map(e => ({
    round:       e.round,
    date:        e.event_date,
    timeRange:   e.time_range,
    title:       e.title,
    description: e.description,
    location:    e.location,
    icon:        e.icon,
  }));
} else {
  social = (await getCollection('social')).map(e => e.data).sort((a: any, b: any) => a.round - b.round);
}

// ─────────────────────────────────────────────────────────────
// 9. Events section
// ─────────────────────────────────────────────────────────────
const hostHere = finals.find((f: any) => f.hostHere);
const featuredEvent = {
  tag: 'Wallaroo Oval Hosts',
  titleLine1: hostHere ? hostHere.name.replace(/Final$/, '').trim() : 'Second Semi',
  titleLine2Italic: 'Final.',
  body: "Wallaroo Oval has been awarded hosting rights for the YPFL Second Semi Final. The biggest crowd of the season — finals footy on home turf, regardless of who's playing.",
  meta: hostHere ? [
    { label: 'YPFL Finals',     value: hostHere.date },
    { label: 'Cornish Terrace', value: hostHere.venue },
    { label: '11:00 AM',        value: 'Gates open' },
  ] : [],
};

const upcomingFixtureItems = fixtures
  .filter((f: any) => f.status === 'now' || f.status === 'upcoming' || (!f.status && f.type === 'match'))
  .slice(0, 2)
  .map((f: any) => {
    const dateStr = f.date ?? '';
    const [, day, mon] = dateStr.match(/(\d+)\s+(\w+)/) ?? [, '', ''];
    const isHome = f.venue === 'HOME' || f.is_home;
    return {
      day, mon,
      title: `Round ${f.round} · ${isHome ? 'Home Game' : 'Away'}`,
      desc: isHome
        ? `Wallaroo v ${f.oppName} · Wallaroo Oval`
        : `${f.oppName} v Wallaroo · ${f.venueDetail ?? f.oppName + ' Oval'} · ${site.nextMatchBounce?.toLowerCase()}`,
      href: `/fixtures/#r${f.round}`,
    };
  });

const upcomingEvents = [
  ...upcomingFixtureItems,
  ...(hostHere ? [{
    day: String(hostHere.date).match(/(\d+)/)?.[1] ?? '',
    mon: String(hostHere.date).match(/\b(\w{3})\b$/)?.[1] ?? '',
    title: `★ ${hostHere.name}`,
    desc: 'YPFL Finals · Wallaroo Oval hosts',
    href: '/fixtures/#finals',
  }] : []),
];

// ─────────────────────────────────────────────────────────────
// 10. Schema.org
// ─────────────────────────────────────────────────────────────
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SportsTeam',
      '@id': 'https://wallaroofc.com.au/#team',
      name: 'Wallaroo Football Club',
      alternateName: ['Wallaroo Bulldogs', 'Wallaroo FC'],
      sport: 'Australian rules football',
      foundingDate: '1867-06-17',
      memberOf: { '@type': 'SportsOrganization', name: 'Yorke Peninsula Football League' },
      url: 'https://wallaroofc.com.au/',
      email: 'admin@wallaroofc.com.au',
      location: {
        '@type': 'Place',
        name: 'Wallaroo Oval',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Cornish Terrace',
          addressLocality: 'Wallaroo',
          addressRegion: 'SA',
          postalCode: '5556',
          addressCountry: 'AU',
        },
      },
    },
    {
      '@type': 'LocalBusiness',
      '@id': 'https://wallaroofc.com.au/#venue',
      name: 'Wallaroo Football Club — Wallaroo Oval',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Cornish Terrace',
        addressLocality: 'Wallaroo',
        addressRegion: 'SA',
        postalCode: '5556',
        addressCountry: 'AU',
      },
      email: 'admin@wallaroofc.com.au',
      url: 'https://wallaroofc.com.au/',
    },
  ],
};
---
<Layout
  title={`Wallaroo Football Club — Home of the Bulldogs · Round ${site.currentRound} vs ${site.nextMatchOpponentName}`}
  description={`Founded 17 June 1867. Yorke Peninsula Football League. Round ${site.currentRound} — ${site.nextMatchDate} at ${site.nextMatchVenue}, ${site.nextMatchBounce} bounce.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <TopStrip round={site.currentRound} date={site.nextMatchDate} season={site.season} />
  <Masthead />

  <main id="main">
  <Hero
    round={site.currentRound}
    homeOrAway={site.nextMatchHomeOrAway}
    homeTeam={{ name: 'Wallaroo', record: site.ourRecord }}
    awayTeam={{ slug: site.nextMatchOpponent, name: site.nextMatchOpponentName, record: site.nextMatchOpponentRecord }}
    date={site.nextMatchDate}
    bounce={site.nextMatchBounce}
    venue={site.nextMatchVenue}
    ribbonItems={ribbonItems}
  />

  <YPFLStrip />

  <ResultsTicker results={tickerResults} />

  <ThisWeek
    round={site.currentRound}
    afterRound={site.lastCompletedRound}
    date={`Saturday ${String(site.currentDate).replace(/^Sat\s+/, '')}`}
    venue={site.thisWeekVenue}
    venueLabel={site.thisWeekVenueLabel}
    fixtures={weekFixtures}
    ladders={ladders}
    news={news}
    recentForm={recentForm}
  />

  <GameDayInfo />

  <CanteenStrip />

  <FullFixture fixtures={fixtures} finals={finals} />

  <SocialCalendar entries={social} />

  <JoinStrip />

  <JuniorPathway />

  <Volunteers />

  <Heritage />

  <PremiershipWall />

  <Events featured={featuredEvent} events={upcomingEvents} />

  <Gallery />

  <Sponsors tiers={sponsorsForHomepage} />
  </main>

  <Footer />
</Layout>
