---
/**
 * PageLayout — the shell every non-homepage page uses.
 * Wraps the bare Layout (head/scripts) with TopStrip + Masthead + Footer,
 * pulling the round-number from the singleton site collection so the live
 * round pill stays in sync everywhere.
 */
import { getEntry } from 'astro:content';

import Layout from './Layout.astro';
import TopStrip from '../components/TopStrip.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;

const siteEntry = await getEntry('site', 'config');
const site = siteEntry?.data ?? { season: 2026, currentRound: 1, currentDate: '' };
---
<Layout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <TopStrip round={site.currentRound} date={site.currentDate} season={site.season} />
  <Masthead />
  <main id="main">
    <slot />
  </main>
  <Footer />
</Layout>
