---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Wallaroo Football Club — Home of the Bulldogs',
  description = "Founded 1867. One of Australia's oldest continuously running football clubs. YPFL · SANFL Affiliate. Wallaroo Oval, Cornish Terrace, SA.",
  canonical,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://wallaroofc.com').toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Wallaroo Football Club" />
  <meta property="og:locale" content="en_AU" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts — non-blocking load: print media + onload swap. font-display:swap in URL gives FOUT not FOIT. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&family=Oswald:wght@400;600&family=Fraunces:ital,wght@0,600;1,400&family=Inter:wght@400;600&display=swap"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&family=Oswald:wght@400;600&family=Fraunces:ital,wght@0,600;1,400&family=Inter:wght@400;600&display=swap" />
  </noscript>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body>
  <slot />

  <script>
    // Masthead shadow on scroll
    const masthead = document.getElementById('masthead');
    if (masthead) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 12) masthead.classList.add('scrolled');
        else masthead.classList.remove('scrolled');
      }, { passive: true });
    }

    // Reveal-on-scroll observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Ladder tabs
    document.querySelectorAll<HTMLButtonElement>('.ladder-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const grade = tab.dataset.grade;
        if (!grade) return;
        const card = tab.closest('.ladder-card');
        if (!card) return;
        card.querySelectorAll('.ladder-tab').forEach(t => t.classList.remove('active'));
        card.querySelectorAll('.ladder-panel').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        card.querySelector(`.ladder-panel[data-panel="${grade}"]`)?.classList.add('active');
      });
    });
  </script>

  <!-- Landing takeover popup — fetches the active announcement and shows it as
       a centred modal for ~10s on every visit. Managed from /admin/takeovers. -->
  <script is:inline>
    (function () {
      "use strict";
      var API_URL = "/api/takeover/current";
      var HOLD_MS = 10000;
      var ANIM_MS = 500;
      var ROOT_ID = "wfc-takeover-root";
      var STYLE_ID = "wfc-takeover-styles";

      function injectStylesOnce() {
        if (document.getElementById(STYLE_ID)) return;
        var css =
          "#" + ROOT_ID + "{position:fixed;inset:0;z-index:2147483000;display:flex;align-items:center;justify-content:center;pointer-events:none;font-family:Inter,system-ui,-apple-system,'Segoe UI',sans-serif;}" +
          "#" + ROOT_ID + " .wfc-backdrop{position:absolute;inset:0;background:rgba(5,14,31,0.66);opacity:0;transition:opacity " + ANIM_MS + "ms ease-out;pointer-events:auto;}" +
          "#" + ROOT_ID + ".wfc-in .wfc-backdrop{opacity:1;}" +
          "#" + ROOT_ID + " .wfc-card{position:relative;max-width:520px;width:calc(100% - 32px);background:#fff;border-radius:12px;box-shadow:0 24px 64px rgba(5,14,31,0.5);overflow:hidden;transform:translateY(-40px) scale(0.96);opacity:0;transition:transform " + ANIM_MS + "ms cubic-bezier(0.16,1,0.3,1),opacity " + ANIM_MS + "ms ease-out;pointer-events:auto;}" +
          "#" + ROOT_ID + ".wfc-in .wfc-card{transform:translateY(0) scale(1);opacity:1;}" +
          "#" + ROOT_ID + " .wfc-card-image{max-width:460px;background:transparent;box-shadow:none;overflow:visible;}" +
          "#" + ROOT_ID + " .wfc-img{display:block;width:100%;height:auto;max-height:86vh;object-fit:contain;border-radius:12px;box-shadow:0 24px 64px rgba(5,14,31,0.5);}" +
          "#" + ROOT_ID + " .wfc-strip{height:4px;background:#C8102E;}" +
          "#" + ROOT_ID + " .wfc-close{position:absolute;top:10px;right:10px;width:32px;height:32px;border:none;background:transparent;color:#595D63;font-size:22px;line-height:1;cursor:pointer;}" +
          "#" + ROOT_ID + " .wfc-close:hover{color:#0A1F3D;}" +
          "#" + ROOT_ID + " .wfc-card-image .wfc-close{background:rgba(5,14,31,0.6);color:#fff;border-radius:9999px;z-index:1;}" +
          "#" + ROOT_ID + " .wfc-card-image .wfc-close:hover{background:rgba(5,14,31,0.85);color:#fff;}" +
          "#" + ROOT_ID + " .wfc-body{padding:32px 32px 28px;text-align:center;color:#15171C;}" +
          "#" + ROOT_ID + " .wfc-heading{font-family:'Anton',Impact,sans-serif;font-size:28px;letter-spacing:0.02em;text-transform:uppercase;color:#0A1F3D;margin:0 0 12px;line-height:1.1;}" +
          "#" + ROOT_ID + " .wfc-text{font-size:15px;line-height:1.55;margin:0 auto;max-width:42ch;}" +
          "#" + ROOT_ID + " .wfc-cta{display:inline-block;margin-top:22px;background:#C8102E;color:#fff;text-decoration:none;padding:12px 24px;border-radius:8px;font-weight:600;font-size:14px;letter-spacing:0.02em;}" +
          "#" + ROOT_ID + " .wfc-cta:hover{background:#8E0B20;}";
        var s = document.createElement("style");
        s.id = STYLE_ID;
        s.textContent = css;
        document.head.appendChild(s);
      }

      function esc(str) {
        return String(str == null ? "" : str)
          .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
      }

      function render(body) {
        if (!body) return;
        injectStylesOnce();
        var prior = document.getElementById(ROOT_ID);
        if (prior) prior.remove();

        var root = document.createElement("div");
        root.id = ROOT_ID;
        root.setAttribute("role", "dialog");
        root.setAttribute("aria-modal", "true");
        root.setAttribute("aria-label", "Wallaroo FC announcement");

        if (body.imageUrl) {
          var img = '<img class="wfc-img" src="' + esc(body.imageUrl) + '" alt="' + esc(body.heading || "Wallaroo FC") + '"/>';
          var inner = body.ctaUrl
            ? '<a href="' + esc(body.ctaUrl) + '" rel="noopener">' + img + '</a>'
            : img;
          root.innerHTML =
            '<div class="wfc-backdrop"></div>' +
            '<div class="wfc-card wfc-card-image">' +
              '<button type="button" class="wfc-close" aria-label="Dismiss">&times;</button>' +
              inner +
            '</div>';
        } else {
          var cta = (body.ctaLabel && body.ctaUrl)
            ? '<a class="wfc-cta" href="' + esc(body.ctaUrl) + '" rel="noopener">' + esc(body.ctaLabel) + '</a>'
            : "";
          root.innerHTML =
            '<div class="wfc-backdrop"></div>' +
            '<div class="wfc-card">' +
              '<div class="wfc-strip"></div>' +
              '<button type="button" class="wfc-close" aria-label="Dismiss">&times;</button>' +
              '<div class="wfc-body">' +
                '<h2 class="wfc-heading">' + esc(body.heading) + '</h2>' +
                '<p class="wfc-text">' + esc(body.body) + '</p>' + cta +
              '</div>' +
            '</div>';
        }

        document.body.appendChild(root);

        var exitTimer;
        function dismiss() {
          clearTimeout(exitTimer);
          root.classList.remove("wfc-in");
          setTimeout(function () { if (root.parentNode) root.parentNode.removeChild(root); }, ANIM_MS);
        }
        root.querySelector(".wfc-close").addEventListener("click", dismiss);
        root.querySelector(".wfc-backdrop").addEventListener("click", dismiss);
        requestAnimationFrame(function () { root.classList.add("wfc-in"); });
        exitTimer = setTimeout(dismiss, HOLD_MS + ANIM_MS);
      }

      function boot() {
        // Landing page only — the takeover is a home-page announcement.
        if (location.pathname !== "/") return;
        fetch(API_URL, { cache: "no-store", credentials: "omit" })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (payload) {
            if (payload && payload.takeover && payload.takeover.template) {
              render(payload.takeover.template.body);
            }
          })
          .catch(function () { /* silent — the site keeps working */ });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
    })();
  </script>
</body>
</html>
