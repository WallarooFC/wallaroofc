---
import Crest from './Crest.astro';
import { CLUBS, CLUB_ORDER } from '../lib/clubs.ts';
---
<section class="ypfl-strip" aria-labelledby="ypfl-heading">
  <div class="ypfl-strip-inner">
    <div class="ypfl-strip-header reveal">
      <div class="ypfl-strip-title">
        <span class="num" aria-hidden="true">09</span>
        <span class="text">
          <span class="heading" id="ypfl-heading">YPFL 2026 Clubs</span>
          <span class="sub">Yorke Peninsula Football League · 30 Years of Auskick</span>
        </span>
      </div>
      <a href="https://ypfl.com.au" class="ypfl-strip-link">YPFL.com.au →</a>
    </div>

    <div class="ypfl-clubs reveal reveal-delay-1">
      {CLUB_ORDER.map(slug => {
        const c = CLUBS[slug];
        return (
          <a href={slug === 'wallaroo' ? '/' : `https://ypfl.com.au/${slug}`} class={`ypfl-club${slug === 'wallaroo' ? ' is-self' : ''}`}>
            <div class="crest-wrap"><Crest club={slug} size={96} /></div>
            <div class="club-name">{c.name}</div>
            <div class="club-nick">{c.nickname}</div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .ypfl-strip { background: var(--blue-darkest); color: var(--white); padding: 64px 32px; position: relative; overflow: hidden; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .ypfl-strip::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(200,16,46,0.08) 0%, transparent 60%); }
  .ypfl-strip-inner { max-width: 1400px; margin: 0 auto; position: relative; z-index: 2; }
  .ypfl-strip-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; flex-wrap: wrap; gap: 20px; }
  .ypfl-strip-title { display: flex; align-items: center; gap: 18px; }
  .ypfl-strip-title .num { font-family: var(--display); font-size: 56px; color: var(--red); line-height: 1; }
  .ypfl-strip-title .text { display: flex; flex-direction: column; }
  .ypfl-strip-title .heading { font-family: var(--display); font-size: 28px; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1; margin-bottom: 6px; }
  .ypfl-strip-title .sub { font-family: var(--serif); font-style: italic; font-size: 14px; color: rgba(255,255,255,0.6); }
  .ypfl-strip-link { font-family: var(--headline); font-size: 14px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); border-bottom: 2px solid var(--red); padding-bottom: 4px; }
  .ypfl-clubs { display: grid; grid-template-columns: repeat(9, 1fr); gap: 24px; align-items: end; }
  .ypfl-club { text-align: center; cursor: pointer; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .ypfl-club:hover { transform: translateY(-6px); }
  .ypfl-club .crest-wrap { width: 100%; aspect-ratio: 1; max-width: 96px; margin: 0 auto 12px; filter: drop-shadow(0 6px 16px rgba(0,0,0,0.4)); transition: filter 0.3s; }
  .ypfl-club:hover .crest-wrap { filter: drop-shadow(0 10px 24px rgba(200,16,46,0.4)); }
  .ypfl-club .club-name { font-family: var(--headline); font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--white); line-height: 1.2; margin-bottom: 2px; }
  .ypfl-club .club-nick { font-family: var(--serif); font-style: italic; font-size: 11px; color: rgba(255,255,255,0.5); }
  .ypfl-club.is-self .club-name { color: var(--red); }
  .ypfl-club.is-self .crest-wrap { filter: drop-shadow(0 6px 20px rgba(200,16,46,0.6)); }

  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }

  @media (max-width: 1100px) { .ypfl-clubs { grid-template-columns: repeat(5, 1fr); } }
  @media (max-width: 768px) { .ypfl-clubs { grid-template-columns: repeat(3, 1fr); gap: 16px; } }
</style>
