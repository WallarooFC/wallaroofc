---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import wallarooOval from '../assets/photos/wallaroo-oval-home-crowd.jpg';
import u11Contest from '../assets/photos/u11-contest-vs-yorketown.jpg';
import inThePack from '../assets/photos/in-the-pack.jpg';
import midfieldBattle from '../assets/photos/midfield-battle.jpg';
import onTheRun from '../assets/photos/on-the-run.jpg';
import firstToTheFooty from '../assets/photos/first-to-the-footy.jpg';
import bulldogsVsCrows from '../assets/photos/bulldogs-vs-crows.jpg';
import matchDayRunner from '../assets/photos/match-day-runner.jpg';
import bulldogsInContest from '../assets/photos/bulldogs-in-the-contest.jpg';
import quickHands from '../assets/photos/quick-hands.jpg';
import openFieldRunning from '../assets/photos/open-field-running.jpg';

interface PhotoTile {
  src: ImageMetadata;
  alt: string;
  caption: string;
  size?: 'tall' | 'wide';
}

const photos: PhotoTile[] = [
  { src: wallarooOval, alt: 'Wallaroo Oval home crowd', caption: 'Wallaroo Oval · home crowd', size: 'wide' },
  { src: u11Contest, alt: 'U11 contest against Yorketown', caption: 'U11 contest · vs Yorketown', size: 'tall' },
  { src: inThePack, alt: 'Players in the pack contesting the ball', caption: 'In the pack' },
  { src: midfieldBattle, alt: 'Midfield battle for possession', caption: 'Midfield battle' },
  { src: onTheRun, alt: 'Bulldogs player on the run', caption: 'On the run', size: 'tall' },
  { src: firstToTheFooty, alt: 'First to the footy contest', caption: 'First to the footy' },
  { src: bulldogsVsCrows, alt: 'Bulldogs vs CMS Crows', caption: 'Bulldogs vs Crows', size: 'wide' },
  { src: matchDayRunner, alt: 'Match-day runner', caption: 'Match-day runner' },
  { src: bulldogsInContest, alt: 'Bulldogs in the contest', caption: 'Bulldogs in the contest', size: 'wide' },
  { src: quickHands, alt: 'Quick hands disposing of the ball', caption: 'Quick hands', size: 'tall' },
  { src: openFieldRunning, alt: 'Open field running with the ball', caption: 'Open field running' },
];
---
<section class="gallery" aria-labelledby="gallery-heading">
  <div class="gallery-inner">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">From the Boundary</div>
        <h2 class="section-title" id="gallery-heading">Bulldogs in the <span class="ital">moment</span></h2>
      </div>
      <a href="/gallery/" class="section-link">Full Gallery →</a>
    </div>

    <div class="gallery-grid reveal reveal-delay-1">
      {photos.map(p => (
        <figure class={`gallery-item${p.size ? ` ${p.size}` : ''}`}>
          <Image
            src={p.src}
            alt={p.alt}
            widths={[320, 640, 960, 1280]}
            sizes="(max-width: 700px) 90vw, (max-width: 1100px) 45vw, 25vw"
            loading="lazy"
            decoding="async"
            format="webp"
            class="gallery-photo"
          />
          <figcaption class="meta">{p.caption}</figcaption>
        </figure>
      ))}
    </div>

    <div class="gallery-cta reveal reveal-delay-2">
      <p>More photos from match days uploaded weekly. Got a great shot? Tag <strong>#BulldogsForever</strong>.</p>
    </div>
  </div>
</section>

<style>
  .gallery { background: var(--cream); padding: 120px 32px; }
  .gallery-inner { max-width: 1400px; margin: 0 auto; }
  .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px; gap: 32px; flex-wrap: wrap; }
  .section-eyebrow { font-family: var(--headline); font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; display: flex; align-items: center; gap: 14px; }
  .section-eyebrow::before { content: ''; width: 36px; height: 3px; background: var(--red); }
  .section-title { font-family: var(--display); font-size: clamp(48px, 6vw, 88px); line-height: 0.92; color: var(--blue-deep); text-transform: uppercase; }
  .section-title .ital { font-family: var(--serif); font-style: italic; font-weight: 400; color: var(--red); text-transform: none; letter-spacing: -0.02em; }
  .section-link { font-family: var(--headline); font-size: 16px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue-deep); border-bottom: 3px solid var(--red); padding-bottom: 4px; }

  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 220px; gap: 12px; }
  .gallery-item { background: var(--blue-darkest); border-radius: 4px; overflow: hidden; position: relative; cursor: pointer; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); display: block; margin: 0; }
  .gallery-item:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.2); }
  .gallery-item.tall { grid-row: span 2; }
  .gallery-item.wide { grid-column: span 2; }
  .gallery-item :global(.gallery-photo) { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover :global(.gallery-photo) { transform: scale(1.06); }
  .gallery-item::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 50%; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%); pointer-events: none; z-index: 1; opacity: 0; transition: opacity 0.3s; }
  .gallery-item:hover::after { opacity: 1; }
  .gallery-item .meta { position: absolute; bottom: 16px; left: 16px; font-family: var(--headline); font-size: 11px; letter-spacing: 0.14em; color: rgba(255,255,255,0.95); text-transform: uppercase; z-index: 3; font-weight: 500; opacity: 0; transform: translateY(8px); transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .gallery-item:hover .meta { opacity: 1; transform: translateY(0); }
  .gallery-cta { margin-top: 40px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px; }
  .gallery-cta p { font-family: var(--serif); font-style: italic; color: var(--grey); }

  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }

  @media (max-width: 1100px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 700px) {
    .gallery { padding: 80px 24px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 180px; }
    .gallery-item.wide, .gallery-item.tall { grid-column: span 1; grid-row: span 1; }
  }
</style>
