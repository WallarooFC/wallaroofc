---
const stages = [
  { circle: 'Auskick', age: 'Ages 5–7', name: 'First Kicks', desc: 'Saturday morning fundamentals. No scores, no pressure. Just running, kicking and laughing.' },
  { circle: 'U9', age: 'Ages 7–9', name: 'Under 9', desc: 'First match-day jumper. Bridging Auskick and competition footy with modified rules and a 9am bounce.' },
  { circle: 'U11', age: 'Ages 9–11', name: 'Under 11', desc: 'Modified rules and full grades. First taste of YPFL competition with weekly fixtures.' },
  { circle: 'U14', age: 'Ages 12–14', name: 'Under 14', desc: 'Full-field football, structured training. Where many lifelong Bulldogs careers begin.' },
  { circle: 'U17', age: 'Ages 15–17', name: 'Under 17', desc: 'Senior pathway prep. Pre-season with the B Grade. Some debut for A-Grade in their final year.' },
  { circle: 'A-Grade', age: '18+', name: 'Senior Football', desc: 'B Grade and A-Grade. The same red, white and blue your dad wore. And his dad before him.' },
];
---
<section class="pathway" aria-labelledby="pathway-heading">
  <div class="pw2-inner">
    <div class="pw2-header reveal">
      <div class="section-eyebrow centered">The Pathway</div>
      <h2 id="pathway-heading">Five &amp; up. From Auskick<span class="ital">to A-Grade.</span></h2>
      <p>A clear path from your child's first kick on the Wallaroo Oval grass to running out for the Bulldogs A-Grade. Every stage. Every Saturday. Every winter.</p>
    </div>

    <div class="pw2-flow reveal reveal-delay-1">
      {stages.map(s => (
        <div class="pw2-stage">
          <div class="pw2-circle">{s.circle}</div>
          <div class="pw2-age">{s.age}</div>
          <div class="pw2-name">{s.name}</div>
          <div class="pw2-desc">{s.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pathway { background: linear-gradient(135deg, var(--blue-deep) 0%, var(--blue-darkest) 100%); color: var(--white); padding: 120px 32px; position: relative; overflow: hidden; }
  .pathway::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 80% 20%, rgba(200,16,46,0.2) 0%, transparent 60%); }
  .pw2-inner { max-width: 1400px; margin: 0 auto; position: relative; z-index: 2; }
  .pw2-header { text-align: center; margin-bottom: 64px; }
  .section-eyebrow { font-family: var(--headline); font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; display: flex; align-items: center; gap: 14px; }
  .section-eyebrow::before { content: ''; width: 36px; height: 3px; background: var(--red); }
  .section-eyebrow.centered { justify-content: center; }
  .pw2-header h2 { font-family: var(--display); font-size: clamp(48px, 6vw, 88px); line-height: 0.92; text-transform: uppercase; margin-bottom: 16px; }
  .pw2-header h2 .ital { font-family: var(--serif); font-style: italic; color: var(--red); text-transform: none; letter-spacing: -0.02em; }
  .pw2-header p { font-family: var(--serif); font-style: italic; font-size: 19px; color: rgba(255,255,255,0.7); max-width: 640px; margin: 0 auto; }
  .pw2-flow { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; position: relative; }
  .pw2-flow::before { content: ''; position: absolute; top: 60px; left: 5%; right: 5%; height: 2px; background: linear-gradient(90deg, transparent 0%, var(--red) 20%, var(--red) 80%, transparent 100%); opacity: 0.4; z-index: 0; }
  .pw2-stage { position: relative; z-index: 2; text-align: center; padding: 24px 16px; }
  .pw2-circle { width: 120px; height: 120px; border-radius: 50%; background: var(--blue-darkest); border: 3px solid var(--red); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-family: var(--display); font-size: 22px; letter-spacing: 0.04em; color: var(--white); text-align: center; line-height: 1.1; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 8px 24px rgba(0,0,0,0.25); }
  .pw2-stage:hover .pw2-circle { transform: scale(1.08); border-color: var(--white); background: var(--red); }
  .pw2-age { font-family: var(--headline); font-size: 12px; letter-spacing: 0.18em; color: var(--red); margin-bottom: 6px; text-transform: uppercase; }
  .pw2-name { font-family: var(--display); font-size: 18px; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 8px; }
  .pw2-desc { font-family: var(--serif); font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.5; }

  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }

  @media (max-width: 1100px) { .pw2-flow { grid-template-columns: repeat(3, 1fr); } .pw2-flow::before { display: none; } }
  @media (max-width: 700px) { .pw2-flow { grid-template-columns: repeat(2, 1fr); } .pw2-circle { width: 90px; height: 90px; font-size: 16px; } .pathway { padding: 80px 24px; } }
</style>
