---
import Crest from './Crest.astro';

const cols = [
  {
    heading: 'Football',
    links: [
      { label: 'Fixtures & Results', href: '/fixtures/' },
      { label: 'Ladder', href: '/ladders/' },
      { label: 'Players & Staff', href: '/teams/a-grade/' },
      { label: 'Juniors', href: '/juniors/' },
      { label: 'Register', href: '/membership/' },
    ],
  },
  {
    heading: 'Club',
    links: [
      { label: 'Membership', href: '/membership/' },
      { label: 'Sponsors', href: '/sponsors/' },
      { label: 'Events & Hospitality', href: '/social/' },
      { label: 'Bingo', href: '/social/#bingo' },
      { label: 'Clubroom Hire', href: '/about/#hire' },
    ],
  },
];
---
<footer>
  <div class="footer-watermark" aria-hidden="true">
    <Crest club="wallaroo" size={600} altOverride="" />
  </div>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-brand-row">
          <div class="footer-logo"><Crest club="wallaroo" size={64} /></div>
          <div>
            <div class="name">Wallaroo FC</div>
            <div class="est">The Bulldogs · Est. 1867</div>
          </div>
        </div>
        <span class="tag">One of Australia's oldest continuously running football clubs. Playing in red, white and blue on the Yorke Peninsula since the late 1960s — and on the same patch of ground since 1867.</span>
        <div class="footer-socials">
          <a href="https://facebook.com/WallarooFC" aria-label="Wallaroo FC on Facebook">f</a>
          <a href="https://instagram.com/wallaroofc" aria-label="Wallaroo FC on Instagram">◉</a>
          <a href="mailto:admin@wallaroofc.com.au" aria-label="Email Wallaroo FC">✉</a>
        </div>
      </div>
      {cols.map(col => (
        <div class="footer-col">
          <h3>{col.heading}</h3>
          <ul>
            {col.links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
        </div>
      ))}
      <div class="footer-col">
        <h3>Contact</h3>
        <ul>
          <li>Wallaroo Oval</li>
          <li>Cornish Terrace, Wallaroo SA 5556</li>
          <li>PO Box 106, Wallaroo</li>
          <li><a href="mailto:admin@wallaroofc.com.au">admin@wallaroofc.com.au</a></li>
        </ul>
      </div>
    </div>

    <div class="acknowledgment">
      <div class="label">Acknowledgment of Country</div>
      Wallaroo Football Club acknowledges the Narungga people as the Traditional Custodians of the lands on which we play, train and gather. We pay our respects to Elders past and present, and recognise the continuing connection of First Nations people to the country, waters and culture of the Yorke Peninsula.
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Wallaroo Football Club Inc. · YPFL · SANFL Affiliate</span>
      <span>Privacy · Code of Conduct · Policies</span>
      <a href="/admin/" class="admin-link">Staff Login</a>
    </div>
  </div>
</footer>

<style>
  footer { background: var(--blue-darkest); color: var(--white); padding: 96px 32px 32px; position: relative; overflow: hidden; }
  footer::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px; background: linear-gradient(90deg, var(--red) 0%, var(--red) 30%, var(--white) 30%, var(--white) 70%, var(--blue) 70%, var(--blue) 100%); }
  .footer-watermark { position: absolute; right: -3%; bottom: -25%; width: 600px; height: 600px; opacity: 0.03; pointer-events: none; }
  .footer-inner { max-width: 1400px; margin: 0 auto; position: relative; z-index: 5; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 56px; padding-bottom: 56px; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .footer-brand { display: flex; flex-direction: column; gap: 20px; }
  .footer-brand-row { display: flex; align-items: center; gap: 16px; }
  .footer-logo { width: 64px; height: 64px; flex-shrink: 0; }
  .footer-brand .name { font-family: var(--display); font-size: 32px; letter-spacing: 0.04em; text-transform: uppercase; line-height: 1; }
  .footer-brand .est { font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--red); margin-top: 4px; }
  .footer-brand .tag { font-family: var(--serif); font-style: italic; font-size: 16px; color: rgba(255,255,255,0.6); max-width: 360px; line-height: 1.6; }
  .footer-socials { display: flex; gap: 12px; margin-top: 12px; }
  .footer-socials a { width: 44px; height: 44px; border: 1px solid rgba(255,255,255,0.2); display: grid; place-items: center; border-radius: 50%; transition: all 0.3s; font-family: var(--display); font-size: 18px; text-decoration: none; color: inherit; }
  .footer-socials a:hover { background: var(--red); border-color: var(--red); transform: translateY(-3px); }
  .footer-col h3 { font-family: var(--headline); font-size: 14px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); margin-bottom: 20px; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; padding: 0; }
  .footer-col li { font-size: 15px; color: rgba(255,255,255,0.7); }
  .footer-col a { font-size: 15px; color: rgba(255,255,255,0.7); transition: all 0.2s; }
  .footer-col a:hover { color: var(--red); padding-left: 4px; }

  .acknowledgment { border-top: 1px solid rgba(255,255,255,0.1); margin-top: 32px; padding-top: 32px; font-family: var(--serif); font-style: italic; font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; max-width: 800px; }
  .acknowledgment .label { font-family: var(--headline); font-style: normal; font-size: 11px; letter-spacing: 0.18em; color: var(--red); margin-bottom: 8px; text-transform: uppercase; }

  .footer-bottom { padding-top: 32px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: rgba(255,255,255,0.4); flex-wrap: wrap; gap: 16px; font-family: var(--headline); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 32px; }
  .admin-link { color: rgba(255,255,255,0.2); font-size: 11px; transition: color 0.2s; }
  .admin-link:hover { color: rgba(255,255,255,0.5); }

  @media (max-width: 1100px) { .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; } }
  @media (max-width: 768px) { footer { padding: 64px 24px 24px; } .footer-top { grid-template-columns: 1fr; } }
</style>
