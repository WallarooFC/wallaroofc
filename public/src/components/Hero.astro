---
import Crest from './Crest.astro';

interface SponsorItem {
  name: string;
  logo?: string;
}

interface Props {
  round: number;
  homeTeam: { name: string; record: string };
  awayTeam: { slug: 'wallaroo' | 'ardrossan' | 'bute' | 'central-yorke' | 'cms' | 'kadina' | 'moonta' | 'paskeville' | 'southern-eagles'; name: string; record: string };
  date: string;
  bounce: string;
  venue: string;
  homeOrAway: 'HOME' | 'AWAY';
  /** Sponsor items for the inline ribbon at the stats row level. */
  ribbonItems?: SponsorItem[];
}

const { round, homeTeam, awayTeam, date, bounce, venue, homeOrAway, ribbonItems = [] } = Astro.props;
const ribbonTrack = ribbonItems.length > 0 ? [...ribbonItems, ...ribbonItems] : [];
---
<section class="hero" aria-labelledby="hero-title">
  <div class="hero-bg-base"></div>
  <div class="hero-slash"></div>
  <div class="hero-grid"></div>
  <div class="hero-noise"></div>
  <div class="hero-1867" aria-hidden="true">1867</div>

  <div class="hero-watermark" aria-hidden="true">
    <Crest
      club="wallaroo"
      size={780}
      widths={[380, 780, 1200]}
      sizes="(max-width: 768px) 380px, 780px"
      loading="eager"
      fetchpriority="high"
      altOverride=""
    />
  </div>

  <div class="hero-inner">
    <!-- ── Row 1 col 1: eyebrow + title + lede ── -->
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="live-dot" aria-hidden="true"></span>
        <span>Round {round} · This Saturday</span>
        <span class="divider" aria-hidden="true"></span>
        <span class="red-text">YPFL 2026</span>
      </div>
      <h1 class="hero-title" id="hero-title">
        <span class="line">HOME</span>
        <span class="line">OF THE</span>
        <span class="line"><span class="red">BULLDOGS.</span></span>
      </h1>
      <p class="hero-lede">
        159 winters on the Yorke Peninsula. Founded at the Globe Inn, June 17, 1867.
        Never merged, never folded. <em>This is country footy at its purest.</em>
      </p>
    </div>

    <!-- ── Row 1 col 2: next-match card + CTAs + stats ── -->
    <div class="hero-right">
      <article class="next-match" aria-label={`Next match — Round ${round}`}>
        <div class="nm-header">
          <span class="label">Next Match · Round {round}</span>
          <span class="tag">{homeOrAway}</span>
        </div>
        <div class="nm-body">
          <div class="nm-grades">A-Grade · B Grade · U17 · U14 · U11 · U9</div>
          <div class="nm-fixture">
            <div class="nm-team">
              <div class="nm-crest-wrap"><Crest club="wallaroo" size={90} loading="eager" /></div>
              <div class="team-name">{homeTeam.name}</div>
              <div class="record">{homeTeam.record}</div>
            </div>
            <div class="nm-vs" aria-hidden="true">VS</div>
            <div class="nm-team">
              <div class="nm-crest-wrap"><Crest club={awayTeam.slug} size={90} loading="eager" /></div>
              <div class="team-name">{awayTeam.name}</div>
              <div class="record">{awayTeam.record}</div>
            </div>
          </div>
          <div class="nm-meta">
            <div class="nm-meta-item"><div class="label">Date</div><div class="val">{date}</div></div>
            <div class="nm-meta-item"><div class="label">Bounce</div><div class="val">{bounce}</div></div>
            <div class="nm-meta-item"><div class="label">Venue</div><div class="val">{venue}</div></div>
          </div>
        </div>
      </article>
      <div class="hero-ctas">
        <a class="btn-primary" href="/membership/"><span>Register to play</span><span class="arrow" aria-hidden="true">→</span></a>
        <a class="btn-ghost" href="#this-week"><span>This week's matches</span></a>
      </div>
      <div class="hero-stats" role="list">
        <div class="hero-stat" role="listitem"><div class="num">159</div><div class="label">Years strong</div></div>
        <div class="hero-stat" role="listitem"><div class="num">27</div><div class="label">A-Grade flags</div></div>
        <div class="hero-stat" role="listitem"><div class="num">5</div><div class="label">Senior grades</div></div>
        <div class="hero-stat" role="listitem"><div class="num">70+</div><div class="label">Sponsors</div></div>
      </div>
    </div>

    <!-- ── Row 2: sponsor ribbon full width ── -->
    <div class="hero-bottom" aria-hidden="true">
      {ribbonTrack.length > 0 && (
        <div class="hr-track">
          {ribbonTrack.map(item => (
            <div class="hr-item">
              <span class="hr-dot">◆</span>
              {item.logo
                ? <div class="hr-pill"><img src={item.logo} alt={item.name} loading="lazy" decoding="async" /></div>
                : <span class="hr-name">{item.name}</span>
              }
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="hero-decoration-crest" aria-hidden="true">
    <Crest club="wallaroo" size={80} altOverride="" />
  </div>
</section>

<style>
  /* ── Hero shell ── */
  .hero {
    position: relative;
    min-height: 92vh;
    background: var(--blue-darkest);
    color: var(--white);
    overflow: hidden;
    border-bottom: 8px solid var(--red);
  }

  /* ── Decorative backgrounds ── */
  .hero-bg-base { position: absolute; inset: 0; background: radial-gradient(ellipse at 75% 30%, rgba(200,16,46,0.4) 0%, transparent 50%), radial-gradient(ellipse at 20% 80%, rgba(20,49,92,0.6) 0%, transparent 60%), linear-gradient(180deg, var(--blue-darkest) 0%, var(--blue-deep) 100%); }
  .hero-slash { position: absolute; top: -10%; right: -20%; width: 80%; height: 140%; background: linear-gradient(115deg, transparent 40%, rgba(200,16,46,0.18) 50%, transparent 60%); pointer-events: none; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(0deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%); pointer-events: none; }
  .hero-noise { position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6' /%3E%3C/svg%3E"); opacity: 0.15; mix-blend-mode: overlay; pointer-events: none; }
  .hero-1867 { position: absolute; left: -2%; bottom: -18%; font-family: var(--display); font-size: clamp(280px, 38vw, 560px); line-height: 0.85; color: var(--white); opacity: 0.04; letter-spacing: -0.02em; pointer-events: none; user-select: none; }
  .hero-watermark { position: absolute; right: -6%; top: -8%; width: 780px; height: 780px; opacity: 0.10; pointer-events: none; animation: breathe 6s ease-in-out infinite; z-index: 1; }
  .hero-watermark :global(img) { width: 100%; height: 100%; object-fit: contain; }

  /* ── Grid: 2 columns, 2 rows ──
     Row 1 (1fr)  : hero-content | hero-right
     Row 2 (auto) : hero-bottom (spans both columns)        */
  .hero-inner {
    position: relative;
    z-index: 5;
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 32px 100px;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    grid-template-rows: 1fr auto;
    column-gap: 56px;
    row-gap: 0;
    min-height: calc(92vh - 8px);
  }

  /* ── Row 1, col 1: textual content ── */
  .hero-content {
    grid-column: 1;
    grid-row: 1;
    align-self: center;
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 14px; font-family: var(--headline); font-size: 14px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); margin-bottom: 32px; }
  .hero-eyebrow .live-dot { width: 10px; height: 10px; background: var(--red); border-radius: 50%; box-shadow: 0 0 0 4px rgba(200,16,46,0.3); animation: pulse 1.4s ease-in-out infinite; }
  .hero-eyebrow .divider { width: 36px; height: 1px; background: rgba(255,255,255,0.4); }
  .hero-eyebrow .red-text { color: var(--red); }
  .hero-title { font-family: var(--display); font-size: clamp(72px, 11vw, 168px); line-height: 0.86; letter-spacing: -0.005em; margin-bottom: 28px; text-transform: uppercase; font-weight: 400; }
  .hero-title .line { display: block; }
  .hero-title .red { color: var(--red); position: relative; display: inline-block; }
  .hero-title .red::after { content: ''; position: absolute; left: 0; bottom: 8%; height: 6px; width: 100%; background: var(--red); opacity: 0.3; }
  .hero-lede { font-family: var(--serif); font-size: 21px; line-height: 1.5; color: rgba(255,255,255,0.8); max-width: 540px; margin-bottom: 0; border-left: 3px solid var(--red); padding-left: 20px; animation: fadeUp 0.9s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both; }

  /* ── Row 1, col 2: next-match card + CTAs + stats ── */
  .hero-right {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    gap: 20px;
    animation: scaleIn 1s 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; animation: fadeUp 0.9s 0.35s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .btn-primary { background: var(--red); color: var(--white); font-family: var(--headline); font-size: 17px; letter-spacing: 0.12em; text-transform: uppercase; padding: 18px 32px; border: 3px solid var(--red); position: relative; overflow: hidden; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); display: inline-flex; align-items: center; gap: 12px; cursor: pointer; }
  .btn-primary::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--white); transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .btn-primary span { position: relative; z-index: 2; transition: color 0.4s; }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 20px 40px rgba(200,16,46,0.3); }
  .btn-primary:hover::before { left: 0; }
  .btn-primary:hover span { color: var(--red); }
  .btn-primary .arrow { transition: transform 0.3s; position: relative; z-index: 2; }
  .btn-primary:hover .arrow { transform: translateX(6px); }
  .btn-ghost { background: transparent; color: var(--white); font-family: var(--headline); font-size: 17px; letter-spacing: 0.12em; text-transform: uppercase; padding: 18px 32px; border: 3px solid rgba(255,255,255,0.3); transition: all 0.3s; display: inline-flex; align-items: center; gap: 12px; cursor: pointer; }
  .btn-ghost:hover { border-color: var(--white); background: rgba(255,255,255,0.08); transform: translateY(-3px); }

  /* ── Next-match card ── */
  .next-match { background: var(--white); color: var(--charcoal); width: 100%; max-width: 480px; border-radius: 6px; overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.45), 0 8px 24px rgba(0,0,0,0.25); position: relative; z-index: 2; border-top: 6px solid var(--red); }
  .nm-header { background: var(--blue-deep); color: var(--white); padding: 18px 28px; display: flex; justify-content: space-between; align-items: center; font-family: var(--headline); text-transform: uppercase; letter-spacing: 0.1em; font-size: 14px; position: relative; overflow: hidden; }
  .nm-header::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 0%, rgba(200,16,46,0.15) 50%, transparent 100%); background-size: 200% 100%; animation: shimmer 4s ease-in-out infinite; }
  .nm-header .label, .nm-header .tag { position: relative; z-index: 1; }
  .nm-header .tag { background: var(--red); padding: 5px 11px; font-size: 11px; letter-spacing: 0.12em; }
  .nm-body { padding: 32px 28px 28px; }
  .nm-grades { font-family: var(--headline); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--grey); text-align: center; margin-bottom: 22px; }
  .nm-fixture { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; margin-bottom: 28px; }
  .nm-team { text-align: center; }
  .nm-crest-wrap { width: 90px; height: 90px; margin: 0 auto 12px; position: relative; }
  .nm-team .team-name { font-family: var(--display); font-size: 20px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--blue-deep); line-height: 1; margin-bottom: 4px; }
  .nm-team .record { font-size: 12px; font-family: var(--headline); letter-spacing: 0.1em; color: var(--grey); text-transform: uppercase; }
  .nm-vs { font-family: var(--display); font-size: 36px; color: var(--red); }
  .nm-meta { background: var(--cream); margin: 0 -28px -28px; padding: 22px 28px; border-top: 2px solid var(--line); display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; text-align: center; }
  .nm-meta-item .label { font-family: var(--headline); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--grey); margin-bottom: 4px; }
  .nm-meta-item .val { font-family: var(--display); font-size: 18px; letter-spacing: 0.03em; color: var(--blue-deep); text-transform: uppercase; }

  /* ── Stats: now inside hero-right, below CTAs ── */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 16px;
    animation: fadeUp 0.9s 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-stat { position: relative; }
  .hero-stat:not(:last-child)::after { content: ''; position: absolute; right: -6px; top: 4px; bottom: 4px; width: 1px; background: rgba(255,255,255,0.12); }
  .hero-stat .num { font-family: var(--display); font-size: 44px; line-height: 1; color: var(--white); margin-bottom: 6px; letter-spacing: 0.01em; }
  .hero-stat:nth-child(1) .num, .hero-stat:nth-child(3) .num { color: var(--red); }
  .hero-stat .label { font-family: var(--headline); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.65); }

  /* ── Row 2: sponsor ribbon full width ── */
  .hero-bottom {
    grid-column: 1 / -1;
    grid-row: 2;
    border-top: 2px solid rgba(255,255,255,0.12);
    overflow: hidden;
    height: 128px;
    position: relative;
  }
  .hr-track {
    display: inline-flex;
    align-items: center;
    height: 100%;
    animation: scroll-left 240s linear infinite;
    will-change: transform;
    white-space: nowrap;
  }
  .hero:hover .hr-track {
    animation-play-state: paused;
  }
  .hr-item {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 0 32px;
    height: 100%;
    flex-shrink: 0;
  }
  .hr-pill {
    background: #fff;
    border-radius: 4px;
    padding: 4px 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 90px;
    box-sizing: border-box;
    opacity: 0.92;
    transition: opacity 0.2s;
  }
  .hr-item:hover .hr-pill { opacity: 1; }
  .hr-pill img {
    height: 78px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
    display: block;
  }
  .hr-name {
    font-family: var(--headline);
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    white-space: nowrap;
  }
  .hr-dot {
    font-size: 6px;
    color: var(--red);
    flex-shrink: 0;
  }

  /* ── Decoration crest ── */
  .hero-decoration-crest { position: absolute; bottom: 30px; left: 30px; width: 80px; height: 80px; opacity: 0.4; animation: spin-slow 60s linear infinite; pointer-events: none; z-index: 4; }

  /* ── Keyframes ── */
  @keyframes fadeUp    { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes scaleIn   { from { opacity: 0; transform: scale(0.85); } to { opacity: 1; transform: scale(1); } }
  @keyframes pulse     { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(0.85); } }
  @keyframes breathe   { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }
  @keyframes shimmer   { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes scroll-left { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .hero-inner { grid-template-columns: 1fr; grid-template-rows: auto auto auto; }
    .hero-content { grid-column: 1; grid-row: 1; align-self: auto; }
    .hero-right { grid-column: 1; grid-row: 2; }
    .hero-bottom { display: none; }
    .hero-stats { border-top: 2px solid rgba(255,255,255,0.12); padding-top: 20px; grid-template-columns: repeat(4, 1fr); }
    .hero-stat .num { font-size: 36px; }
  }
  @media (max-width: 768px) {
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
    .hero-watermark { width: 380px; height: 380px; right: -18%; top: -5%; }
    .hero-1867 { font-size: 220px; }
  }
</style>
