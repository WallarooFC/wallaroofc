---
import { Image } from 'astro:assets';
import { CLUBS, type ClubSlug } from '../lib/clubs.ts';

interface Props {
  club: ClubSlug;
  /** Display size in CSS px (largest viewport). Astro emits 1x + 2x variants by default. */
  size: number;
  /** Optional explicit widths array — overrides densities. Use for responsive crests. */
  widths?: number[];
  /** Companion sizes attribute when widths is set. */
  sizes?: string;
  /** Optional aria-label override (e.g. for decorative uses). Leave unset for normal use. */
  altOverride?: string;
  /** Override default lazy loading for above-the-fold crests. */
  loading?: 'lazy' | 'eager';
  /** Native fetch priority. Use 'high' for LCP candidates. */
  fetchpriority?: 'auto' | 'high' | 'low';
  class?: string;
}

const {
  club, size, widths, sizes,
  altOverride, loading = 'lazy', fetchpriority, class: className = '',
} = Astro.props;
const c = CLUBS[club];
if (!c) throw new Error(`Unknown club: ${club}`);

// When widths is supplied, prefer it over densities (responsive srcset).
const imgProps = widths
  ? { widths, sizes: sizes ?? `${size}px` }
  : { densities: [1, 2] };
---
<Image
  src={c.crest}
  alt={altOverride ?? c.altName}
  width={size}
  height={size}
  {...imgProps}
  loading={loading}
  decoding="async"
  format="webp"
  fetchpriority={fetchpriority}
  class={`crest ${className}`}
/>
<style>
  .crest {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.15));
  }
</style>
