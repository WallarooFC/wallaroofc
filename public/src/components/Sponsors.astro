---
interface Tier {
  label: string;
  platinum?: boolean;
  logos: string[];
}

interface Props {
  tiers: Tier[];
}

const { tiers } = Astro.props;
---
<section class="sponsors" aria-labelledby="sponsors-heading">
  <div class="container">
    <div class="section-header reveal centered">
      <div>
        <div class="section-eyebrow centered">2026 Partners</div>
        <h2 class="section-title" id="sponsors-heading">Built by the <span class="ital">community.</span></h2>
      </div>
    </div>

    {tiers.map((t, i) => (
      <div class={`reveal reveal-delay-${i}`}>
        <div class="sponsors-tier-label">{t.label}</div>
        <div class={`sponsors-tier${t.platinum ? ' platinum-tier' : ''}`}>
          {t.logos.map(name => (
            <span class={`sponsor-logo${t.platinum ? ' platinum' : ''}`}>{name}</span>
          ))}
        </div>
      </div>
    ))}

    <div class="sponsors-cta-block reveal reveal-delay-2">
      <p>Plus 60+ Silver and Bronze partners across Yorke Peninsula and beyond.</p>
      <a class="sponsor-cta" href="/sponsors/">
        <span>Become a 2026 sponsor</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .sponsors { background: var(--white); text-align: center; padding: 120px 32px; }
  .container { max-width: 1400px; margin: 0 auto; }
  .section-header.centered { justify-content: center; text-align: center; }
  .section-header { display: flex; align-items: flex-end; margin-bottom: 64px; gap: 32px; flex-wrap: wrap; }
  .section-header > div { margin: 0 auto; }
  .section-eyebrow { font-family: var(--headline); font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; display: flex; align-items: center; gap: 14px; }
  .section-eyebrow::before { content: ''; width: 36px; height: 3px; background: var(--red); }
  .section-eyebrow.centered { justify-content: center; }
  .section-title { font-family: var(--display); font-size: clamp(48px, 6vw, 88px); line-height: 0.92; color: var(--blue-deep); text-transform: uppercase; }
  .section-title .ital { font-family: var(--serif); font-style: italic; font-weight: 400; color: var(--red); text-transform: none; letter-spacing: -0.02em; }

  .sponsors-tier-label { font-family: var(--headline); font-size: 13px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--red); margin-bottom: 24px; display: flex; align-items: center; justify-content: center; gap: 20px; }
  .sponsors-tier-label::before, .sponsors-tier-label::after { content: ''; width: 48px; height: 1px; background: var(--red); }
  .sponsors-tier { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 56px; margin-bottom: 56px; padding: 36px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .sponsors-tier.platinum-tier { border-top: 3px solid var(--red); border-bottom: 3px solid var(--red); }
  .sponsor-logo { font-family: var(--serif); font-style: italic; font-size: 24px; color: var(--blue-deep); opacity: 0.65; transition: all 0.3s; cursor: pointer; }
  .sponsor-logo:hover { opacity: 1; transform: scale(1.05); color: var(--red); }
  .sponsor-logo.platinum { font-family: var(--display); font-style: normal; font-size: 44px; color: var(--blue-deep); letter-spacing: 0.04em; text-transform: uppercase; opacity: 0.85; }
  .sponsors-cta-block { margin-top: 24px; display: flex; flex-direction: column; align-items: center; gap: 24px; }
  .sponsors-cta-block p { font-family: var(--serif); font-style: italic; color: var(--grey); max-width: 580px; font-size: 17px; }
  .sponsor-cta { background: var(--blue-deep); color: var(--white); font-family: var(--headline); font-size: 16px; letter-spacing: 0.14em; text-transform: uppercase; padding: 18px 36px; position: relative; overflow: hidden; transition: all 0.3s; display: inline-flex; align-items: center; gap: 12px; }
  .sponsor-cta::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--red); transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .sponsor-cta span { position: relative; z-index: 1; }
  .sponsor-cta:hover::before { left: 0; }
  .sponsor-cta:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(0,0,0,0.2); }

  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }

  @media (max-width: 700px) {
    .sponsors { padding: 80px 24px; }
    .sponsors-tier { gap: 32px; }
    .sponsor-logo.platinum { font-size: 32px; }
  }
</style>
