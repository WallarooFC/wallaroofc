---
interface SocialEntry {
  round: number;
  date: string;
  type: 'event' | 'bye';
  host?: string;
  venue?: string;
  featured?: boolean;
  status?: 'past' | 'now' | 'upcoming';
}

interface Props {
  entries: SocialEntry[];
  note?: string;
}

const { entries, note = 'Social events are hosted at the venue listed. Some rounds align with hotels & sponsor partners; others are held at opposition club venues for after-match catch-ups.' } = Astro.props;
---
<section class="social-calendar" aria-labelledby="social-heading">
  <div class="container">
    <div class="section-header reveal">
      <div>
        <div class="section-eyebrow">WFNC 2026 Social Calendar</div>
        <h2 class="section-title" id="social-heading">Off the field, <span class="ital">on the town</span></h2>
      </div>
      <a href="/social/" class="section-link">Save to phone →</a>
    </div>

    <div class="sc-grid reveal reveal-delay-1">
      {entries.map(e => {
        const classes = ['sc-card'];
        if (e.status === 'past') classes.push('sc-past');
        if (e.status === 'now') classes.push('sc-now');
        if (e.featured) classes.push('sc-featured');
        if (e.type === 'bye') classes.push('sc-bye');
        return (
          <div class={classes.join(' ')}>
            <div class="sc-rnd">{e.status === 'now' ? `R${e.round} · NOW` : `R${e.round}`}</div>
            <div class="sc-date">{e.date}</div>
            {e.type === 'bye' ? (
              <div class="sc-bye-mark" aria-label="Bye round">BYE</div>
            ) : (
              <>
                <div class="sc-host">{e.host}</div>
                <div class="sc-venue">{e.venue}</div>
              </>
            )}
          </div>
        );
      })}
    </div>

    <p class="sc-note reveal reveal-delay-2">{note}</p>
  </div>
</section>

<style>
  .social-calendar { background: var(--cream); padding: 120px 32px; }
  .container { max-width: 1400px; margin: 0 auto; }
  .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px; gap: 32px; flex-wrap: wrap; }
  .section-eyebrow { font-family: var(--headline); font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; display: flex; align-items: center; gap: 14px; }
  .section-eyebrow::before { content: ''; width: 36px; height: 3px; background: var(--red); }
  .section-title { font-family: var(--display); font-size: clamp(48px, 6vw, 88px); line-height: 0.92; color: var(--blue-deep); text-transform: uppercase; }
  .section-title .ital { font-family: var(--serif); font-style: italic; font-weight: 400; color: var(--red); text-transform: none; letter-spacing: -0.02em; }
  .section-link { font-family: var(--headline); font-size: 16px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue-deep); border-bottom: 3px solid var(--red); padding-bottom: 4px; display: inline-flex; align-items: center; gap: 8px; }

  .sc-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 32px; }
  .sc-card { background: var(--white); border: 1px solid var(--line); border-left: 4px solid var(--blue-deep); border-radius: 4px; padding: 18px 16px; display: flex; flex-direction: column; gap: 6px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); position: relative; min-height: 130px; }
  .sc-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(20,49,92,0.1); }
  .sc-card.sc-now { background: linear-gradient(135deg, var(--blue-darkest) 0%, var(--blue-deep) 100%); color: var(--white); border-left-color: var(--red); border: 1px solid var(--red); border-left-width: 4px; box-shadow: 0 12px 32px rgba(200,16,46,0.25); }
  .sc-card.sc-past { background: rgba(20,49,92,0.03); }
  .sc-card.sc-past .sc-host { color: var(--grey); }
  .sc-card.sc-past::after { content: 'PAST'; position: absolute; top: 8px; right: 10px; font-family: var(--headline); font-size: 9px; letter-spacing: 0.14em; color: var(--grey); }
  .sc-card.sc-featured { border-left-color: var(--red); background: linear-gradient(180deg, var(--white) 0%, rgba(245,241,232,0.6) 100%); }
  .sc-card.sc-featured .sc-host { color: var(--red); }
  .sc-card.sc-now.sc-featured .sc-host { color: var(--white); }
  .sc-rnd { font-family: var(--display); font-size: 14px; letter-spacing: 0.06em; color: var(--red); text-transform: uppercase; }
  .sc-card.sc-now .sc-rnd { color: var(--white); }
  .sc-date { font-family: var(--headline); font-size: 11px; letter-spacing: 0.12em; color: var(--grey); text-transform: uppercase; }
  .sc-card.sc-now .sc-date { color: rgba(255,255,255,0.7); }
  .sc-host { font-family: var(--display); font-size: 15px; text-transform: uppercase; letter-spacing: 0.02em; color: var(--blue-deep); line-height: 1.15; margin-top: 6px; flex-grow: 1; }
  .sc-card.sc-now .sc-host { color: var(--white); }
  .sc-venue { font-family: var(--headline); font-size: 12px; letter-spacing: 0.12em; color: var(--grey); text-transform: uppercase; padding-top: 8px; border-top: 1px dashed var(--line); margin-top: 6px; }
  .sc-card.sc-now .sc-venue { color: rgba(255,255,255,0.7); border-top-color: rgba(255,255,255,0.15); }
  .sc-card.sc-bye { background: rgba(20,49,92,0.04); border-style: dashed; border-left-style: solid; border-left-color: var(--grey); align-items: center; justify-content: center; text-align: center; }
  .sc-bye-mark { font-family: var(--display); font-size: 26px; color: var(--grey); margin-top: 4px; }
  .sc-note { font-family: var(--serif); font-style: italic; font-size: 16px; color: var(--grey); max-width: 720px; margin: 32px auto 0; text-align: center; line-height: 1.6; }

  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }

  @media (max-width: 1100px) { .sc-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .sc-grid { grid-template-columns: repeat(2, 1fr); } .social-calendar { padding: 80px 24px; } }
</style>
